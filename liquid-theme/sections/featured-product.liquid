<!-- sections/featured_product.liquid -->
{% comment %}
  Featured product on any page with entire details of the product. This product can output content similar to the product page.

  Globals:
  - layout_horizontal: {string} Horizontal margin from global theme settings.

  Recommendations:
    - Section will be hidden unless a valid product is selected.
{% endcomment %}

{% comment %} Create product script, assign correct gallery style, set column widths {% endcomment %}
{% assign product = section.settings.product %}

{% comment %} Set placeholder product if blank {% endcomment %}
{% if request.design_mode and product == null %}
  {% for product in collections.all.products limit: 1 %}
    {% assign product = product %}
  {% endfor %}
{% endif %}

{% unless product == null %}
  {% liquid
    capture script_product
      render 'script__product', gallery_style: section.settings.media_gallery_style, enable_default_selling_plan_widget: section.settings.enable_default_selling_plan_widget, is_featured: true
    endcapture

    if section.settings.media_gallery_style == 'grid'
      capture gallery_snippet
        render 'product__gallery-grid', is_featured: true
      endcapture
    elsif section.settings.media_gallery_style == 'slider'
      capture gallery_snippet
        render 'product__gallery-slider', is_featured: true
      endcapture
    else
      capture gallery_snippet
        render 'product__gallery-thumbnail-slider', is_featured: true
      endcapture
    endif

    capture left_column_width
      echo section.settings.layout_column_width | append: '%'
    endcapture
    capture right_column_width
      echo 100 | minus: section.settings.layout_column_width | append: '%'
    endcapture
  %}

  <section
    id="{{ section.id }}"
    class="
      js-product-{{ section.id }} animation-1000 relative z-30
      {{ section.settings.color_border }}
      {{ section.settings.style_border }}
      {% unless section.settings.enable_color_fade %}
        {{ section.settings.color_text }}
        {% unless section.settings.color_scheme == 'custom' %}
          {{ section.settings.color_scheme }}
        {% endunless %}
      {% endunless %}
    "
    {% if section.settings.color_scheme == 'custom' %}
      {% unless section.settings.enable_color_fade %}
        style="background:{{ section.settings.color_background }};"
      {% endunless %}
    {% endif %}
    {% if section.settings.enable_color_fade %}
      :class="`${body_background_color} ${body_text_color}`"
      :style="{ background: body_background_color }"
      x-intersect.margin.-50%="
        body_background_color = '{% if section.settings.color_scheme == 'custom' %}{{ section.settings.color_background }}{% else %}{{ section.settings.color_scheme }}{% endif %}';
        body_text_color = '{{ section.settings.color_text }}';
      "
    {% endif %}
  >
    <div
      class="
        flex flex-row flex-wrap
        {% if section.settings.enable_header_overlap %}
          section--overlap
        {% endif %}
      "
      x-data="{{ script_product }}"
      x-init="
        attachStandardForm();
        initProductForm();
      "
      x-ref="formContainer"
      @keyup.left="galleryScrollBack();"
      @keyup.right="galleryScrollNext();"
    >
      {% comment %} If gallery is top {% endcomment %}
      {% if section.settings.media_gallery_position == 'top' %}
        <div
          class="
            w-full
            {% if section.settings.enable_media_margin %}
              {{ settings.x_margin }}
            {% endif %}
          "
          {% if section.settings.enable_header_overlap %}
            x-init="
              has_banner_overlap = true;
              header_color = header_overlay_color;
              header_border = header_overlay_border;
            "
          {% endif %}
        >
          {{ gallery_snippet }}
        </div>
      {% endif %}

      {% comment %} Columns {% endcomment %}
      {% capture form_class %}
        w-full
      {% endcapture %}
      {% form 'product', product, class: form_class, x-ref: 'productForm' %}
        <div
          class="
            w-full !px-0
            {% if section.settings.enable_main_margin %}
              {{ settings.x_margin }}
            {% endif %}
          "
          style="
            padding-top:{{ section.settings.spacing_top }}px;
            padding-bottom:{{ section.settings.spacing_bottom }}px;
          "
          x-data="
            {
              {% for block in section.blocks %}
                {% case block.type %}
                {% when 'drawer' %}
                  drawer_{{ block.id }}: false,
                {% when 'pickup' %}
                  drawer_pickup: false,
                {% endcase %}
              {% endfor %}
            }
          "
        >
          <div
            class="
              product-blocks-container-{{ section.id }}
              {% if section.settings.enable_main_margin %}
                md:{{ settings.x_margin }}
              {% endif %}
            "
          >
            {% comment %} Mobile view: blocks in exact editor order {% endcomment %}
            {% if section.settings.media_gallery_position == 'left'
              or section.settings.media_gallery_position == 'right'
            %}
              <div class="block-{{ section.settings.media_gallery_position }} w-full md:hidden">
                {{ gallery_snippet }}
              </div>
            {% endif %}
            {% for block in section.blocks %}
              {% unless block.type == 'stickyadd' %}
                <div
                  class="block-{{ block.settings.position }} w-full md:hidden"
                  :class="
                    {
                      {% if block.type == 'options' %}
                        '!z-40' : has_overlay,
                      {% endif %}
                    }
                  "
                >
                  {% comment %} Render the block content {% endcomment %}
                  {% case block.type %}
                    {% when 'list' %}
                      {% render 'product__list', block: block, is_featured: true %}

                    {% when 'tabs' %}
                      {% render 'product__tabs', block: block, is_featured: true %}

                    {% when 'linked_products' %}
                      {% render 'product__linked-products', block: block, is_featured: true, product: product %}

                    {% when 'breadcrumb' %}
                      {% render 'product__breadcrumb', block: block, is_featured: true %}

                    {% when 'title' %}
                      {% render 'product__title', block: block, is_featured: true %}

                    {% when 'price' %}
                      <div
                        class="
                          px-4
                          {{ block.settings.color_scheme }}
                          {{ block.settings.color_border }}
                          {{ block.settings.style_border }}
                        "
                        style="
                          padding-top:{{ block.settings.spacing_top }}px;
                          padding-bottom:{{ block.settings.spacing_bottom }}px;
                        "
                        x-show="current_variant_exists"
                      >
                        <div class="relative flex items-end justify-between">
                          {% render 'product__price', block: block, is_featured: true %}
                        </div>
                        <div class="type--small mt-1">
                          {% # theme-check-disable UndefinedObject %}
                          {{ form | payment_terms }}
                          {% # theme-check-enable UndefinedObject %}
                        </div>
                      </div>

                    {% when 'custom' %}
                      {% render 'product__custom-field', block: block, is_featured: true %}

                    {% when 'text' %}
                      {% render 'product__text', block: block, is_featured: true %}

                    {% when 'description' %}
                      {% render 'product__description', block: block, is_featured: true %}

                    {% when 'accordion' %}
                      {% render 'product__accordion', block: block, is_featured: true %}

                    {% when 'drawer' %}
                      {% render 'product__drawer-button', block: block, is_featured: true %}

                    {% when 'inventory' %}
                      {% render 'product__inventory', block: block, is_featured: true %}

                    {% when 'pickup' %}
                      {% render 'product__pickup-button', block: block, is_featured: true %}

                    {% when 'rating' %}
                      {% render 'product__rating', block: block, is_featured: true %}

                    {% when 'liquid' %}
                      {% render 'product__liquid', block: block, is_featured: true %}

                    {% when 'upsell' %}
                      {% render 'product__upsell', block: block, is_featured: true %}

                    {% when 'options' %}
                      <div
                        class="
                          options-{{ section.id }}
                          {{ block.settings.color_scheme }}
                          {{ block.settings.color_border }}
                          {{ block.settings.style_border }}
                        "
                        style="
                          padding-top:{% if product.selected_or_first_available_selling_plan_allocation or product.has_only_default_variant == false %}{{ block.settings.spacing_top }}px;{% else %}0;{% endif %}
                          padding-bottom:{% if product.selected_or_first_available_selling_plan_allocation or product.has_only_default_variant == false %}{{ block.settings.spacing_bottom }}px;{% else %}0;{% endif %}
                        "
                      >
                        {% render 'product__options',
                          block: block,
                          is_featured: true,
                          enable_default_selling_plan_widget: section.settings.enable_default_selling_plan_widget
                        %}
                      </div>

                    {% when 'add' %}
                      <div
                        class="
                          {{ block.settings.color_scheme }}
                          {{ block.settings.color_border }}
                          {{ block.settings.style_border }}
                        "
                        style="
                          padding-top:{{ block.settings.spacing_top }}px;
                          padding-bottom:{{ block.settings.spacing_bottom }}px;
                        "
                      >
                        {% render 'product__add', block: block, is_featured: true %}
                        {% if block.settings.enable_dynamic_checkout %}
                          <div
                            class="color__inherit mt-4 px-4"
                            x-show="current_variant_exists && current_variant_available"
                          >
                            {% form 'product', product, x-ref: 'productForm' %}
                              {{ form | payment_button }}
                            {% endform %}
                          </div>
                        {% endif %}
                        {% unless block.settings.content == blank %}
                          <div class="mt-4 w-full px-4">
                            <div class="type--small color__bg-shade-1 border--radius rte space-y-4 p-2 text-center">
                              {{ block.settings.content }}
                            </div>
                          </div>
                        {% endunless %}
                      </div>

                    {% when 'bundle' %}
                      {% render 'product__bundle', block: block, is_featured: true %}

                    {% when '@app' %}
                      <div class="p-4">{% render block %}</div>
                  {% endcase %}
                </div>
              {% endunless %}
            {% endfor %}

            {% comment %} Desktop view: two separate columns {% endcomment %}
            {% comment %} Left column {% endcomment %}
            <div class="product-column-left-{{ section.id }}">
              {% if section.settings.media_gallery_position == 'left' %}
                <div
                  class="top-4 z-30 w-full md:sticky"
                  {% if settings.header_position == 'sticky' %}
                    :style="{ top: header_bar_height + 'px' }"
                  {% endif %}
