                          >
                            <div class="relative flex items-end justify-between">
                              {% render 'product__price',
                                block: block,
                                is_featured: true
                              %}
                            </div>
                            <div class="type--small mt-1">
                              {% # theme-check-disable UndefinedObject %}
                            {{ form | payment_terms }}
                            {% # theme-check-enable UndefinedObject %}
                            </div>
                          </div>

                        {% when 'custom' %}
                          {% render 'product__custom-field',
                            block: block,
                            is_featured: true
                          %}

                        {% when 'text' %}
                          {% render 'product__text',
                            block: block,
                            is_featured: true
                          %}

                        {% when 'description' %}
                          {% render 'product__description',
                            block: block,
                            is_featured: true
                          %}

                        {% when 'accordion' %}
                          {% render 'product__accordion',
                            block: block,
                            is_featured: true
                          %}

                        {% when 'drawer' %}
                          {% render 'product__drawer-button',
                            block: block,
                            is_featured: true
                          %}

                        {% when 'inventory' %}
                          {% render 'product__inventory',
                            block: block,
                            is_featured: true
                          %}

                        {% when 'pickup' %}
                          {% render 'product__pickup-button',
                            block: block,
                            is_featured: true
                          %}

                        {% when 'rating' %}
                          {% render 'product__rating',
                            block: block,
                            is_featured: true
                          %}

                        {% when 'liquid' %}
                          {% render 'product__liquid',
                            block: block,
                            is_featured: true
                          %}

                        {% when 'upsell' %}
                          {% render 'product__upsell',
                            block: block,
                            is_featured: true
                          %}

                        {% when 'options' %}
                          <div
                            class="
                              options-{{ section.id }}
                              {{ block.settings.color_scheme }}
                              {{ block.settings.color_border }}
                              {{ block.settings.style_border }}
                            "
                            style="
                              padding-top:{% if product.selected_or_first_available_selling_plan_allocation or product.has_only_default_variant == false %}{{ block.settings.spacing_top }}px;{% else %}0;{% endif %}
                              padding-bottom:{% if product.selected_or_first_available_selling_plan_allocation or product.has_only_default_variant == false %}{{ block.settings.spacing_bottom }}px;{% else %}0;{% endif %}
                            "
                          >
                            {% render 'product__options',
                              block: block,
                              is_featured: true,
                              enable_default_selling_plan_widget: section.settings.enable_default_selling_plan_widget
                            %}
                          </div>

                        {% when 'add' %}
                          <div
                            class="
                              {{ block.settings.color_scheme }}
                              {{ block.settings.color_border }}
                              {{ block.settings.style_border }}
                            "
                            style="
                              padding-top:{{ block.settings.spacing_top }}px;
                              padding-bottom:{{ block.settings.spacing_bottom }}px;
                            "
                          >
                            {% render 'product__add',
                              block: block,
                              is_featured: true
                            %}
                            {% if block.settings.enable_dynamic_checkout %}
                              <div
                                class="color__inherit mt-4 px-4"
                                x-show="current_variant_exists && current_variant_available"
                              >
                                {% form 'product', product, x-ref: 'productForm' %}
                                  {{ form | payment_button  }}
                                {% endform %}
                              </div>
                            {% endif %}
                            {% unless block.settings.content == blank %}
                              <div class="mt-4 w-full px-4">
                                <div class="type--small color__bg-shade-1 border--radius rte space-y-4 p-2 text-center">
                                  {{ block.settings.content }}
                                </div>
                              </div>
                            {% endunless %}
                          </div>

                        {% when 'bundle' %}
                          {% render 'product__bundle',
                            block: block,
                            is_featured: true
                          %}

                        {% when '@app' %}
                          {% if settings.app_block_column == 'right_column' %}
                            <div class="p-4">{% render block %}</div>
                          {% endif %}
                      {% endcase %}
                    </div>
                  {% endunless %}
                {% endif %}
              {% endfor %}
            </div>

            {% comment %} Overlay blocks {% endcomment %}
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'stickyadd' %}
                  {% render 'product__stickyadd', block: block %}
                {% when 'drawer' %}
                  {% render 'product__drawer-content', block: block %}
                {% when 'pickup' %}
                  {% render 'product__pickup-drawer', block: block %}
              {% endcase %}
            {% endfor %}
          </div>
        </div>
      {% endform %}

      {% comment %} If gallery is below {% endcomment %}
      {% if section.settings.media_gallery_position == 'bottom' %}
        <div
          class="
            w-full
            {% if section.settings.enable_media_margin %}
