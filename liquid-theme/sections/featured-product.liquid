        >
          {{ gallery_snippet }}
        </div>
      {% endif %}

      {% comment %} Fullscreen zoom gallery {% endcomment %}
      {% if section.settings.enable_zoom %}
        {% render 'product__gallery-fullscreen', is_featured: true %}
      {% endif %}
    </div>
  </section>
{% endunless %}

{% comment %} Mobile: single column, Desktop: two flex columns side-by-side {% endcomment %}
<style>
  /* Mobile: single column - blocks flow in exact editor order */
  .product-blocks-container-{{ section.id }} {
    display: flex;
    flex-direction: column;
  }

  /* Desktop: two columns side by side */
  @media (min-width: 768px) {
    .product-blocks-container-{{ section.id }} {
      display: flex;
      flex-direction: row;
      align-items: start;
      gap: 0;
    }

    .product-column-left-{{ section.id }} {
      width: {{ left_column_width }};
      display: flex;
      flex-direction: column;
    }

    .product-column-right-{{ section.id }} {
      width: {{ right_column_width }};
      display: flex;
      flex-direction: column;
    }

    /* Hide columns on desktop, show only on mobile for ordering */
    .product-blocks-container-{{ section.id }} > .block-left,
    .product-blocks-container-{{ section.id }} > .block-right {
      display: none;
    }

    .product-column-left-{{ section.id }} > *,
    .product-column-right-{{ section.id }} > * {
      display: block;
    }
  }

  /* On mobile, hide the desktop columns */
  @media (max-width: 767px) {
    .product-column-left-{{ section.id }},
    .product-column-right-{{ section.id }} {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "t:sections.featured_product.name",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "t:general.settings.product.label"
    },
    {
      "type": "checkbox",
      "id": "enable_default_variant",
      "label": "t:general.settings.enable_default_variant.label",
      "info": "t:general.settings.enable_default_variant.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_default_plans",
      "label": "t:general.settings.enable_default_plans.label",
      "info": "t:general.settings.enable_default_plans.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_default_selling_plan_widget",
      "label": "t:general.settings.enable_default_selling_plan_widget.label",
      "info": "t:general.settings.enable_default_selling_plan_widget.info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:general.headers.gallery.content"
    },
    {
      "type": "select",
      "id": "media_gallery_style",
      "label": "t:general.settings.media_gallery_style.label",
      "options": [
