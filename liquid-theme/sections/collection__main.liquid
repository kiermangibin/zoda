<!-- sections/collection__main.liquid -->
{% comment %}
  Main contents of the collection template

  Globals:
  - layout_horizontal: {string} Class string to set horizontal margin.
  - layout_gap_size: {integer} Set the gap between grid items.

  Recommendations:
  - Use blocks to showcase promotional content.
{% endcomment %}

<section
  id="{{ section.id }}"
  class="
    js-paginationTop
    animation-1000
    {% unless section.settings.enable_color_fade %}
      {{ section.settings.color_text }}
      {% unless section.settings.color_scheme == 'custom' %}
        {{ section.settings.color_scheme }}
      {% endunless %}
    {% endunless %}
  "
  {% if section.settings.color_scheme == 'custom' %}
    {% unless section.settings.enable_color_fade %}
      style="background:{{ section.settings.color_background }};"
    {% endunless %}
  {% endif %}
  {% if section.settings.enable_color_fade %}
    :class="`${body_background_color} ${body_text_color}`"
    :style="{ background: body_background_color }"
    x-intersect.margin.-50%="
      body_background_color = '{% if section.settings.color_scheme == 'custom' %}{{ section.settings.color_background }}{% else %}{{ section.settings.color_scheme }}{% endif %}';
      body_text_color = '{{ section.settings.color_text }}';
    "
  {% endif %}
  {% if settings.pagination_type != 'pages' %}
    x-data="
      {
        enablePaginateUp: false
      }
    "
    x-init="
      if(new URLSearchParams(window.location.search).has('page')) {
        enablePaginateUp = true
      }
    "
  {% endif %}
>
  {% comment %} Filtering and sub navigation {% endcomment %}
  <div
    class="sticky top-0 z-40"
    {% if settings.header_position == 'sticky' %}
      :style="
        {
          top: header_bar_height + 'px'
        }
      "
    {% endif %}
    :class="
      {
        '!-z-10' : has_overlay
      }
    "
  >
    {% render 'collection__subcollections' %}
    {% render 'collection__subtags' %}
    {% if section.settings.filter_placement == 'top' %}
      {% render 'component__filter-bar', results: collection %}
    {% endif %}
  </div>

  {% comment %} Main content {% endcomment %}
  <div
    class="
      flex flex-wrap
      {% if section.settings.enable_margin %}
        {{ settings.x_margin }}
      {% endif %}
    "
  >
    {% comment %} Sidebar filters {% endcomment %}
    {% if section.settings.filter_placement == 'side' %}
      <div
        class="sticky z-20 w-full md:z-0 md:w-1/4"
        style=""
        {% if settings.header_position == 'sticky' %}
          :style="
            {
              top: header_group_height + 'px'
            }
          "
        {% endif %}
      >
        {% render 'component__filter-stack', results: collection %}
      </div>
    {% endif %}

    {% comment %} Paginate up button {% endcomment %}
    {% if settings.pagination_type != 'pages' %}
      <section
        class="
          type--small border--t-width border--b-width w-full py-4
          {{ section.settings.color_border }}
        "
        x-data="
          {
            button_loading: false
          }
        "
        x-show="pagination_current_page > 1 && enablePaginateUp"
        x-cloak
      >
        <div
          class="text-center"
        >
          <button
            class="btn btn--small btn--load btn--secondary"
            :class="{ 'btn--loading' : button_loading }"
            :disabled="button_loading"
            role="button"
            title="{{ 'actions.load_more' | t }}"
            @click="fetchAndRenderPage('previous'); button_loading = true; setTimeout(function(){ button_loading = false}, 1000);"
          >
            <div class="btn__content">{{ 'actions.load_more' | t }}</div>
            <div class="btn__spinner">
              {% render 'component__icon', icon: 'spinner', size: '16', class: '' %}
            </div>
          </button>
        </div>
      </section>
    {% endif %}

    {% comment %} Grid {% endcomment %}
    <div
      class="
        w-full
        {% if section.settings.filter_placement == 'side' %}
          md:w-3/4
        {% endif %}
      "
    >
      {% paginate collection.products by section.settings.products_per_page %}
        {% comment %} Results {% endcomment %}
        <section
          id="js-results"
          class="
            animation-500 grid
            md:grid-cols-{{ section.settings.layout_row_desktop }}
            grid-cols-{{ section.settings.layout_row_mobile }}
          "
          :class="
            {
              'opacity-25' : pagination_loading
            }
          "
          style="
            gap: {{ settings.gap_size }}px;
            {% if section.settings.spacing_top == 0 %}
              padding-top:{{ settings.border_element_width }}px;
            {% else %}
              padding-top:{{ section.settings.spacing_top }}px;
            {% endif %}
            {% if section.settings.spacing_bottom == 0 %}
              padding-bottom:{{ settings.border_element_width }}px;
            {% else %}
              padding-bottom:{{ section.settings.spacing_bottom }}px;
            {% endif %}
            {% unless section.settings.enable_margin %}
              {% unless settings.gap_size == 1 %}
                padding-left: {{ settings.gap_size }}px;
                padding-right: {{ settings.gap_size }}px;
              {% endunless %}
            {% endunless %}
          "
        >
          {% for product in collection.products %}
            {% assign previous_index = paginate.current_page | minus: 1 | times: section.settings.products_per_page %}
            {% assign grid_index = forloop.index | plus: previous_index %}
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'newsletter' %}
                  {% if block.settings.index == grid_index %}
                    {% render 'component__newsletter-item',
                      heading: block.settings.heading,
                      content: block.settings.content,
                      image: block.settings.image,
                      button_label: block.settings.button_label,
                      disclaimer: block.settings.disclaimer,
                      success: block.settings.success,
                      color_scheme: block.settings.color_scheme,
                      color_border: block.settings.color_border,
                      color_button: block.settings.color_button,
                      spacing_minimum_height: block.settings.spacing_minimum_height,
                      enable_padding: block.settings.enable_padding,
                      layout_col_span_desktop: block.settings.layout_col_span,
                      layout_row_span_desktop: block.settings.layout_row_span,
                      layout_y_alignment: block.settings.layout_y_alignment,
                      layout_x_alignment: block.settings.layout_x_alignment
                    %}
                  {% endif %}

                {% when 'content' %}
                  {% if block.settings.index == grid_index %}
                    {% render 'component__content-item',
                      heading: block.settings.heading,
                      content: block.settings.content,
                      button_label: block.settings.button_label,
                      url: block.settings.url,
                      image: block.settings.image,
                      show_image_as_background: block.settings.show_image_as_background,
                      video: block.settings.video,
                      enable_autoplay: block.settings.enable_autoplay,
                      enable_mute_toggle: block.settings.enable_mute_toggle,
                      enable_loop: block.settings.enable_loop,
                      color_scheme: block.settings.color_scheme,
                      color_border: block.settings.color_border,
                      color_text: block.settings.color_text,
                      color_button: block.settings.color_button,
                      enable_gradient: block.settings.enable_gradient,
                      spacing_minimum_height: block.settings.spacing_minimum_height,
                      enable_padding: block.settings.enable_padding,
                      layout_col_span_desktop: block.settings.layout_col_span,
                      layout_row_span_desktop: block.settings.layout_row_span,
                      layout_y_alignment: block.settings.layout_y_alignment,
                      layout_x_alignment: block.settings.layout_x_alignment,
                      text_position: block.settings.text_position
                    %}
                  {% endif %}
              {% endcase %}
            {% endfor %}

            {% render 'component__product-grid', product: product %}
          {% endfor %}
        </section>

        {% comment %} Pagination {% endcomment %}
        {% if collection.all_products_count == 0 %}
          <section class="py-4 text-center">
            <span>{{ 'info.collection_no_products' | t }}</span>
          </section>
        {% else %}
          {% render 'component__pagination', paginate: paginate %}
        {% endif %}
      {% endpaginate %}
    </div>
  </div>
</section>

