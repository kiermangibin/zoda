{% comment %}
  ZODA collection page — Liquid port of src/routes/collections.$handle.tsx
{% endcomment %}

<div class="zoda-shell zoda-shell--light">
  <main class="zoda-shell__main">
    <div class="zoda-shell__heading">
      <h1>{{ collection.title }}</h1>
      <nav class="zoda-shell__breadcrumbs" aria-label="Breadcrumbs">
        <a href="{{ routes.root_url }}">Home</a>
        <span aria-hidden="true">/</span>
        <a href="{{ routes.collections_url }}">Collections</a>
        <span aria-hidden="true">/</span>
        <span>{{ collection.title }}</span>
      </nav>
      {%- if collection.description != blank -%}
        <p>{{ collection.description | strip_html | truncate: 240 }}</p>
      {%- endif -%}
    </div>

    {%- if collection.products.size == 0 -%}
      <p class="zoda-shell__empty">No products in this collection yet.</p>
    {%- else -%}
      <div class="zoda-collection-grid">
        {%- for product in collection.products -%}
          {% render 'zoda-product-card', product: product %}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div style="display:flex;justify-content:center;gap:12px;margin-top:32px">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}
    {%- endif -%}
  </main>
</div>

{% schema %}
{
  "name": "ZODA Collection",
  "settings": [],
  "presets": [{ "name": "ZODA Collection" }]
}
{% endschema %}
