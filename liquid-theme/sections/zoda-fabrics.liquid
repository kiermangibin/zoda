{% comment %}
  ZODA Fabrics — Liquid port of src/routes/fabrics.tsx.
  Content lives in section settings + repeater blocks (one block per fabric).
{% endcomment %}

<div class="zoda-shell zoda-shell--light">
  <main class="zoda-shell__main zoda-fabrics">
    <header class="zoda-fabrics__intro">
      <p class="zoda-fabrics__kicker">{{ section.settings.kicker }}</p>
      <h1 class="zoda-fabrics__title">{{ section.settings.title }}</h1>
      {% if section.settings.lede != blank %}
        <p class="zoda-fabrics__lede">{{ section.settings.lede }}</p>
      {% endif %}
    </header>

    <section class="zoda-fabrics__grid" aria-label="Fabric directory">
      {% for block in section.blocks %}
        <a href="#fabric-{{ block.settings.handle }}" class="zoda-fabrics__tile" {{ block.shopify_attributes }}>
          <span class="zoda-fabrics__tile-name">{{ block.settings.name }}</span>
          <span class="zoda-fabrics__tile-tag">{{ block.settings.tagline }}</span>
          <span class="zoda-fabrics__tile-cta">Read more →</span>
        </a>
      {% endfor %}
    </section>

    <section class="zoda-fabrics__showcase">
      {% for block in section.blocks %}
        {% assign orient = 'left' %}
        {% cycle 'left', 'right' %}
        {% if forloop.index0 | modulo: 2 == 1 %}{% assign orient = 'right' %}{% endif %}
        <article id="fabric-{{ block.settings.handle }}" class="zoda-fabrics__row" data-orientation="{{ orient }}">
          <div class="zoda-fabrics__row-media">
            {% if block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.name | escape }} swatch" loading="lazy">
            {% endif %}
          </div>
          <div class="zoda-fabrics__row-body">
            <h2 class="zoda-fabrics__row-title">{{ block.settings.hero_title }}</h2>
            <p class="zoda-fabrics__row-desc">{{ block.settings.description }}</p>

            {% assign feats = block.settings.features | newline_to_br | split: '<br />' %}
            <ul class="zoda-fabrics__features" aria-label="Key technologies">
              {% for line in feats %}
                {% assign parts = line | split: '|' %}
                {% if parts.size >= 2 %}
                  <li><img src="{{ parts[1] | strip }}" alt="" loading="lazy"><span>{{ parts[0] | strip }}</span></li>
                {% endif %}
              {% endfor %}
            </ul>

            <div class="zoda-fabrics__detail">
              <h3>Engineered for performance</h3>
              <ul>
                {% assign perf = block.settings.performance | newline_to_br | split: '<br />' %}
                {% for p in perf %}{% if p != blank %}<li>{{ p | strip }}</li>{% endif %}{% endfor %}
              </ul>
            </div>
            <div class="zoda-fabrics__detail">
              <h3>Sustainability at its core</h3>
              <ul>
                {% assign sus = block.settings.sustainability | newline_to_br | split: '<br />' %}
                {% for p in sus %}{% if p != blank %}<li>{{ p | strip }}</li>{% endif %}{% endfor %}
              </ul>
            </div>
            <div class="zoda-fabrics__detail">
              <h3>Built for the community of athletes</h3>
              <p>{{ block.settings.community }}</p>
            </div>

            <div class="zoda-fabrics__row-actions">
              {% if block.settings.shop_url != blank %}
                <a class="zoda-fabrics__shop" href="{{ block.settings.shop_url }}">Shop featured products</a>
              {% endif %}
              <a class="zoda-fabrics__back" href="#fabric-{{ section.blocks.first.settings.handle }}">Back to fabrics</a>
            </div>
          </div>
        </article>
      {% endfor %}
    </section>
  </main>
</div>

{% schema %}
{
  "name": "ZODA Fabrics",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Our Fabrics" },
    { "type": "textarea", "id": "title", "label": "Heading", "default": "Explore the fabrics behind ZODA — engineered for performance, comfort and sustainability." },
    { "type": "textarea", "id": "lede", "label": "Intro paragraph", "default": "Every ZODA garment starts with a fabric story. From BCI cotton blends to recycled nylons, each material is selected for how it performs, how it feels, and how lightly it treads." }
  ],
  "blocks": [
    {
      "type": "fabric",
      "name": "Fabric",
      "settings": [
        { "type": "text", "id": "handle", "label": "Anchor handle (lowercase, no spaces)" },
        { "type": "text", "id": "name", "label": "Fabric name" },
        { "type": "textarea", "id": "tagline", "label": "Tile tagline" },
        { "type": "textarea", "id": "hero_title", "label": "Showcase title" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "image_picker", "id": "image", "label": "Showcase image" },
        { "type": "textarea", "id": "features", "label": "Features (one per line: Label | icon URL)" },
        { "type": "textarea", "id": "performance", "label": "Performance bullets (one per line)" },
        { "type": "textarea", "id": "sustainability", "label": "Sustainability bullets (one per line)" },
        { "type": "textarea", "id": "community", "label": "Community paragraph" },
        { "type": "url", "id": "shop_url", "label": "Shop featured products URL" }
      ]
    }
  ],
  "presets": [{ "name": "ZODA Fabrics" }]
}
{% endschema %}
