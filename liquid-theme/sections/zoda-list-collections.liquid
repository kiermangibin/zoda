{% comment %}
  ZODA list-collections page (collections index)
{% endcomment %}

<div class="zoda-shell zoda-shell--light">
  <main class="zoda-shell__main">
    <div class="zoda-shell__heading">
      <h1>Collections</h1>
      <p>Pick your training mode.</p>
    </div>
    <ul style="list-style:none;padding:0;margin:0;border-top:1px solid var(--line)">
      {%- for c in collections -%}
        {%- unless c.handle == 'frontpage' -%}
          <li style="border-bottom:1px solid var(--line)">
            <a href="{{ c.url }}" style="display:flex;justify-content:space-between;align-items:center;padding:20px 8px;font-size:14px;font-weight:500;text-transform:uppercase;letter-spacing:.06em;color:#fff;text-decoration:none">
              <span>{{ c.title }}</span>
              <span aria-hidden="true">›</span>
            </a>
          </li>
        {%- endunless -%}
      {%- endfor -%}
    </ul>
  </main>
</div>

{% schema %}
{
  "name": "ZODA List Collections",
  "settings": [],
  "presets": [{ "name": "ZODA List Collections" }]
}
{% endschema %}
