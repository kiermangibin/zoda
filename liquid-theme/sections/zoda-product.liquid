{% comment %}
  ZODA product detail — Liquid port of src/routes/product.$handle.tsx
  Breadcrumbs above title, Color/Size split, global font tokens.
{% endcomment %}

<div class="zoda-shell zoda-shell--light">
  <div class="zoda-pdp">
    <div class="zoda-pdp__grid">
      <div class="zoda-pdp__gallery">
        {%- assign main_image = product.featured_image -%}
        <div class="zoda-pdp__gallery-main">
          {%- if main_image -%}
            <img src="{{ main_image | image_url: width: 1200 }}" alt="{{ main_image.alt | default: product.title | escape }}" width="1200" height="1500">
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="zoda-pdp__gallery-thumbs">
            {%- for img in product.images limit: 4 -%}
              <button type="button" class="zoda-pdp__gallery-thumb" onclick="document.querySelector('.zoda-pdp__gallery-main img').src=this.dataset.full" data-full="{{ img | image_url: width: 1200 }}">
                <img src="{{ img | image_url: width: 320 }}" alt="{{ img.alt | escape }}" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="zoda-pdp__info">
        <nav class="zoda-pdp__breadcrumbs" aria-label="Breadcrumbs">
          <a href="{{ routes.root_url }}">Home</a>
          <span aria-hidden="true">/</span>
          <a href="{{ routes.collections_url }}">Collections</a>
          <span aria-hidden="true">/</span>
          <span>{{ product.title }}</span>
        </nav>

        <div>
          <h1 class="zoda-pdp__title">{{ product.title }}</h1>
          <p class="zoda-pdp__price">{{ product.selected_or_first_available_variant.price | money }}</p>
        </div>

        {%- form 'product', product, novalidate: 'novalidate' -%}
          {%- assign current_variant = product.selected_or_first_available_variant -%}

          {%- for opt in product.options_with_values -%}
            {%- assign opt_name_down = opt.name | downcase -%}
            {%- assign is_color = false -%}
            {%- if opt_name_down contains 'color' or opt_name_down contains 'colour' -%}
              {%- assign is_color = true -%}
            {%- endif -%}
            {%- assign is_size = false -%}
            {%- if opt_name_down contains 'size' -%}{%- assign is_size = true -%}{%- endif -%}

            {%- if opt.values.size > 1 -%}
              <div>
                <p class="zoda-pdp__option-label">{{ opt.name }} <span class="zoda-pdp__option-selected" data-opt-display="{{ opt.position }}">— {{ opt.selected_value }}</span></p>
                <div class="zoda-pdp__variants {% if is_color %}zoda-pdp__variants--colors{% endif %}">
                  {%- for v in opt.values -%}
                    {%- assign is_active = false -%}
                    {%- if v == opt.selected_value -%}{%- assign is_active = true -%}{%- endif -%}
                    {%- if is_color -%}
                      {%- assign color_key = v | downcase | strip -%}
                      <button type="button" data-zoda-option data-position="{{ opt.position }}" data-value="{{ v | escape }}" title="{{ v | escape }}" aria-label="{{ v | escape }}"
                        class="zoda-pdp__swatch{% if is_active %} zoda-pdp__swatch--active{% endif %}"
                        style="background: {{ color_key | replace: ' ', '' }};"></button>
                    {%- else -%}
                      <button type="button" data-zoda-option data-position="{{ opt.position }}" data-value="{{ v | escape }}"
                        class="zoda-pdp__variant{% if is_active %} zoda-pdp__variant--active{% endif %}{% if is_size %} zoda-pdp__variant--size{% endif %}">{{ v }}</button>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}

          <input type="hidden" name="id" value="{{ current_variant.id }}" data-zoda-variant-id>

          <button type="submit" class="zoda-pdp__add" {% unless current_variant.available %}disabled{% endunless %}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M6 7h12l-1.5 11a2 2 0 0 1-2 1.7H9.5a2 2 0 0 1-2-1.7L6 7Z"/><path d="M9 7a3 3 0 1 1 6 0"/></svg>
            {%- if current_variant.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
          </button>
        {%- endform -%}

        {%- if product.description != blank -%}
          <div class="zoda-pdp__description">{{ product.description }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  var variants = {{ product.variants | json }};
  var optionsCount = {{ product.options.size }};
  var current = {};
  variants[0] && variants[0].options.forEach(function(v,i){ current[i+1] = v; });
  // Sync to currently selected variant
  var firstAvail = {{ product.selected_or_first_available_variant.id }};
  variants.forEach(function(v){ if (v.id === firstAvail) v.options.forEach(function(val,i){ current[i+1] = val; }); });

  function pickVariant() {
    return variants.find(function(v){
      for (var i=1;i<=optionsCount;i++){ if (v.options[i-1] !== current[i]) return false; }
      return true;
    });
  }

  document.querySelectorAll('[data-zoda-option]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var pos = parseInt(btn.dataset.position, 10);
      current[pos] = btn.dataset.value;
      // Update active state in same group
      btn.parentElement.querySelectorAll('[data-zoda-option]').forEach(function (b) {
        b.classList.remove('zoda-pdp__variant--active');
        b.classList.remove('zoda-pdp__swatch--active');
      });
      btn.classList.add(btn.classList.contains('zoda-pdp__swatch') ? 'zoda-pdp__swatch--active' : 'zoda-pdp__variant--active');
      // Update display label
      var label = document.querySelector('[data-opt-display="'+pos+'"]');
      if (label) label.textContent = '— ' + btn.dataset.value;
      // Resolve variant
      var v = pickVariant();
      var hidden = document.querySelector('[data-zoda-variant-id]');
      if (v && hidden) hidden.value = v.id;
      var addBtn = document.querySelector('.zoda-pdp__add');
      if (v && addBtn) {
        addBtn.disabled = !v.available;
        addBtn.lastChild && (addBtn.lastChild.textContent = v.available ? 'Add to cart' : 'Sold out');
      }
      var priceEl = document.querySelector('.zoda-pdp__price');
      if (v && priceEl) priceEl.textContent = (v.price/100).toLocaleString(undefined,{style:'currency',currency:'{{ cart.currency.iso_code }}'});
    });
  });
})();
</script>

{% schema %}
{
  "name": "ZODA Product",
  "settings": [],
  "presets": [{ "name": "ZODA Product" }]
}
{% endschema %}
