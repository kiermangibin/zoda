{% comment %}
  Featured product gallery — Liquid version of ProductMotionGallery.
  Pulls from settings.zoda_featured_collection (theme setting).
{% endcomment %}

{%- assign coll_handle = settings.zoda_featured_collection | default: 'frontpage' -%}
{%- assign coll = collections[coll_handle] -%}

<div class="zoda-pim" data-animate="" style="--zoda-delay: 260ms">
  {%- if coll.products.size > 0 -%}
    <div class="zoda-pim__rail">
      {%- for p in coll.products limit: 12 -%}
        {% render 'zoda-product-card', product: p %}
      {%- endfor -%}
    </div>
    <div class="zoda-pim__controls">
      <button type="button" aria-label="Scroll left" class="zoda-pim__nav" onclick="this.closest('.zoda-pim').querySelector('.zoda-pim__rail').scrollBy({left:-400,behavior:'smooth'})">‹</button>
      <button type="button" aria-label="Scroll right" class="zoda-pim__nav" onclick="this.closest('.zoda-pim').querySelector('.zoda-pim__rail').scrollBy({left:400,behavior:'smooth'})">›</button>
    </div>
  {%- else -%}
    <p style="padding:24px 0;color:rgba(255,255,255,.7);font-size:14px">No products yet — add one in Shopify to populate this section.</p>
  {%- endif -%}
</div>
