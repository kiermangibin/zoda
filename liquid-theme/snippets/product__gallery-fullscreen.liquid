<!-- snippets/product__gallery-fullscreen.liquid -->
{% comment %}
  A fullscreen overlay of zoomable product images. This snippet is used to display a fullscreen gallery of product images,
  where each image can be zoomed in and out by clicking on it. The gallery also supports navigation through arrows.

  Accepts:
  - featured: {boolean} Assigns product object from section settings. Set this to true if block is used within a section rather than product template.

  Globals:
  - settings.layout_horizontal: {string} Class string to set horizontal margin.

  Usage:
    {% render 'product__gallery-fullscreen',
      featured: true
    %}

  Recommendations:
  - Use this snippet to display a fullscreen gallery of product images in a product detail page.
  - Ensure that the product images are high resolution as they can be zoomed in.
{% endcomment %}

{% if is_featured %}
  {% assign product = section.settings.product %}
{% endif %}

{% capture fullscreen_content %}

  {% capture slides %}
    {% for media in product.media %}
      <div 
        class="
          color__bg-overlay-1 relative flex h-full w-full flex-none snap-center items-center justify-center overflow-clip whitespace-normal
          {% unless media.media_type == 'image' %} hidden {% endunless %}
        " 
        :class="{ 
          'z-10' : gallery_index == {{ forloop.index0 }}
        }"
        x-bind:data-slide="{{ forloop.index0 }}"
        x-intersect:enter.half="gallery_index = {{ forloop.index0 }};"
        @click="
          if (window.innerWidth >= 768) {
            gallery_zoom_{{ forloop.index0 }} = !gallery_zoom_{{ forloop.index0 }};
            zoomed = !zoomed;
          }
        ">
        <div 
          class="flex h-full w-full flex-none cursor-zoom-in items-center justify-center"
          x-show="!gallery_zoom_{{ forloop.index0 }}">
          {% render 'component__image',
            image: media,
            max_width: media.width,
            parent_class: 'w-full',
            container_class: 'absolute max-h-full',
            image_class: 'max-h-full max-w-full',
            crop_class: 'object-contain',
            enable_ratio: true,
            enable_lazy_load: true
          %}
          {% if section.settings.enable_alt %}
            <div 
              class="
                type--smaller color__bg-shade-1 border--radius absolute bottom-4 left-2 max-w-64 whitespace-normal p-2 text-left backdrop-blur-sm
              "
            >
              {{ media.alt }}
            </div>
          {% endif %}
        </div>
        <div 
          class="pointer-events-none flex h-full w-full flex-none cursor-zoom-out items-center justify-center"
          :class="{ 
            'hidden' : !gallery_zoom_{{ forloop.index0 }} 
          }"
          x-bind:style="
            'transform: translate('+(((mouse_x/width)-0.5)*100)+'%, '+(((mouse_y/height)-0.5)*100)+'%)'
          "
          x-show="gallery_zoom_{{ forloop.index0 }}"
          x-cloak>
          {% capture image_class %}
            absolute object-contain h-auto max-w-none {{ section.settings.zoom_level }}
          {% endcapture %}
          <div class="{{ image_class }}">
              {% render 'component__image',
              image: media,
              max_width: media.width,
              crop_class: 'object-contain',
              enable_lazy_load: true
            %}
          </div>
        </div>
      </div>
    {% endfor %}
  {% endcapture %}
  
  <div 
    class="flex w-full flex-col"
    x-data="{
      mouse_x: 0,
      mouse_y: 0,
      height: 0,
      width: 0,
      zoomed: false
    }"
    x-trap="fullscreen">

    {% comment %} Media {% endcomment %}
    <div 
      class="relative flex w-full flex-grow"
      x-ref="fullscreen"
      @mousemove="
        height = $refs.fullscreen.offsetHeight;
        width = $refs.fullscreen.offsetWidth;
        mouse_x = $event.offsetX; 
        mouse_y = $event.offsetY;
      ">

      {% comment %} Slides {% endcomment %}
      <div 
        class="js-zoomSlider inline-flex w-full snap-y snap-mandatory flex-col gap-4 overflow-y-auto scroll-smooth whitespace-nowrap"
        :class="{
          '!overflow-hidden': zoomed
        }"
        style="
          gap: {{ settings.layout_gap_size }}px;
        ">
        {{ slides }}
      </div>

      {% comment %} Product count and close button{% endcomment %}
      <div class="absolute top-4 z-20 w-full text-center">
        <div 
          class="
            window--full flex justify-between
          ">
          {% if product.media.size > 1 %}
            <div class="btn btn--unshade btn--smaller">
              <span x-text="gallery_index+1">1</span>/<span>{{ product.media.size }}</span>
            </div>
          {% endif %}
          <button 
            class="btn btn--unshade btn--smaller"
            title="{{ 'actions.close' | t }}"
            @click="
              fullscreen = false; 
              enable_body_scrolling = true;
              has_overlay = false;
            ">
            {% if settings.close_button_content contains 'icon' %}
              {% render 'component__icon', icon: 'x', size: '20' %} 
            {% endif %}
            {% if settings.close_button_content contains 'text' %}
              <span 
                {% if settings.close_button_content contains 'icon' %}
                  class="ml-1"
                {% endif %}>
                {{ 'actions.close' | t }}
              </span>
            {% endif %}
          </button>
        </div>
      </div>
      
      {% comment %} Indicators {% endcomment %}
      {% if product.media.size > 1 %}
        <div 
          class="
            absolute bottom-4 left-0 right-0 z-20 flex flex-wrap items-end justify-center gap-1 px-4 text-center
            {% if product.media.size < 15 %}
              mix-blend-difference
            {% endif %}
          ">
          {% if product.media.size > 15 %}
            <span class="type--smaller color__bg-unshade-1 border__button--radius animation-300 flex gap-1 px-4 py-2 backdrop-blur-sm">
              <span
                class="leading-none"
                x-text="gallery_index+1"
                >1</span
              >
              <span
                class="leading-none"
                >/</span
              >
              <span
                class="leading-none"
              >
                {{ product.media.size }}
              </span>
            </span>
          {% else %}
            {% for media in product.media %}
              <button 
                class="
                  animation-300--all border__button--radius color__bg-body h-1 w-2 opacity-25 backdrop-blur-sm
                  {% unless media.media_type == 'image' %} hidden {% endunless %}
                " 
                title="{{ 'actions.next' | t }}"
                :class="{ '!opacity-100 !w-6': gallery_index === {{ forloop.index0 }} }"
                @click="
                  galleryScrollToIndex({{ forloop.index0 }});
                "
              >
              </button>
            {% endfor %}
          {% endif %}
        </div>
      {% endif %}

    </div>
    
    {% comment %} Controls {% endcomment %}
    <div 
      class="
        hidden w-full py-4 md:block
        {{ settings.layout_horizontal }}
      ">
      <div class="flex justify-center gap-6">
        <div class="gap-2">
          <button 
            class="btn btn--plain btn--smaller"
            title="{{ 'actions.previous' | t }}"
            @click="galleryScrollBack();">
            {% render 'component__icon', icon: 'chevron-up', size: '16', class: '' %}
          </button>
          <button 
            class="btn btn--plain btn--smaller"
            title="{{ 'actions.next' | t }}"
            @click="galleryScrollNext();">
            {% render 'component__icon', icon: 'chevron-down', size: '16', class: '' %}
          </button>
        </div>
      </div>
    </div>
    
  </div>
{% endcapture %}

{% render 'component__fullscreen', fullscreen_id: 'fullscreen', content: fullscreen_content %}
