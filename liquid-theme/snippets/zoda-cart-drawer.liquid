{% comment %}
  Slide-in cart drawer — Liquid port of src/components/zoda/CartDrawer.tsx
  Always rendered in layout/theme.liquid so any page can open it.
{% endcomment %}

<div class="zoda-cart-drawer zoda-cart-drawer--light" data-zoda-cart-drawer data-open="false" aria-hidden="true">
  <div class="zoda-cart-drawer__backdrop" data-zoda-cart-close></div>
  <aside class="zoda-cart-drawer__panel" role="dialog" aria-label="Cart">
    <header style="display:flex;align-items:center;justify-content:space-between;padding:20px 24px;border-bottom:1px solid var(--line)">
      <strong class="zoda-cart-drawer__title">Your cart</strong>
      <button type="button" aria-label="Close cart" class="zoda-cart-drawer__remove" data-zoda-cart-close>✕</button>
    </header>

    <div class="zoda-cart-drawer__body" style="flex:1;overflow-y:auto;padding:0 24px" data-zoda-cart-body>
      {%- if cart.item_count == 0 -%}
        <div class="zoda-cart-drawer__empty">
          <p>Your cart is empty.</p>
          <a class="zoda-button" href="{{ routes.collections_url }}">Shop ZODA</a>
        </div>
      {%- else -%}
        {%- for item in cart.items -%}
          <div class="zoda-cart-drawer__item" data-cart-line="{{ item.key }}">
            <div class="zoda-cart-drawer__item-thumb">
              {%- if item.image -%}
                <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}">
              {%- endif -%}
            </div>
            <div style="flex:1;min-width:0">
              <div class="zoda-cart-drawer__item-title">{{ item.product.title }}</div>
              {%- if item.variant.title and item.variant.title != 'Default Title' -%}
                <div class="zoda-cart-drawer__item-variant">{{ item.variant.title }}</div>
              {%- endif -%}
              <div class="zoda-cart-drawer__item-price">{{ item.final_price | money }}</div>
              <div style="display:flex;align-items:center;gap:6px;margin-top:8px">
                <button type="button" class="zoda-cart-drawer__qty-btn" data-cart-qty="-1" data-key="{{ item.key }}">−</button>
                <span style="min-width:24px;text-align:center;font-size:13px">{{ item.quantity }}</span>
                <button type="button" class="zoda-cart-drawer__qty-btn" data-cart-qty="+1" data-key="{{ item.key }}">+</button>
                <button type="button" class="zoda-cart-drawer__remove" data-cart-remove data-key="{{ item.key }}" style="margin-left:auto">Remove</button>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if cart.item_count > 0 -%}
      <footer class="zoda-cart-drawer__footer" style="padding:20px 24px">
        <div class="zoda-cart-drawer__subtotal">
          <span>Subtotal</span>
          <span data-zoda-cart-subtotal>{{ cart.total_price | money }}</span>
        </div>
        <form action="{{ routes.cart_url }}" method="post">
          <button type="submit" name="checkout" class="zoda-cart-drawer__checkout">Checkout</button>
        </form>
      </footer>
    {%- endif -%}
  </aside>
</div>

<style>
  .zoda-cart-drawer { position: fixed; inset: 0; z-index: 100; pointer-events: none; }
  .zoda-cart-drawer[data-open="true"] { pointer-events: auto; }
  .zoda-cart-drawer__backdrop { position: absolute; inset: 0; background: rgba(0,0,0,.6); opacity: 0; transition: opacity .25s ease; }
  .zoda-cart-drawer[data-open="true"] .zoda-cart-drawer__backdrop { opacity: 1; }
  .zoda-cart-drawer__panel { position: absolute; top: 0; right: 0; height: 100%; width: min(420px, 100vw); background: #0a0a0a; color: #fff; display: flex; flex-direction: column; transform: translateX(100%); transition: transform .3s ease; }
  .zoda-cart-drawer[data-open="true"] .zoda-cart-drawer__panel { transform: translateX(0); }
</style>
