<!-- snippets/component__fullscreen.liquid -->
{% comment %}
  This component creates a overlay with a fullscreen overlay. It is ideal for displaying content in a focused manner.

  Accepts:
  - fullscreen_id: {string} Unique id for the overlay.
  - content: {Object} Liquid object of content to be displayed in the overlay.
  - footer: {Object} Liquid object of footer content.

  Globals:
  - enable_animations: {boolean} Indicates if animations should be enabled.

  Usage:
    {% render 'component__fullscreen',
      fullscreen_id: 'fullscreen',
      content: fullscreen_content,
      footer: fullscreen_footer
    %}

  Recommendations:
  - Use this snippet to display content in a fullscreen overlay. This is great for getting a focused look at specific content.
{% endcomment %}

<section
  class="color__bg-body color__text fixed inset-0 z-50 overflow-hidden"
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'labels.menu' | t }}"
  @keyup.escape.window="
    enable_body_scrolling = true;
    has_overlay = false;
    {{ fullscreen_id }} = false;
  "
  x-show="{{ fullscreen_id }}"
  x-trap="{{ fullscreen_id }}"
  x-cloak
>
  <div
    class="absolute bottom-0 left-0 right-0 top-0 m-auto flex h-auto overflow-auto text-left align-middle"
    x-show="{{ fullscreen_id }}"
    {% if settings.enable_animations %}
      x-transition:enter="animation-300"
      x-transition:enter-start="opacity-0 translate-y-8"
      x-transition:enter-end="opacity-100"
      x-transition:leave="animation-300"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0 translate-y-8"
    {% endif %}
    x-cloak
  >
    {{ content }}
  </div>

  {% if footer %}
    <div class="color__bg-body border--t-width color__border-divider-1 fixed bottom-0 w-full p-4">
      {{ footer }}
    </div>
  {% endif %}
</section>
