<!-- templates/customers/activate_account.liquid -->

<section>
  <div
    class="
      py-24
      {{ settings.x_margin }}
      {{ settings.x_alignment }}
    "
  >
    <div class="w-full max-w-prose">
      <h1>
        {{ 'actions.activate' | t }}
      </h1>
      {% form 'activate_customer_password' %}
        {% if form.errors %}
          <div class="color__bg-overlay-1 type--small border--radius mb-4 mt-2 p-2">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <label for="password">{{ 'labels.password' | t }}</label>
        <input id="password" class="mb-4" type="password" name="customer[password]">

        <label for="password_confirmation">{{ 'actions.confirm_password' | t }}</label>
        <input id="password_confirmation" class="mb-4" type="password" name="customer[password_confirmation]">

        <div class="mb-4">
          <button type="submit" class="btn">
            {{ 'actions.activate' | t }}
          </button>

          <span class="px-2">{{ 'labels.or' | t | downcase }}</span>

          <button type="submit" name="decline" class="btn btn--secondary">
            {{ 'actions.decline_invitation' | t }}
          </button>
        </div>

        <div class="border--t-width color__border-divider-1 flex flex-col gap-4 pt-4">
          <p>{{ 'info.already_have_account' | t }}</p>
          <div class="flex gap-4">
            <a href="{{ routes.account_login_url }}" class="btn btn--plain">
              {{ 'actions.log_in' | t }}
            </a>
          </div>
        </div>
      {% endform %}
    </div>
  </div>
</section>
