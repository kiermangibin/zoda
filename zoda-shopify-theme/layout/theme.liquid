<!doctype html>
<html
  class="min-h-[100vh]"
  lang="{{ request.locale.iso_code }}"
  x-data="app()"
  x-init="
    updateCart(false);
    handleSharedCart();
    handleSharedDiscount();
    initAnimationObserver();
    initPopstate();
    header_color = header_overlay_color;
    header_border = header_overlay_border;
  "
>
  <head>
    {% comment %} Meta {% endcomment %}
    {% render 'theme__meta' %}

    {% comment %} Preload {% endcomment %}
    {% unless settings.type_header_font.system? and settings.type_body_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {% endunless %}

    {% comment %} Assets {% endcomment %}
    {% render 'theme__styles' %}
    {% render 'assets' with 'styles.css', preload_stylesheet: true %}
    {{ 'zoda-fonts.css' | asset_url | stylesheet_tag }}
    {% liquid
      assign zoda_template_suffix = template.suffix | default: ''
      assign uses_zoda_foundation = false
      assign uses_zoda_home = false
      assign uses_zoda_product = false
      assign uses_zoda_fabrics = false
      assign uses_zoda_ikigai = false
      assign uses_zoda_mission = false

      if zoda_template_suffix contains 'zoda'
        assign uses_zoda_foundation = true
      endif

      if zoda_template_suffix == 'fabrics'
        assign uses_zoda_foundation = true
        assign uses_zoda_fabrics = true
      elsif template.name == 'page' and page.handle == 'fabrics'
        assign uses_zoda_foundation = true
        assign uses_zoda_fabrics = true
      endif

      if zoda_template_suffix == 'ikigai'
        assign uses_zoda_foundation = true
        assign uses_zoda_ikigai = true
      elsif template.name == 'page' and page.handle == 'ikigai'
        assign uses_zoda_foundation = true
        assign uses_zoda_ikigai = true
      endif

      if zoda_template_suffix == 'mission'
        assign uses_zoda_foundation = true
        assign uses_zoda_mission = true
      elsif template.name == 'page' and page.handle == 'mission'
        assign uses_zoda_foundation = true
        assign uses_zoda_mission = true
      endif

      if zoda_template_suffix contains 'home'
        assign uses_zoda_foundation = true
        assign uses_zoda_home = true
      endif

      if template.name == 'index'
        assign uses_zoda_foundation = true
        assign uses_zoda_home = true
      endif

      if zoda_template_suffix contains 'product'
        assign uses_zoda_foundation = true
        assign uses_zoda_product = true
      endif

      if zoda_template_suffix contains 'collection'
        assign uses_zoda_foundation = true
      endif
    %}
    {% if uses_zoda_foundation %}
      {{ 'zoda-tokens.css' | asset_url | stylesheet_tag }}
      <style>
        :root {
          --zoda-bg: {{ settings.color_background_body | default: '#050505' }};
          --zoda-fg: {{ settings.color_foreground_body | default: '#ffffff' }};
          --zoda-muted: {{ settings.color_foreground_body | default: '#ffffff' | color_modify: 'alpha', 0.62 }};
          --zoda-line: {{ settings.color_foreground_body | default: '#ffffff' | color_modify: 'alpha', 0.1 }};
          --zoda-line-strong: {{ settings.color_foreground_body | default: '#ffffff' | color_modify: 'alpha', 0.22 }};
          --zoda-accent: {{ settings.color_background_primary | default: '#55cda1' }};
          --zoda-accent-ink: {{ settings.color_foreground_primary | default: '#000000' }};
          --bg: var(--zoda-bg);
          --fg: var(--zoda-fg);
          --muted: var(--zoda-muted);
          --line: var(--zoda-line);
          --line-strong: var(--zoda-line-strong);
          --accent: var(--zoda-accent);
        }
      </style>
      {{ 'zoda-site-light.css' | asset_url | stylesheet_tag }}
      {{ 'zoda-product-card.css' | asset_url | stylesheet_tag }}
      {{ 'zoda-cart-drawer.css' | asset_url | stylesheet_tag }}
    {% endif %}
    {% if uses_zoda_home %}
      {{ 'zoda-home-circuit.css' | asset_url | stylesheet_tag }}
    {% endif %}
    {% if uses_zoda_product %}
      {{ 'zoda-pdp-page.css' | asset_url | stylesheet_tag }}
    {% endif %}
    {% if uses_zoda_fabrics %}
      {{ 'zoda-fabrics-page.css' | asset_url | stylesheet_tag }}
    {% endif %}
    {% if uses_zoda_ikigai %}
      {{ 'zoda-ikigai-page.css' | asset_url | stylesheet_tag }}
    {% endif %}
    {% if uses_zoda_mission %}
      {{ 'zoda-mission-page.css' | asset_url | stylesheet_tag }}
    {% endif %}
    {{ content_for_header }}

    {% comment %} Structured data {% endcomment %}
    {% render 'theme__structured-data' %}
  </head>

  <body
    class="
      animation-500--all min-h-[100vh] break-words
      {{ template | handle }}
    "
    :class="
      {
        'overflow-hidden': !enable_body_scrolling
      }
    "
    @scroll.window.throttle.100ms="
      if(!Shopify.visualPreviewMode){
        handleBodyScroll();
      }
    "
  >
    {% comment %} Skip to content link {% endcomment %}
    <a
      class="btn btn--plain btn--small fixed left-4 top-4 !z-[100] -translate-y-20 transform opacity-0 shadow-md focus:translate-y-0 focus:opacity-100"
      href="#root"
    >
      {{ 'actions.skip_to_content' | t }}
    </a>

    {% comment %} Header {% endcomment %}
    <header
      class="
        animation-1000 z-50
        {{ settings.header_position }}
        {% if settings.header_blend %} mix-blend-difference {% endif %}
        {% if settings.header_position == 'dynamic' %}sticky top-0 left-0 right-0{% endif %}
        {% if settings.header_position == 'sticky' %}sticky top-0 left-0 right-0{% endif %}
        {% unless request.design_mode %}
          {% if settings.enable_animations %}
            {% if settings.animate_header == 'slide' %}
              opacity-0 -translate-y-4 js-animation
            {% endif %}
            {% if settings.animate_header == 'fade' %}
              opacity-0 js-animation
            {% endif %}
          {% endif %}
        {% endunless %}
      "
      {% if settings.header_position == 'dynamic' %}
        :style="
          is_scrolled ?
          'pointer-events: none;' :
          'pointer-events: auto;'
        "
      {% endif %}
      {% if settings.enable_animations %}
        {% if settings.animate_header == 'slide' %}
          data-delay="500"
          data-replace="
            {
              'opacity-0' : 'opacity-100',
              '-translate-y-4' : ''
            }
          "
        {% endif %}
        {% if settings.animate_header == 'fade' %}
          data-delay="500"
          data-replace="
            {
              'opacity-0' : 'opacity-100'
            }
          "
        {% endif %}
      {% endif %}
      :class="
        {
          '!-z-10' : has_overlay
        }
      "
      x-ref="header"
      x-init="header_group_height = $refs.header.offsetHeight;"
    >
      <div
        class="animation-500"
        {% if settings.header_position == 'dynamic' %}
          :style="
            is_scrolled ?
            'transform: translateY(-2rem); opacity: 0; pointer-events: none;' :
            'transform: none; opacity: 1;'
          "
        {% endif %}
      >
        {% sections 'header-group' %}
      </div>
    </header>

    {% comment %} Cart, menu and search {% endcomment %}
    {% section 'theme__cart' %}
    {% section 'theme__menu' %}
    {% section 'theme__search' %}

    {% comment %} Main Content {% endcomment %}
    <main
      id="root"
      role="main"
    >
      {{ content_for_layout }}
    </main>

    {% comment %} Section groups {% endcomment %}
    {% sections 'footer-group' %}
    {% sections 'overlay-group' %}

    {% comment %} Overlays {% endcomment %}
    {% if uses_zoda_foundation %}
      {% render 'zoda-cart-drawer' %}
    {% endif %}
    {% render 'theme__quick-overlays' %}
    {% render 'theme__localization-overlay' %}
    {% render 'theme__audio-overlay' %}
    {% render 'theme__error-overlay' %}
    {% render 'theme__discount-overlay' %}

    {% comment %} Scripts {% endcomment %}
    {% render 'assets' with 'main.js' %}
    {% render 'theme__scripts' %}
    {% if uses_zoda_home %}
      <script src="{{ 'zoda-circuit.js' | asset_url }}" defer></script>
    {% endif %}
    {% if uses_zoda_foundation %}
      <script src="{{ 'zoda-cart.js' | asset_url }}" defer></script>
    {% endif %}
    {% if uses_zoda_mission %}
      <script src="{{ 'zoda-mission.js' | asset_url }}" defer></script>
    {% endif %}
  </body>
</html>
