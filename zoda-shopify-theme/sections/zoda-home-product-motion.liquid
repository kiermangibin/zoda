{% liquid
  assign featured_collection = section.settings.collection
  if featured_collection == blank
    assign featured_collection = shop.metafields.zoda.featured_collection.value
  endif
  if featured_collection == blank
    assign featured_collection = collections['new-arrivals']
  endif
  if featured_collection == blank or featured_collection.products_count == 0
    assign featured_collection = collections.all
  endif
%}

<section id="zoda-home-product-motion-{{ section.id }}" class="zoda-circuit" data-zoda-home-section="product-motion">
  <article id="zoda-circuit-home-2" class="zoda-circuit__panel zoda-circuit__panel--signal">
    <div class="zoda-circuit__signal-grid">
      <div>
        {% if section.settings.kicker != blank %}
          <p class="zoda-circuit__kicker" data-animate>{{ section.settings.kicker }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="zoda-circuit__heading" data-animate style="--zoda-delay: 90ms">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
      </div>

      <div class="zoda-circuit__signal-meta" data-animate style="--zoda-delay: 180ms">
        {% if section.settings.copy != blank %}
          <p class="zoda-circuit__copy">{{ section.settings.copy }}</p>
        {% endif %}

        {% if section.settings.line != blank %}
          <div class="zoda-circuit__signal-line">{{ section.settings.line }}</div>
        {% endif %}
      </div>
    </div>

    <div class="zoda-pim" data-animate style="--zoda-delay: 260ms">
      {% if featured_collection != blank and featured_collection.products_count > 0 %}
        <div class="zoda-pim__rail">
          {% for product in featured_collection.products limit: section.settings.product_limit %}
            {% render 'zoda-product-card', product: product %}
          {% endfor %}
        </div>

        <div class="zoda-pim__controls">
          <button
            type="button"
            aria-label="Scroll left"
            class="zoda-pim__nav"
            onclick="this.closest('.zoda-pim').querySelector('.zoda-pim__rail').scrollBy({left:-400,behavior:'smooth'})"
          >
            ‹
          </button>
          <button
            type="button"
            aria-label="Scroll right"
            class="zoda-pim__nav"
            onclick="this.closest('.zoda-pim').querySelector('.zoda-pim__rail').scrollBy({left:400,behavior:'smooth'})"
          >
            ›
          </button>
        </div>
      {% else %}
        <p class="zoda-circuit__copy">
          Select a collection with products to populate this section.
        </p>
      {% endif %}
    </div>
  </article>
</section>

{% schema %}
{
  "name": "ZODA Product Motion",
  "tag": "section",
  "class": "zoda-home-product-motion-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "What's New / 02"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Products in motion."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "ZODA is built for training, recovery, and every hour between. Step into the circuit and move with intent."
    },
    {
      "type": "text",
      "id": "line",
      "label": "Signal line",
      "default": "In It To Win It"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Featured collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Products to show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "ZODA Product Motion"
    }
  ]
}
{% endschema %}
