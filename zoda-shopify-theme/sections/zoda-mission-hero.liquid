{% assign video_asset = section.settings.video_asset | default: 'sustainability-video.mp4' %}

<section
  id="mission-intro"
  class="zoda-fabrics-page zoda-mission-page zoda-fabrics-snap__section zoda-mission-hero"
  data-zoda-page-section="mission-hero"
>
  {% if section.settings.video_url != blank %}
    <video
      class="zoda-mission-hero__video"
      src="{{ section.settings.video_url }}"
      aria-label="{{ section.settings.video_label | escape }}"
      autoplay
      loop
      muted
      playsinline
    ></video>
  {% else %}
    <video
      class="zoda-mission-hero__video"
      aria-label="{{ section.settings.video_label | escape }}"
      autoplay
      loop
      muted
      playsinline
    >
      <source src="{{ video_asset | asset_url }}" type="video/mp4">
    </video>
  {% endif %}

  <div class="zoda-mission-hero__wash"></div>

  <div class="zoda-mission-hero__content">
    {% if section.settings.kicker != blank %}
      <p class="zoda-mission-kicker">{{ section.settings.kicker }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1>{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.copy != blank %}
      <p>{{ section.settings.copy }}</p>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="zoda-mission-hero__stats" aria-label="{{ section.settings.stats_label | escape }}">
        {% for block in section.blocks %}
          {% if block.settings.stat != blank %}
            <span {{ block.shopify_attributes }}>{{ block.settings.stat }}</span>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="zoda-mission-hero__card" aria-label="{{ section.settings.card_label | escape }}">
    {% if section.settings.card_kicker != blank %}
      <span>{{ section.settings.card_kicker }}</span>
    {% endif %}

    {% if section.settings.card_heading != blank %}
      <strong>{{ section.settings.card_heading }}</strong>
    {% endif %}

    {% if section.settings.card_copy != blank %}
      <p>{{ section.settings.card_copy }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "ZODA Mission Hero",
  "tag": "section",
  "class": "zoda-mission-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "video_asset",
      "label": "Theme asset video filename",
      "default": "sustainability-video.mp4"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "External video URL"
    },
    {
      "type": "text",
      "id": "video_label",
      "label": "Video accessibility label",
      "default": "ZODA Mission video"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "The Final Mission"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "21-day build a habit mission."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "A digital copy of the board game, rules, official playbook and Mission Bag blueprint. Built for athletes who move with intent and live with purpose."
    },
    {
      "type": "text",
      "id": "stats_label",
      "label": "Stats accessibility label",
      "default": "Mission summary"
    },
    {
      "type": "text",
      "id": "card_label",
      "label": "Card accessibility label",
      "default": "Mission summary card"
    },
    {
      "type": "text",
      "id": "card_kicker",
      "label": "Card kicker",
      "default": "Play & Win"
    },
    {
      "type": "text",
      "id": "card_heading",
      "label": "Card heading",
      "default": "The Final Mission"
    },
    {
      "type": "text",
      "id": "card_copy",
      "label": "Card copy",
      "default": "Start clean. Build the streak. Finish Beast."
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "stat",
          "label": "Stat"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZODA Mission Hero",
      "blocks": [
        { "type": "stat", "settings": { "stat": "21 days" } },
        { "type": "stat", "settings": { "stat": "450+ points" } },
        { "type": "stat", "settings": { "stat": "3 badge tiers" } }
      ]
    }
  ]
}
{% endschema %}
