{% liquid
  assign hero_video_url = section.settings.video_embed_url | default: 'https://player.vimeo.com/video/1135229306?autoplay=1&muted=1&loop=0&autopause=1&controls=0&playsinline=1&title=0&byline=0&portrait=0'
%}

<section id="zoda-home-hero-{{ section.id }}" class="zoda-circuit" data-zoda-home-section="hero">
  <div class="zoda-circuit__track">
    <article id="zoda-circuit-home-1" class="zoda-circuit__panel zoda-circuit__panel--video is-active">
      <div class="zoda-circuit__video-media" aria-hidden="true">
        <iframe
          class="zoda-circuit__video"
          src="{{ hero_video_url | escape }}"
          title="{{ section.settings.video_title | escape }}"
          allow="autoplay; fullscreen; picture-in-picture"
          loading="eager"
        ></iframe>
      </div>

      <div class="zoda-circuit__content zoda-circuit__video-content">
        {% if section.settings.kicker != blank %}
          <p class="zoda-circuit__kicker" data-animate>{{ section.settings.kicker }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h1 class="zoda-circuit__heading" data-animate style="--zoda-delay: 90ms">
            {{ section.settings.heading }}
          </h1>
        {% endif %}

        <div class="zoda-circuit__actions" data-animate style="--zoda-delay: 180ms">
          {% if section.settings.primary_label != blank and section.settings.primary_url != blank %}
            <a class="zoda-circuit__button" href="{{ section.settings.primary_url }}">
              {{ section.settings.primary_label }}
            </a>
          {% endif %}

          {% if section.settings.secondary_label != blank and section.settings.secondary_url != blank %}
            <a class="zoda-circuit__button-secondary" href="{{ section.settings.secondary_url }}">
              {{ section.settings.secondary_label }}
            </a>
          {% endif %}
        </div>

        {% if section.blocks.size > 0 %}
          <div
            class="zoda-circuit__press-strip"
            data-animate
            style="--zoda-delay: 360ms"
            aria-label="{{ section.settings.press_label | escape }}"
          >
            {% if section.settings.press_label != blank %}
              <span class="zoda-circuit__press-label">{{ section.settings.press_label }}</span>
            {% endif %}

            {% for block in section.blocks %}
              {% liquid
                assign press_label_handle = block.settings.label | handle
                assign press_logo_class = 'zoda-circuit__press-logo'
                if press_label_handle contains 'straits'
                  assign press_logo_class = press_logo_class | append: ' zoda-circuit__press-logo--straits'
                elsif press_label_handle contains 'money'
                  assign press_logo_class = press_logo_class | append: ' zoda-circuit__press-logo--money'
                endif
              %}
              <a
                class="{{ press_logo_class }}"
                href="{{ block.settings.url }}"
                {% if block.settings.open_new_tab %}
                  target="_blank" rel="noopener"
                {% endif %}
                aria-label="{{ block.settings.label | escape }}"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.logo != blank %}
                  <img
                    src="{{ block.settings.logo | image_url: width: 360 }}"
                    alt="{{ block.settings.label | escape }}"
                    loading="lazy"
                    width="{{ block.settings.logo.width }}"
                    height="{{ block.settings.logo.height }}"
                  >
                {% elsif press_label_handle contains 'straits' %}
                  <img
                    src="{{ 'the-straits-times-logo_480x480.png' | asset_url }}"
                    alt="{{ block.settings.label | escape }}"
                    loading="lazy"
                    width="360"
                    height="120"
                  >
                {% elsif press_label_handle contains 'money' %}
                  <img
                    src="{{ 'moneyfmlogo-1.png' | asset_url }}"
                    alt="{{ block.settings.label | escape }}"
                    loading="lazy"
                    width="180"
                    height="120"
                  >
                {% else %}
                  <span>{{ block.settings.label }}</span>
                {% endif %}
              </a>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </article>
  </div>
</section>

{% schema %}
{
  "name": "ZODA Home Hero",
  "tag": "section",
  "class": "zoda-home-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Our Mission / 01"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Changing the way humans experience activewear"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Partner With Us"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Explore Collections"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "video_embed_url",
      "label": "Video embed URL",
      "default": "https://player.vimeo.com/video/1135229306?autoplay=1&muted=1&loop=0&autopause=1&controls=0&playsinline=1&title=0&byline=0&portrait=0"
    },
    {
      "type": "text",
      "id": "video_title",
      "label": "Video title",
      "default": "ZODA opener video"
    },
    {
      "type": "text",
      "id": "press_label",
      "label": "Press label",
      "default": "YOU MIGHT HAVE SEEN US AT:"
    }
  ],
  "blocks": [
    {
      "type": "press_logo",
      "name": "Press logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Press feature"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open in new tab",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZODA Home Hero",
      "blocks": [
        {
          "type": "press_logo",
          "settings": {
            "label": "The Straits Times",
            "url": "https://www.straitstimes.com/life/style/the-next-fit-thing-sportswears-glow-up-moment-is-here"
          }
        },
        {
          "type": "press_logo",
          "settings": {
            "label": "Money FM 89.3",
            "url": "https://www.instagram.com/p/DIdbKN5BiQI/"
          }
        }
      ]
    }
  ]
}
{% endschema %}
