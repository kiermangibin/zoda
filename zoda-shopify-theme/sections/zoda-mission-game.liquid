{% liquid
  assign initiator_icon = 'Initiator-trophy.png' | asset_url
  assign ascender_icon = 'ascender-trophy.png' | asset_url
  assign beast_icon = 'finisher-trophy.png' | asset_url
  assign final_icon = 'Final Mission.png' | asset_url
%}

<section
  id="mission-game"
  class="zoda-fabrics-page zoda-mission-page zoda-fabrics-snap__section zoda-mission-section zoda-mission-game"
  data-zoda-page-section="mission-game"
  data-zoda-mission-game
>
  <div class="zoda-mission-copy zoda-mission-game__intro">
    <div class="zoda-mission-game__rules" aria-label="{{ section.settings.rules_label | escape }}">
      <span>{{ section.settings.rules_kicker }}</span>
      <h3>{{ section.settings.rules_heading }}</h3>
      <ul>
        {% for block in section.blocks %}
          {% if block.type == 'rule' and block.settings.text != blank %}
            <li {{ block.shopify_attributes }}>
              <i aria-hidden="true"></i>
              <span>{{ block.settings.text }}</span>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>

    <div class="zoda-mission-finishers" aria-label="{{ section.settings.finishers_label | escape }}">
      <article class="zoda-mission-finisher" data-tone="gold">
        <div>
          <span>Week 1 Finisher</span>
          <strong>Initiator</strong>
        </div>
        <img src="{{ 'Initiator-trophy.png' | asset_url }}" alt="" width="160" height="160">
      </article>
      <article class="zoda-mission-finisher" data-tone="coral">
        <div>
          <span>Week 2 Finisher</span>
          <strong>Ascender</strong>
        </div>
        <img src="{{ 'ascender-trophy.png' | asset_url }}" alt="" width="160" height="160">
      </article>
      <article class="zoda-mission-finisher" data-tone="green">
        <div>
          <span>Week 3 Finisher</span>
          <strong>Beast</strong>
        </div>
        <img src="{{ 'finisher-trophy.png' | asset_url }}" alt="" width="160" height="160">
      </article>
    </div>
  </div>

  <div class="zoda-mission-game__stage">
    <div class="zoda-mission-path" aria-label="{{ section.settings.path_label | escape }}">
      <div class="zoda-mission-path__header">
        <span>{{ section.settings.path_heading }}</span>
        <strong>21 days</strong>
      </div>
      <div class="zoda-mission-path__track">
        <button
          type="button"
          class="zoda-mission-path__space"
          data-mission-space
          data-space-id="start"
          data-label="Start"
          data-type="start"
          data-tone="black"
          data-week="Entry"
          data-points="Ready"
          data-day="1"
          data-detail="Begin the 21-day mission. Complete spaces, protect the streak and build toward Beast."
          aria-pressed="true"
        >
          <img class="zoda-mission-path__start-logo" src="{{ 'zoda-Z.png' | asset_url }}" alt="" width="96" height="96">
          <strong>Start</strong>
          <em>Ready</em>
        </button>

        {% for block in section.blocks %}
          {% if block.type == 'space' %}
            {% assign space_icon = '' %}
            {% if block.settings.icon == 'initiator' %}
              {% assign space_icon = initiator_icon %}
            {% elsif block.settings.icon == 'ascender' %}
              {% assign space_icon = ascender_icon %}
            {% elsif block.settings.icon == 'beast' %}
              {% assign space_icon = beast_icon %}
            {% elsif block.settings.icon == 'final' %}
              {% assign space_icon = final_icon %}
            {% endif %}

            <button
              type="button"
              class="zoda-mission-path__space"
              data-mission-space
              data-space-id="{{ block.id }}"
              data-label="{{ block.settings.label | escape }}"
              data-type="{{ block.settings.space_type }}"
              data-tone="{{ block.settings.tone }}"
              data-week="{{ block.settings.week | escape }}"
              data-points="{{ block.settings.points | escape }}"
              data-day="{{ block.settings.day }}"
              data-detail="{{ block.settings.detail | escape }}"
              {% if space_icon != blank %}
                data-icon="{{ space_icon }}"
              {% endif %}
              {{ block.shopify_attributes }}
              aria-pressed="false"
            >
              {% if block.settings.space_type == 'final' and space_icon != blank %}
                {% if block.settings.icon == 'initiator' %}
                  <img class="zoda-mission-path__icon" src="{{ 'Initiator-trophy.png' | asset_url }}" alt="" width="96" height="96">
                {% elsif block.settings.icon == 'ascender' %}
                  <img class="zoda-mission-path__icon" src="{{ 'ascender-trophy.png' | asset_url }}" alt="" width="96" height="96">
                {% elsif block.settings.icon == 'beast' %}
                  <img class="zoda-mission-path__icon" src="{{ 'finisher-trophy.png' | asset_url }}" alt="" width="96" height="96">
                {% elsif block.settings.icon == 'final' %}
                  <img class="zoda-mission-path__icon" src="{{ 'Final Mission.png' | asset_url }}" alt="" width="96" height="96">
                {% endif %}
                <strong>{{ block.settings.label }}</strong>
              {% else %}
                <span>{{ block.settings.day }}</span>
                <strong>{{ block.settings.label }}</strong>
                <em>{{ block.settings.points }}</em>
              {% endif %}
            </button>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <aside class="zoda-mission-game__detail" data-tone="black" data-mission-detail aria-live="polite">
      <img class="zoda-mission-game__detail-icon" data-mission-detail-icon src="{{ 'zoda-Z.png' | asset_url }}" alt="" width="96" height="96" hidden>
      <span data-mission-detail-week>Entry</span>
      <h3 data-mission-detail-title>Start</h3>
      <p data-mission-detail-copy>Begin the 21-day mission. Complete spaces, protect the streak and build toward Beast.</p>
      <div class="zoda-mission-game__daily" data-mission-daily hidden>
        <span>Mission Active</span>
        <strong data-mission-daily-day>Day 1 / 21</strong>
        <small data-mission-daily-start>Started</small>
      </div>
      <dl>
        <div>
          <dt>Points</dt>
          <dd data-mission-detail-points>Ready</dd>
        </div>
        <div>
          <dt>Space</dt>
          <dd data-mission-detail-type>start</dd>
        </div>
      </dl>
      <div class="zoda-mission-game__actions">
        <button type="button" data-mission-start>Start Mission</button>
        <button type="button" data-mission-today hidden>Today's Challenge</button>
      </div>
    </aside>
  </div>
</section>

{% schema %}
{
  "name": "ZODA Mission Game",
  "tag": "section",
  "class": "zoda-mission-game-section",
  "settings": [
    { "type": "text", "id": "rules_label", "label": "Rules accessibility label", "default": "Play and win rules" },
    { "type": "text", "id": "rules_kicker", "label": "Rules kicker", "default": "Play & Win" },
    { "type": "text", "id": "rules_heading", "label": "Rules heading", "default": "21-day build a habit mission" },
    { "type": "text", "id": "finishers_label", "label": "Finishers accessibility label", "default": "Mission finisher tiers" },
    { "type": "text", "id": "path_label", "label": "Path accessibility label", "default": "Interactive mission game path" },
    { "type": "text", "id": "path_heading", "label": "Path heading", "default": "21-day path" }
  ],
  "blocks": [
    {
      "type": "rule",
      "name": "Rule",
      "settings": [
        { "type": "text", "id": "text", "label": "Rule" }
      ]
    },
    {
      "type": "space",
      "name": "Board space",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "week", "label": "Week" },
        { "type": "text", "id": "points", "label": "Points" },
        { "type": "textarea", "id": "detail", "label": "Detail" },
        { "type": "number", "id": "day", "label": "Day", "default": 1 },
        {
          "type": "select",
          "id": "space_type",
          "label": "Space type",
          "options": [
            { "value": "challenge", "label": "Challenge" },
            { "value": "bonus", "label": "Bonus" },
            { "value": "repeat", "label": "Repeat" },
            { "value": "beast", "label": "Beast" },
            { "value": "badge", "label": "Badge" },
            { "value": "final", "label": "Final" }
          ],
          "default": "challenge"
        },
        {
          "type": "select",
          "id": "tone",
          "label": "Tone",
          "options": [
            { "value": "green", "label": "Green" },
            { "value": "orange", "label": "Orange" },
            { "value": "gold", "label": "Gold" },
            { "value": "coral", "label": "Coral" },
            { "value": "mint", "label": "Mint" },
            { "value": "black", "label": "Black" }
          ],
          "default": "green"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "initiator", "label": "Initiator" },
            { "value": "ascender", "label": "Ascender" },
            { "value": "beast", "label": "Beast" },
            { "value": "final", "label": "Final Mission" }
          ],
          "default": "none"
        }
      ]
    }
  ],
  "presets": [{ "name": "ZODA Mission Game" }]
}
{% endschema %}
