<section class="zoda-fabrics-page" data-zoda-page-section="fabrics-hero">
  <div class="zoda-fabrics-snap__section zoda-fabrics-hero">
    {% if section.settings.hero_image != blank %}
      {{
        section.settings.hero_image
        | image_url: width: 2200
        | image_tag:
          class: 'zoda-fabrics-hero__media',
          loading: 'eager',
          widths: '750, 1100, 1600, 2200',
          sizes: '100vw',
          alt: section.settings.image_alt
      }}
    {% elsif section.settings.hero_image_url != blank %}
      {% # theme-check-disable RemoteAsset %}
      <img
        class="zoda-fabrics-hero__media"
        src="{{ section.settings.hero_image_url }}"
        alt="{{ section.settings.image_alt | escape }}"
        width="2200"
        height="1238"
        loading="eager"
      >
      {% # theme-check-enable RemoteAsset %}
    {% endif %}

    <div class="zoda-fabrics-hero__overlay"></div>

    <div class="zoda-fabrics-hero__content">
      {% if section.settings.kicker != blank %}
        <p class="zoda-fabrics-hero__kicker">{{ section.settings.kicker }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="zoda-fabrics-hero__title">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.lede != blank %}
        <p class="zoda-fabrics-hero__lede">{{ section.settings.lede }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ZODA Fabrics Hero",
  "tag": "section",
  "class": "zoda-fabrics-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "url",
      "id": "hero_image_url",
      "label": "Fallback image URL"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "ZODA fabrics swatches"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Our Fabrics"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore the Fabrics Behind ZODA"
    },
    {
      "type": "textarea",
      "id": "lede",
      "label": "Lede",
      "default": "Engineered for Performance, Comfort and Sustainability."
    }
  ],
  "presets": [
    {
      "name": "ZODA Fabrics Hero"
    }
  ]
}
{% endschema %}
