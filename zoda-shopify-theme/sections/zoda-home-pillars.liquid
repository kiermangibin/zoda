<section id="zoda-home-pillars-{{ section.id }}" class="zoda-circuit" data-zoda-home-section="pillars">
  <article id="zoda-circuit-home-4" class="zoda-circuit__panel zoda-circuit__panel--pillars">
    <div class="zoda-circuit__intro-row">
      <div>
        {% if section.settings.kicker != blank %}
          <p class="zoda-circuit__kicker" data-animate>{{ section.settings.kicker }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="zoda-circuit__heading" data-animate style="--zoda-delay: 90ms">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
      </div>

      {% if section.settings.copy != blank %}
        <p class="zoda-circuit__copy" data-animate style="--zoda-delay: 180ms">
          {{ section.settings.copy }}
        </p>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="zoda-circuit__cards">
        {% for block in section.blocks %}
          {% liquid
            assign delay = forloop.index0 | times: 100 | plus: 220
          %}
          <div
            class="zoda-circuit__pillar-card"
            tabindex="0"
            data-animate
            style="--zoda-delay: {{ delay }}ms"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.number != blank %}
              <span class="zoda-circuit__card-number">{{ block.settings.number }}</span>
            {% endif %}

            {% if block.settings.title != blank %}
              <strong class="zoda-circuit__card-title">{{ block.settings.title }}</strong>
            {% endif %}

            {% if block.settings.copy != blank %}
              <p class="zoda-circuit__card-copy">{{ block.settings.copy }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </article>
</section>

{% schema %}
{
  "name": "ZODA Pillars",
  "tag": "section",
  "class": "zoda-home-pillars-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Alpha Standard / 04"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Three standards."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Performance gear should work harder than ordinary activewear: move with the body, respect the planet, and connect athletes who train with purpose."
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Technology"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Engineered fabrics, body-mapped fit, and strategic construction help manage sweat, stretch, chafe, and support when training intensity rises."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZODA Pillars",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "number": "01",
            "title": "Technology",
            "copy": "Engineered fabrics, body-mapped fit, and strategic construction help manage sweat, stretch, chafe, and support when training intensity rises."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "number": "02",
            "title": "Sustainability",
            "copy": "We prioritize responsible fibers such as recycled polyester, regenerated nylon, and certified cotton so performance does not come at the planet's expense."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "number": "03",
            "title": "Community",
            "copy": "ZODA is built for athletes who show up, share standards, and push each other past the easy rep, the safe pace, and the old limit."
          }
        }
      ]
    }
  ]
}
{% endschema %}
