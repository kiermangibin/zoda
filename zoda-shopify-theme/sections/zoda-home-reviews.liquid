<section id="zoda-home-reviews-{{ section.id }}" class="zoda-circuit" data-zoda-home-section="reviews">
  <article id="zoda-circuit-home-9" class="zoda-circuit__panel zoda-circuit__panel--reviews zoda-circuit__panel--command">
    <div class="zoda-circuit__content">
      {% if section.settings.kicker != blank %}
        <p class="zoda-circuit__kicker" data-animate>{{ section.settings.kicker }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="zoda-circuit__heading" data-animate style="--zoda-delay: 90ms">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.copy != blank %}
        <p class="zoda-circuit__copy" data-animate style="--zoda-delay: 180ms">
          {{ section.settings.copy }}
        </p>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="zoda-circuit__reviews-grid" data-animate style="--zoda-delay: 240ms">
          <div class="zoda-circuit__reviews-track">
            {% for block in section.blocks %}
              {% render 'zoda-review-card', block: block, index: forloop.index %}
            {% endfor %}

            {% if section.settings.loop_reviews %}
              {% for block in section.blocks %}
                {% render 'zoda-review-card', block: block, index: forloop.index, is_duplicate: true %}
              {% endfor %}
            {% endif %}
          </div>
        </div>
      {% else %}
        <div class="zoda-circuit__reviews-empty" data-animate style="--zoda-delay: 240ms">
          <p>{{ section.settings.empty_heading }}</p>
          <span class="zoda-circuit__reviews-empty-sub">{{ section.settings.empty_copy }}</span>
        </div>
      {% endif %}
    </div>
  </article>
</section>

{% schema %}
{
  "name": "ZODA Reviews",
  "tag": "section",
  "class": "zoda-home-reviews-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Reviews / 08"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What athletes are saying."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Real product feedback and athlete notes. Replace these blocks with a reviews app when the store is connected."
    },
    {
      "type": "checkbox",
      "id": "loop_reviews",
      "label": "Duplicate cards for continuous rail",
      "default": true
    },
    {
      "type": "text",
      "id": "empty_heading",
      "label": "Empty heading",
      "default": "Reviews coming soon."
    },
    {
      "type": "textarea",
      "id": "empty_copy",
      "label": "Empty copy",
      "default": "Connect a review app or add manual review blocks to populate this section."
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag",
          "default": "01 / Training"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "The fit stays locked in during every rep, but still feels easy enough for the rest of the day."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "ZODA Athlete"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Hybrid Training"
        },
        {
          "type": "text",
          "id": "product",
          "label": "Product note",
          "default": "on Core Performance"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Avatar"
        },
        {
          "type": "text",
          "id": "initials",
          "label": "Fallback initials",
          "default": "ZA"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZODA Reviews"
    }
  ]
}
{% endschema %}
