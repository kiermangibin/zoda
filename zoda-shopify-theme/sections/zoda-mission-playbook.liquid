{% liquid
  assign final_icon = 'Final Mission.png' | asset_url
  assign zoda_logo = 'zoda-Z.png' | asset_url
%}

<section
  id="mission-playbook"
  class="zoda-fabrics-page zoda-mission-page zoda-fabrics-snap__section zoda-mission-section zoda-mission-playbook"
  data-zoda-page-section="mission-playbook"
  data-zoda-mission-playbook
>
  <div class="zoda-mission-copy">
    {% if section.settings.kicker != blank %}
      <p class="zoda-mission-kicker">{{ section.settings.kicker }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
  </div>

  <div class="zoda-mission-playbook__cards" aria-label="{{ section.settings.cards_label | escape }}">
    <button type="button" class="zoda-mission-playbook__nav" aria-label="Previous playbook card" data-playbook-prev>
      <span aria-hidden="true">&lt;</span>
    </button>

    <div class="zoda-mission-playbook__sheet">
      <article class="zoda-mission-week" data-playbook-card data-card-index="0">
        <div class="zoda-mission-week__head">
          <span>Week 1</span>
          <h3>Foundation</h3>
        </div>
        <div class="zoda-mission-week__body">
          <ul>
            {% for block in section.blocks %}
              {% if block.type == 'week_item' and block.settings.card == 'foundation' %}
                <li data-playbook-item-row {{ block.shopify_attributes }}>
                  <button
                    type="button"
                    class="zoda-mission-week__check"
                    aria-pressed="false"
                    data-playbook-check
                    data-check-id="week-1-{{ block.id }}"
                  >
                    <i aria-hidden="true"></i>
                    <b>{{ block.settings.name }}</b>
                    <span>{{ block.settings.detail }}</span>
                    <strong>{{ block.settings.points }}</strong>
                  </button>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      </article>

      <article class="zoda-mission-week" data-playbook-card data-card-index="1" hidden>
        <div class="zoda-mission-week__head">
          <span>Week 2</span>
          <h3>Ascend</h3>
        </div>
        <div class="zoda-mission-week__body">
          <ul>
            {% for block in section.blocks %}
              {% if block.type == 'week_item' and block.settings.card == 'ascend' %}
                <li data-playbook-item-row {{ block.shopify_attributes }}>
                  <button
                    type="button"
                    class="zoda-mission-week__check"
                    aria-pressed="false"
                    data-playbook-check
                    data-check-id="week-2-{{ block.id }}"
                  >
                    <i aria-hidden="true"></i>
                    <b>{{ block.settings.name }}</b>
                    <span>{{ block.settings.detail }}</span>
                    <strong>{{ block.settings.points }}</strong>
                  </button>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      </article>

      <article class="zoda-mission-week" data-playbook-card data-card-index="2" hidden>
        <div class="zoda-mission-week__head">
          <span>Week 3</span>
          <h3>Dominance</h3>
        </div>
        <div class="zoda-mission-week__body">
          <ul>
            {% for block in section.blocks %}
              {% if block.type == 'week_item' and block.settings.card == 'dominance' %}
                <li data-playbook-item-row {{ block.shopify_attributes }}>
                  <button
                    type="button"
                    class="zoda-mission-week__check"
                    aria-pressed="false"
                    data-playbook-check
                    data-check-id="week-3-{{ block.id }}"
                  >
                    <i aria-hidden="true"></i>
                    <b>{{ block.settings.name }}</b>
                    <span>{{ block.settings.detail }}</span>
                    <strong>{{ block.settings.points }}</strong>
                  </button>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      </article>

      <article
        class="zoda-mission-week zoda-mission-week--note zoda-mission-week--final"
        data-playbook-card
        data-card-index="3"
        hidden
      >
        <img src="{{ final_icon }}" alt="" width="180" height="180" aria-hidden="true">
        <div class="zoda-mission-week__final-title">
          <img src="{{ zoda_logo }}" alt="" width="96" height="96" aria-hidden="true">
          <h3>Final Mission</h3>
        </div>
        <ul class="zoda-mission-week__final-list">
          {% for block in section.blocks %}
            {% if block.type == 'note_item' and block.settings.card == 'final' %}
              <li data-playbook-item-row {{ block.shopify_attributes }}>
                <button
                  type="button"
                  class="zoda-mission-week__check"
                  aria-pressed="false"
                  data-playbook-check
                  data-check-id="final-{{ block.id }}"
                >
                  <i aria-hidden="true"></i>
                  <span>{{ block.settings.text }}</span>
                </button>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </article>

      <article class="zoda-mission-week zoda-mission-week--note" data-playbook-card data-card-index="4" hidden>
        <div class="zoda-mission-week__head">
          <span>Rulebook</span>
          <h3>Streak Hit Rulebook</h3>
        </div>
        <div class="zoda-mission-week__body">
          <ul>
            {% for block in section.blocks %}
              {% if block.type == 'note_item' and block.settings.card == 'rulebook' %}
                <li data-playbook-item-row {{ block.shopify_attributes }}>
                  <button
                    type="button"
                    class="zoda-mission-week__check"
                    aria-pressed="false"
                    data-playbook-check
                    data-check-id="rulebook-{{ block.id }}"
                  >
                    <i aria-hidden="true"></i>
                    <strong>{{ forloop.index }}</strong>
                    <span>{{ block.settings.text }}</span>
                  </button>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      </article>
    </div>

    <button type="button" class="zoda-mission-playbook__nav" aria-label="Next playbook card" data-playbook-next>
      <span aria-hidden="true">&gt;</span>
    </button>

    <div class="zoda-mission-playbook__count" aria-live="polite" data-playbook-count>01 / 05</div>

    <div class="zoda-mission-playbook__dots" aria-label="{{ section.settings.dots_label | escape }}">
      {% assign dot_labels = 'Week 1 Foundation|Week 2 Ascend|Week 3 Dominance|Final Mission|Rulebook' | split: '|' %}
      {% for label in dot_labels %}
        <button
          type="button"
          class="zoda-mission-playbook__dot{% if forloop.first %} is-active{% endif %}"
          aria-label="Show {{ label }}"
          aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
          data-playbook-dot
          data-card-index="{{ forloop.index0 }}"
        >
          {{ forloop.index | prepend: '0' | slice: -2, 2 }}
        </button>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ZODA Mission Playbook",
  "tag": "section",
  "class": "zoda-mission-playbook-section",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Official Mission Playbook" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Three weeks. Three tiers." },
    { "type": "text", "id": "cards_label", "label": "Cards accessibility label", "default": "Official mission playbook" },
    { "type": "text", "id": "dots_label", "label": "Dots accessibility label", "default": "Playbook pages" }
  ],
  "blocks": [
    {
      "type": "week_item",
      "name": "Week item",
      "settings": [
        {
          "type": "select",
          "id": "card",
          "label": "Card",
          "options": [
            { "value": "foundation", "label": "Week 1 Foundation" },
            { "value": "ascend", "label": "Week 2 Ascend" },
            { "value": "dominance", "label": "Week 3 Dominance" }
          ],
          "default": "foundation"
        },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "textarea", "id": "detail", "label": "Detail" },
        { "type": "text", "id": "points", "label": "Points" }
      ]
    },
    {
      "type": "note_item",
      "name": "Note item",
      "settings": [
        {
          "type": "select",
          "id": "card",
          "label": "Card",
          "options": [
            { "value": "final", "label": "Final Mission" },
            { "value": "rulebook", "label": "Rulebook" }
          ],
          "default": "final"
        },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [{ "name": "ZODA Mission Playbook" }]
}
{% endschema %}
