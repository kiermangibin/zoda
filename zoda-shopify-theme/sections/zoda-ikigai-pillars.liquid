<section class="zoda-fabrics-page zoda-ikigai-page" data-zoda-page-section="ikigai-pillars">
  <div id="ikigai-pillars" class="zoda-fabrics-snap__section zoda-ikigai-pillars">
    <header class="zoda-fabrics-directory__head">
      {% if section.settings.kicker != blank %}
        <p class="zoda-fabrics-directory__kicker">{{ section.settings.kicker }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="zoda-fabrics-directory__title">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.lede != blank %}
        <p class="zoda-ikigai-pillars__lede">{{ section.settings.lede }}</p>
      {% endif %}
    </header>

    {% if section.blocks.size > 0 %}
      <div class="zoda-ikigai-pillars__grid">
        {% for block in section.blocks %}
          <article class="zoda-ikigai-pillars__card" {{ block.shopify_attributes }}>
            <div class="zoda-ikigai-pillars__media">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 900
                  | image_tag:
                    loading: 'lazy',
                    widths: '360, 540, 720, 900',
                    sizes: '(max-width: 760px) 78vw, 28vw',
                    alt: block.settings.title
                }}
              {% elsif block.settings.image_url != blank %}
                <img
                  src="{{ block.settings.image_url }}"
                  alt="{{ block.settings.title | escape }}"
                  width="900"
                  height="900"
                  loading="lazy"
                >
              {% endif %}
            </div>

            {% if block.settings.title != blank %}
              <h3 class="zoda-ikigai-pillars__title">{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.copy != blank %}
              <p class="zoda-ikigai-pillars__desc">{{ block.settings.copy }}</p>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "ZODA Ikigai Pillars",
  "tag": "section",
  "class": "zoda-ikigai-pillars-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Foundations"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Pillars of Excellence"
    },
    {
      "type": "textarea",
      "id": "lede",
      "label": "Lede",
      "default": "Built for those who rise, conquer, and push limits, we create high-performance, sustainable activewear that fuels a global movement of champions."
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Technology"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "ZODA is driven by an unwavering commitment to innovation, continuously pushing the boundaries of activewear technology."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "image_url",
          "label": "Fallback image URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZODA Ikigai Pillars"
    }
  ]
}
{% endschema %}
