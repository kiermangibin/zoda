<section id="zoda-home-mindset-{{ section.id }}" class="zoda-circuit" data-zoda-home-section="mindset">
  <article id="zoda-circuit-home-3" class="zoda-circuit__panel zoda-circuit__panel--pursuit">
    <div class="zoda-circuit__content">
      {% if section.settings.kicker != blank %}
        <p class="zoda-circuit__kicker" data-animate>{{ section.settings.kicker }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="zoda-circuit__heading" data-animate style="--zoda-delay: 90ms">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.copy != blank %}
        <p class="zoda-circuit__copy" data-animate style="--zoda-delay: 180ms">
          {{ section.settings.copy }}
        </p>
      {% endif %}

      {% if section.settings.button_label != blank and section.settings.button_url != blank %}
        <div class="zoda-circuit__actions" data-animate style="--zoda-delay: 260ms">
          <a class="zoda-circuit__button" href="{{ section.settings.button_url }}">
            {{ section.settings.button_label }}
          </a>
        </div>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="zoda-circuit__statements" aria-label="{{ section.settings.statements_label | escape }}">
        {% for block in section.blocks %}
          {% liquid
            assign delay = forloop.index0 | times: 100 | plus: 220
          %}
          <div
            class="zoda-circuit__statement"
            data-animate
            style="--zoda-delay: {{ delay }}ms"
            {{ block.shopify_attributes }}
          >
            <span>{{ block.settings.number }}</span>
            {{ block.settings.text }}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </article>
</section>

{% schema %}
{
  "name": "ZODA Mindset",
  "tag": "section",
  "class": "zoda-home-mindset-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Mindset / 03"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Relentless Pursuit"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Early starts. Extra laps. Final reps."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "statements_label",
      "label": "Statements accessibility label",
      "default": "ZODA training cues"
    }
  ],
  "blocks": [
    {
      "type": "statement",
      "name": "Statement",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Train harder."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZODA Mindset",
      "blocks": [
        {
          "type": "statement",
          "settings": {
            "number": "01",
            "text": "Train harder."
          }
        },
        {
          "type": "statement",
          "settings": {
            "number": "02",
            "text": "Recover sharper."
          }
        },
        {
          "type": "statement",
          "settings": {
            "number": "03",
            "text": "Move with intent."
          }
        }
      ]
    }
  ]
}
{% endschema %}
