<section
  id="ikigai-community"
  class="zoda-fabrics-page zoda-ikigai-page zoda-fabrics-snap__section zoda-ikigai-community"
  data-zoda-page-section="ikigai-community"
>
  <div class="zoda-ikigai-community__content">
    {% if section.settings.kicker != blank %}
      <p class="zoda-fabrics-hero__kicker">{{ section.settings.kicker }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="zoda-fabrics-hero__title">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.lede != blank %}
      <p class="zoda-ikigai-community__lede">{{ section.settings.lede }}</p>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <ul class="zoda-ikigai-community__values">
        {% for block in section.blocks %}
          {% if block.settings.value != blank %}
            <li {{ block.shopify_attributes }}>{{ block.settings.value }}</li>
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}

    {% if section.settings.button_label != blank and section.settings.button_url != blank %}
      <div class="zoda-fabrics-feature__actions">
        <a class="zoda-fabrics-feature__shop" href="{{ section.settings.button_url }}">
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>

  <div class="zoda-ikigai-community__images" aria-label="{{ section.settings.images_label | escape }}">
    <div class="zoda-ikigai-community__image-column">
      {% if section.settings.image_one != blank %}
        {{
          section.settings.image_one
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            widths: '360, 540, 720, 900',
            sizes: '(max-width: 760px) 50vw, 24vw',
            alt: section.settings.image_one_alt
        }}
      {% elsif section.settings.image_one_url != blank %}
        <img
          src="{{ section.settings.image_one_url }}"
          alt="{{ section.settings.image_one_alt | escape }}"
          width="900"
          height="900"
          loading="lazy"
        >
      {% endif %}

      {% if section.settings.image_two != blank %}
        {{
          section.settings.image_two
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            widths: '360, 540, 720, 900',
            sizes: '(max-width: 760px) 50vw, 24vw',
            alt: section.settings.image_two_alt
        }}
      {% elsif section.settings.image_two_url != blank %}
        <img
          src="{{ section.settings.image_two_url }}"
          alt="{{ section.settings.image_two_alt | escape }}"
          width="900"
          height="900"
          loading="lazy"
        >
      {% endif %}
    </div>

    {% if section.settings.image_three != blank %}
      {{
        section.settings.image_three
        | image_url: width: 900
        | image_tag:
          class: 'zoda-ikigai-community__image-tall',
          loading: 'lazy',
          widths: '360, 540, 720, 900',
          sizes: '(max-width: 760px) 50vw, 24vw',
          alt: section.settings.image_three_alt
      }}
    {% elsif section.settings.image_three_url != blank %}
      <img
        class="zoda-ikigai-community__image-tall"
        src="{{ section.settings.image_three_url }}"
        alt="{{ section.settings.image_three_alt | escape }}"
        width="900"
        height="1200"
        loading="lazy"
      >
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "ZODA Ikigai Community",
  "tag": "section",
  "class": "zoda-ikigai-community-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Community"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Together we achieve more."
    },
    {
      "type": "textarea",
      "id": "lede",
      "label": "Lede",
      "default": "ZODA is more than a brand; it's a community of champions united by a passion for pushing limits. Whether you're a pro or just starting out, ZODA welcomes you - because together, we achieve more."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Join the movement"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "images_label",
      "label": "Images accessibility label",
      "default": "ZODA community imagery"
    },
    {
      "type": "image_picker",
      "id": "image_one",
      "label": "Image one"
    },
    {
      "type": "url",
      "id": "image_one_url",
      "label": "Image one fallback URL"
    },
    {
      "type": "text",
      "id": "image_one_alt",
      "label": "Image one alt text",
      "default": "Two women stretching outdoors on a sunny day"
    },
    {
      "type": "image_picker",
      "id": "image_two",
      "label": "Image two"
    },
    {
      "type": "url",
      "id": "image_two_url",
      "label": "Image two fallback URL"
    },
    {
      "type": "text",
      "id": "image_two_alt",
      "label": "Image two alt text",
      "default": "Two people wearing ZODA compression sleeves"
    },
    {
      "type": "image_picker",
      "id": "image_three",
      "label": "Tall image"
    },
    {
      "type": "url",
      "id": "image_three_url",
      "label": "Tall image fallback URL"
    },
    {
      "type": "text",
      "id": "image_three_alt",
      "label": "Tall image alt text",
      "default": "Athlete in ZODA activewear posing against a light background"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Community value",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZODA Ikigai Community",
      "blocks": [
        { "type": "value", "settings": { "value": "Collective Strength" } },
        { "type": "value", "settings": { "value": "Open and Honest" } },
        { "type": "value", "settings": { "value": "Mutual Motivation" } },
        { "type": "value", "settings": { "value": "Milestone Moments" } },
        { "type": "value", "settings": { "value": "Unyielding Passion" } },
        { "type": "value", "settings": { "value": "Nurturing Connections" } },
        { "type": "value", "settings": { "value": "Inclusive Mindset" } },
        { "type": "value", "settings": { "value": "Together Achieving Greatness" } },
        { "type": "value", "settings": { "value": "You Are The Inspiration" } }
      ]
    }
  ]
}
{% endschema %}
