{% liquid
  assign performance_items = section.settings.performance | newline_to_br | split: '<br />'
  assign sustainability_items = section.settings.sustainability | newline_to_br | split: '<br />'
%}

<section class="zoda-fabrics-page" data-zoda-page-section="fabrics-feature">
  <div
    id="fabric-{{ section.settings.anchor_id | default: section.settings.name | handleize }}"
    class="zoda-fabrics-snap__section zoda-fabrics-feature"
    data-orientation="{{ section.settings.orientation }}"
    data-zoda-fabric-feature
  >
    <div class="zoda-fabrics-feature__media">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            loading: 'lazy',
            widths: '540, 720, 960, 1200, 1400',
            sizes: '(max-width: 760px) 100vw, 50vw',
            alt: section.settings.image_alt
        }}
      {% elsif section.settings.image_url != blank %}
        <img
          src="{{ section.settings.image_url }}"
          alt="{{ section.settings.image_alt | escape }}"
          width="1400"
          height="1400"
          loading="lazy"
        >
      {% endif %}
    </div>

    <div class="zoda-fabrics-feature__body">
      {% if section.settings.name != blank %}
        <p class="zoda-fabrics-feature__eyebrow">{{ section.settings.name }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="zoda-fabrics-feature__title">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="zoda-fabrics-feature__desc">{{ section.settings.description }}</p>
      {% endif %}

      <ul class="zoda-fabrics-feature__features" aria-label="{{ section.settings.features_label | escape }}">
        {% for block in section.blocks %}
          {% if block.type == 'technology' %}
            <li {{ block.shopify_attributes }}>
              {% if block.settings.icon_url != blank %}
                <img src="{{ block.settings.icon_url }}" alt="" width="80" height="80" loading="lazy">
              {% endif %}
              <span>{{ block.settings.label }}</span>
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      <div
        class="zoda-fabrics-feature__accordion"
        aria-label="{{ section.settings.name | escape }} fabric details"
        data-zoda-fabric-accordion
      >
        <article class="zoda-fabrics-feature__accordion-item" data-zoda-fabric-accordion-item>
          <button
            type="button"
            class="zoda-fabrics-feature__accordion-trigger"
            aria-expanded="false"
            aria-controls="fabric-{{ section.id }}-performance"
            data-zoda-fabric-accordion-trigger
          >
            <span class="zoda-fabrics-feature__accordion-index">01</span>
            <strong>{{ section.settings.performance_title }}</strong>
            <span class="zoda-fabrics-feature__accordion-label">{{ section.settings.performance_label }}</span>
            <i aria-hidden="true"></i>
          </button>
          <div id="fabric-{{ section.id }}-performance" class="zoda-fabrics-feature__accordion-panel">
            <ul class="zoda-fabrics-feature__accordion-list">
              {% for item in performance_items %}
                {% assign stripped_item = item | strip %}
                {% if stripped_item != blank %}
                  <li>{{ stripped_item }}</li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        </article>

        <article class="zoda-fabrics-feature__accordion-item" data-zoda-fabric-accordion-item>
          <button
            type="button"
            class="zoda-fabrics-feature__accordion-trigger"
            aria-expanded="false"
            aria-controls="fabric-{{ section.id }}-impact"
            data-zoda-fabric-accordion-trigger
          >
            <span class="zoda-fabrics-feature__accordion-index">02</span>
            <strong>{{ section.settings.impact_title }}</strong>
            <span class="zoda-fabrics-feature__accordion-label">{{ section.settings.impact_label }}</span>
            <i aria-hidden="true"></i>
          </button>
          <div id="fabric-{{ section.id }}-impact" class="zoda-fabrics-feature__accordion-panel">
            <ul class="zoda-fabrics-feature__accordion-list">
              {% for item in sustainability_items %}
                {% assign stripped_item = item | strip %}
                {% if stripped_item != blank %}
                  <li>{{ stripped_item }}</li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        </article>

        <article class="zoda-fabrics-feature__accordion-item" data-zoda-fabric-accordion-item>
          <button
            type="button"
            class="zoda-fabrics-feature__accordion-trigger"
            aria-expanded="false"
            aria-controls="fabric-{{ section.id }}-community"
            data-zoda-fabric-accordion-trigger
          >
            <span class="zoda-fabrics-feature__accordion-index">03</span>
            <strong>{{ section.settings.community_title }}</strong>
            <span class="zoda-fabrics-feature__accordion-label">{{ section.settings.community_label }}</span>
            <i aria-hidden="true"></i>
          </button>
          <div id="fabric-{{ section.id }}-community" class="zoda-fabrics-feature__accordion-panel">
            {% if section.settings.community != blank %}
              <p>{{ section.settings.community }}</p>
            {% endif %}
          </div>
        </article>
      </div>

      <div class="zoda-fabrics-feature__actions">
        {% if section.settings.shop_label != blank and section.settings.shop_url != blank %}
          <a class="zoda-fabrics-feature__shop" href="{{ section.settings.shop_url }}">
            {{ section.settings.shop_label }}
          </a>
        {% endif %}

        {% if section.settings.back_label != blank and section.settings.back_url != blank %}
          <a class="zoda-fabrics-feature__back" href="{{ section.settings.back_url }}">
            {{ section.settings.back_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.getElementById('fabric-{{ section.settings.anchor_id | default: section.settings.name | handleize }}');
    if (!root) return;

    root.querySelectorAll('[data-zoda-fabric-accordion-trigger]').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('[data-zoda-fabric-accordion-item]');
        const open = !item.classList.contains('is-open');
        item.classList.toggle('is-open', open);
        trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "ZODA Fabric Feature",
  "tag": "section",
  "class": "zoda-fabrics-feature-section",
  "settings": [
    { "type": "text", "id": "name", "label": "Fabric name", "default": "ZENCOT" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "zencot" },
    {
      "type": "select",
      "id": "orientation",
      "label": "Media orientation",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "url", "id": "image_url", "label": "Fallback image URL" },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "Fabric swatch" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Performance and Sustainability in Perfect Harmony" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "A premium fabric system selected for performance, comfort and responsible material choices." },
    { "type": "text", "id": "features_label", "label": "Features label", "default": "Key technologies" },
    { "type": "text", "id": "performance_title", "label": "Performance title", "default": "Engineered for performance" },
    { "type": "text", "id": "performance_label", "label": "Performance label", "default": "Performance" },
    { "type": "textarea", "id": "performance", "label": "Performance bullets", "default": "4-way stretch for full mobility\nMoisture management for hard sessions\nShape retention through repeated use" },
    { "type": "text", "id": "impact_title", "label": "Impact title", "default": "Sustainability at its core" },
    { "type": "text", "id": "impact_label", "label": "Impact label", "default": "Impact" },
    { "type": "textarea", "id": "sustainability", "label": "Sustainability bullets", "default": "Selected for responsible sourcing\nDesigned to reduce waste without compromising performance" },
    { "type": "text", "id": "community_title", "label": "Community title", "default": "Built for the community of athletes" },
    { "type": "text", "id": "community_label", "label": "Community label", "default": "Community" },
    { "type": "textarea", "id": "community", "label": "Community copy", "default": "Made for athletes who expect more from their gear." },
    { "type": "text", "id": "shop_label", "label": "Shop label", "default": "Shop fabric" },
    { "type": "url", "id": "shop_url", "label": "Shop link" },
    { "type": "text", "id": "back_label", "label": "Back label", "default": "All collections" },
    { "type": "url", "id": "back_url", "label": "Back link" }
  ],
  "blocks": [
    {
      "type": "technology",
      "name": "Technology",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "FluidMotion" },
        { "type": "url", "id": "icon_url", "label": "Icon URL" }
      ]
    }
  ],
  "presets": [
    { "name": "ZODA Fabric Feature" }
  ]
}
{% endschema %}
