{% assign video_asset = section.settings.video_asset | default: 'sustainability-video.mp4' %}

<section class="zoda-fabrics-page zoda-ikigai-page" data-zoda-page-section="ikigai-sustainability">
  <div
    id="ikigai-sustainability"
    class="zoda-fabrics-snap__section zoda-fabrics-feature"
    data-orientation="{{ section.settings.orientation }}"
  >
    <div class="zoda-fabrics-feature__media">
      {% if section.settings.video_url != blank %}
        <video
          src="{{ section.settings.video_url }}"
          aria-label="{{ section.settings.video_label | escape }}"
          autoplay
          loop
          muted
          playsinline
        ></video>
      {% else %}
        <video
          aria-label="{{ section.settings.video_label | escape }}"
          autoplay
          loop
          muted
          playsinline
        >
          <source src="{{ video_asset | asset_url }}" type="video/mp4">
        </video>
      {% endif %}
    </div>

    <div class="zoda-fabrics-feature__body">
      {% if section.settings.eyebrow != blank %}
        <p class="zoda-fabrics-feature__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="zoda-fabrics-feature__title">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.copy != blank %}
        <p class="zoda-fabrics-feature__desc">{{ section.settings.copy }}</p>
      {% endif %}

      {% if section.settings.button_label != blank and section.settings.button_url != blank %}
        <div class="zoda-fabrics-feature__actions">
          <a class="zoda-fabrics-feature__shop" href="{{ section.settings.button_url }}">
            {{ section.settings.button_label }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ZODA Sustainability",
  "tag": "section",
  "class": "zoda-ikigai-sustainability-section",
  "settings": [
    {
      "type": "select",
      "id": "orientation",
      "label": "Media orientation",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "text",
      "id": "video_asset",
      "label": "Theme asset video filename",
      "default": "sustainability-video.mp4"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "External video URL"
    },
    {
      "type": "text",
      "id": "video_label",
      "label": "Video accessibility label",
      "default": "ZODA sustainability"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Sustainability"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made with the planet in mind."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "ZODA is dedicated to protecting our planet through responsible practices at every stage of production. We source eco-friendly materials, including OCS and GOTS-certified organic cotton and GRS-certified recycled polyester. Our partners meet high social and environmental standards, ensuring safe, fair working conditions and reduced impacts. Committed to continuous improvement, ZODA actively works towards waste reduction, water conservation, and a circular economy for sustainable future."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "ZODA Ikigai Sustainability"
    }
  ]
}
{% endschema %}
