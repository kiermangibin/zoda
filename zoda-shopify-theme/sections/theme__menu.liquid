<!-- sections/theme__menu.liquid -->
{% comment %}
  Slide out menu.

  Globals:
  - enable_region: {boolean} Enable or disable the region selector.
  - enable_language: {boolean} Enable or disable the language selector.
  - type_seperator: {string} Setting to pick the type of separator between text.

  Recommendations:
  - Create a new navigation link list to set unique menu items.
  - Use this section to customize the navigation menu of your store.
{% endcomment %}
{% liquid
  assign menu = settings.header_links_mobile
  if menu == blank
    assign menu = settings.header_links_desktop
  endif
%}
{% capture menu_content %}

  {% comment %} Announcement bar {% endcomment %}
  {% for block in section.blocks %}
    {% if block.type == 'announcement' %}
      <section class="{{ block.settings.color_scheme }}">
        <div class="p-2">
          <div class="flex w-full
            {% if block.settings.layout_x_alignment == "center" %}
              justify-center
            {% elsif block.settings.layout_x_alignment == "right" %}
              justify-end
            {% endif %}">
            <span class="type--smaller rte">{{ block.settings.content }}</span>
          </div>
        </div>
      </section>
    {% endif %}
  {% endfor %}

  {% comment %} Drawer contents {% endcomment %}
  <nav 
    class="
      relative h-[inherit] overflow-y-auto overflow-x-hidden
      {{ section.settings.main_color_scheme }}
    ">

    {% comment %} Search input (clicking this opens theme__search) {% endcomment %}
    {% if section.settings.show_search %}
      <div 
        class="
          sticky top-0 w-full p-4
          {{ section.settings.main_color_scheme }}
        ">
        <div 
          class="relative">
          <label 
            class="sr-only"
            for="search-desktop">
            {{ 'labels.search' | t }}
          </label>
    
          {% comment %} Icon {% endcomment %}
          <div 
            class="pointer-events-none absolute left-2 top-0 flex h-full items-center opacity-50">
            {% render 'component__icon', 
              icon: 'search',
              size: '20' %}
          </div>
    
          {% comment %} Input field {% endcomment %}
          <input 
            class="
              color__text !w-full !px-10 focus:!shadow-[none] focus:!outline-none
              {{ section.settings.search_color_border }}
            " 
            type="text"
            tabindex="-1"
            placeholder="{{ 'actions.search_placeholder' | t }}"
            @click="openSearch()"
          />
        
        </div>
      </div>
    {% endif %}

    {% comment %} Menu {% endcomment %}
    <div 
      class="group/menu"
      x-data="{ flipbook: false }">
      {% for link in menu.links %}
        <div 
          class="
            border--t-width w-full 
            {{ section.settings.main_color_border }}
          ">
          
          {% liquid
            assign is_nested = false
            assign has_blocks = false
            if link.links != blank
              assign is_nested = true
            endif
            for block in section.blocks
              if block.type == 'collection' or 'image'
                assign link_handle = link.handle | handle
                assign menu_handle = block.settings.menu | handle
                if link_handle == menu_handle
                  assign is_nested = true
                  assign has_blocks = true
                endif
              endif
            endfor
          %}

          {% comment %} Nested menu {% endcomment %}
          {% if is_nested %}

            {% comment %} Button to open nested {% endcomment %}
            {% if has_blocks %}
              <a 
                class="
                  animation-300 flex w-full items-center justify-between px-4 no-underline hover:!opacity-100 group-hover/menu:opacity-50
                  {% if section.settings.main_color_border == '!color__border-transparent' %}
                    pt-4
                  {% else %}
                    py-4
                  {% endif %}
                "
                href="{{ link.url }}"
                @click.prevent="
                    flipbook = flipbook === '{{ link.handle | handle }}' ? false : '{{ link.handle | handle }}';
                    menu_nested = !menu_nested;
                  "
                @mouseover="
                  if (window.innerWidth > 768) { 
                    flipbook = '{{ link.handle | handle }}'; 
                    menu_nested = true; 
                  }
                ">
                <span class="{{ section.settings.main_font }}">
                  {{ link.title }}
                </span>
                {% if section.settings.show_chevrons %}
                  <span>
                    {% render 'component__icon', icon: 'chevron-right', size: '20' %} 
                  </span>
                {% endif %}
              </a>
            {% else %}
              <button 
                class="
                  animation-300 flex w-full items-center justify-between px-4 hover:!opacity-100 group-hover/menu:opacity-50
                  {% if section.settings.main_color_border == '!color__border-transparent' %}
                    pt-4
                  {% else %}
                    py-4
                  {% endif %}
                "
                type="button" 
                @click="
                  flipbook = flipbook === '{{ link.handle | handle }}' ? false : '{{ link.handle | handle }}';
                  menu_nested = !menu_nested;
                "
                @mouseover="
                  if (window.innerWidth > 768) { 
                    flipbook = '{{ link.handle | handle }}'; 
                    menu_nested = true; 
                  }
                ">
                <span class="{{ section.settings.main_font }}">
                  {{ link.title }}
                </span>
                {% if section.settings.show_chevrons %}
                  <span>
                    {% render 'component__icon', icon: 'chevron-right', size: '20' %} 
                  </span>
                {% endif %}
              </button>
            {% endif %}

            {% comment %} Secondary slide out {% endcomment %}
            <div 
              class="
                color__border-divider-1 border--l-width group/nested fixed bottom-0 top-0 z-20 h-full w-full flex-col items-stretch overflow-y-scroll md:left-[28rem] md:flex md:max-w-[calc(100vw-28rem)]
                {{ section.settings.main_color_scheme }}
              "
              @click.outside="flipbook = false; menu_nested = false;"
              x-show="flipbook == '{{ link.handle | handle }}'"
              {% if settings.enable_animations %}
                x-transition:enter="animation-300"
                x-transition:enter-start="opacity-0"
                x-transition:enter-end="opacity-100"
                x-transition:leave="animation-300"
                x-transition:leave-start="opacity-100"
                x-transition:leave-end="opacity-0"
              {% endif %}
              x-cloak>

              {% comment %} Back button {% endcomment %}
              <div 
                class="
                  sticky top-0 z-10 flex p-4 md:hidden
                  {{ section.settings.main_color_scheme }}
                ">
                <button 
                  class=" btn btn--smaller btn--plain"
                  title="{{ 'actions.back' | t }}"
                  @click="flipbook = false; menu_nested = false;">
                  {% render 'component__icon', icon: 'chevron-left', size: '14' %} 
                  <span class="ml-1">
                    {{ 'actions.back' | t }}
                  </span>
                </button>
              </div>

              {% comment %} Nested links {% endcomment %}
              {% if link.links != blank %}
                <div>
                  {% for child_link in link.links %}
                    {% if child_link.links != blank %}
                      <div 
                        class="
                          border--t-width
                          {{ section.settings.main_color_border }}
                          {% if section.settings.main_color_border == '!color__border-transparent' %}
                            pb-4
                          {% endif %}
                        ">
                        <a 
                          class="
                            type__body animation-300 flex w-full items-center justify-between px-4 pt-4 no-underline opacity-50 hover:!opacity-100 group-hover/nested:opacity-50
                            {{ section.settings.main_color_scheme }}
                          "
                          href="{{ child_link.url }}">
                          {{ child_link.title }}
                        </a>
                        {% for grandchild_link in child_link.links %}
                          <a 
                            class="
                              animation-300 flex w-full items-center justify-between px-4 no-underline hover:!opacity-100 group-hover/nested:opacity-50
                              {{ section.settings.main_font }}
                              {% if section.settings.main_color_border == '!color__border-transparent' %}
                                pt-4
                              {% else %}
                                py-4
                              {% endif %}
                            "
                            href="{{ grandchild_link.url }}">
                            {{ grandchild_link.title }}
                          </a>
                        {% endfor %}
                      </div>
                    {% else %}
                      <a 
                        class="
                          border--t-width animation-300 flex w-full items-center justify-between px-4 no-underline hover:!opacity-100 group-hover/nested:opacity-50
                          {% if section.settings.main_color_border == '!color__border-transparent' %}
                                pt-4
                              {% else %}
                                py-4
                              {% endif %}
                          {{ section.settings.main_font }}
                          {{ section.settings.main_color_border }}
                        "
                        href="{{ child_link.url }}">
                        {{ child_link.title }}
                      </a>
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}

              {% comment %} Featured blocks {% endcomment %}
              {% for block in section.blocks %}
                {% liquid
                  assign link_handle = link.handle | handle
                  assign menu_handle = block.settings.menu | handle
                %}
                {% if link_handle == menu_handle %}

                  {% comment %} Collection block {% endcomment %}
                  {% if block.type == 'collection' %}
                    <div
                      class="
                        animation-300 grid
                        {% unless settings.product_card_border_style == 'thumbnail' %}
                          p-4
                        {% endunless %}
                      "
                      style="
                        gap: {{ settings.gap_size }}px;
                        {% unless settings.gap_size == 1 %}
                          padding: {{ settings.gap_size }}px;
                        {% endunless %}
                      ">
                        {% for product in collections[block.settings.collection].products limit: 20 %}
                          {% render 'component__product-grid', product: product %}
                        {% endfor %}
                    </div>
                  {% endif %}

                  {% comment %} Image block {% endcomment %}
                  {% if block.type == 'image' %}
                    <a 
                      class="h-full"
                      href="{{ link.url }}">
                      {% if block.settings.image == blank %}
                        <div class="color__bg-shade-2 h-full w-full">
                          {{ 'image' | placeholder_svg_tag: 'w-full h-full' }}
                        </div>
                      {% else %}
                        {% render 'component__image', 
                          image: block.settings.image,
                          max_width: 2000,
                          container_class: 'w-full h-full',
                          crop_class: 'object-cover',
                          lazy_load: true,
                          enable_2x: true
                        %}
                      {% endif %}
                    </a>
                  {% endif %}
                  
                {% endif %}
              {% endfor %}
              
            </div>

          {% comment %} Single link {% endcomment %}
          {% else %}
            <a 
              class="
                animation-300 flex w-full items-center justify-between px-4 no-underline hover:!opacity-100 group-hover/menu:opacity-50
                {% if link.child_active %}!underline{% endif %}
                {% if link.active %}!underline{% endif %}
                {% if section.settings.main_color_border == '!color__border-transparent' %}
                  pt-4
                {% else %}
                  py-4
                {% endif %}
              "
              href="{{ link.url }}">
              <span class="{{ section.settings.main_font }}">
                {{ link.title }}
              </span>
            </a>
          {% endif %}

        </div>
      {% endfor %}
    </div>
    
    {% comment %} Promo block {% endcomment %}
    {% for block in section.blocks %}
      {% if block.type == 'content' %}
        <div class="p-4">
          {% render 'component__content-item',
            heading: block.settings.heading,
            content: block.settings.content,
            button_label: block.settings.button_label,
            url: block.settings.url,
            image: block.settings.image,
            show_image_as_background: block.settings.show_image_as_background,
            video: block.settings.video,
            enable_autoplay: block.settings.enable_autoplay,
            enable_mute_toggle: block.settings.enable_mute_toggle,
            enable_loop: block.settings.enable_loop,
            enable_scroll_motion: 'false',
            color_scheme: block.settings.color_scheme,
            color_border: block.settings.color_border,
            color_button: block.settings.color_button,
            color_text: block.settings.color_text,
            enable_gradient: block.settings.enable_gradient,
            spacing_minimum_height: block.settings.spacing_minimum_height,
            spacing_maximum_height: 300,
            enable_padding: block.settings.enable_padding,
            layout_y_alignment: block.settings.layout_y_alignment,
            layout_x_alignment: block.settings.layout_x_alignment,
            text_position: block.settings.text_position
          %}
        </div>
      {% endif %}
    {% endfor %}
    
  </nav>
  
  {% comment %} Sticky footer {% endcomment %}
  <aside 
    class="
      border--t-width bottom-0 flex w-full flex-col gap-4 py-4
      {{ section.settings.bottom_color_border }}
      {{ section.settings.bottom_color_scheme }}
    "
    {% if settings.enable_animations %}
      x-transition:enter="animation-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="animation-300"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
    {% endif %}>
    <div class="flex w-full flex-wrap items-start gap-2 px-4">

      {% comment %} Sub links {% endcomment %}
      {% for link in settings.header_links_submenu.links %}
        <a 
          class="type--small no-underline"
          href="{{ link.url }}">
          {{ link.title }}
        </a>
      {% endfor %}

      {% comment %} Login/account {% endcomment %}
      {% if shop.customer_accounts_enabled %} 
        <a 
          class="type--small no-underline"
          href="{{ routes.account_url }}">
          {% if customer %}
            {{ 'labels.account' | t }}, 
            {{ customer.name }}
          {% else %}
            {{ 'actions.log_in' | t }}
          {% endif %}
        </a>
      {% endif %}

      {% comment %} Audio settings {% endcomment %}
      {% if settings.enable_audio %}
        <button 
          class="type--small flex items-center no-underline" 
          @click="audio_overlay = true;">
          {% render 'component__icon', icon: 'volume', size: '14', class: 'mr-1' %}
          <span x-show="enable_audio == false">{{ 'labels.audio_off' | t }}</span>
          <span x-show="enable_audio == true">{{ 'labels.audio_on' | t }}</span>
        </button>
      {% endif %}

      {% comment %} Localization {% endcomment %}
      {% if settings.enable_region or settings.enable_language %}
        <button 
          class="type--small flex items-center gap-2" 
          @click="localization_overlay = true;">
          <span 
            class="fi type--smaller"
            style="background-image: url(https://flagicons.lipis.dev/flags/4x3/{{ localization.country.iso_code | downcase }}.svg)">
          </span>
          <span class="hover:underline">
            {{ localization.country.currency.symbol }} {{ localization.country.currency.iso_code }}
            {% if settings.type_seperator == 'dot' %}·{% else %}|{% endif %}
            {{ localization.language.iso_code | upcase }}
          </span> 
        </button>
      {% endif %}

    </div>

  </aside>

{% endcapture %}
{% assign label = 'labels.menu' | t %}
<section
  id="{{ section.id }}"
>
  {% render 'component__dragdrawer',
    drawer_id: 'menu_drawer',
    mobile_pos: 'bottom',
    desktop_pos: 'left',
    enable_full_height: true,
    content: menu_content,
    top_bar_label: label
  %}
</section>
{% schema %}
{
  "name": "t:sections.theme_menu.name",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:general.paragraphs.menu_navigation.content"
    },
    {
      "type": "header",
      "content": "t:general.headers.top_bar.content"
    },
    {
      "type": "select",
      "id": "top_color_scheme",
      "label": "t:general.settings.color_scheme.label",
      "options": [
        {
          "value": "color__bg-body color__text",
          "label": "t:general.settings.color_scheme.body.label"
        },
        {
          "value": "color__bg-neutral color__text",
          "label": "t:general.settings.color_scheme.neutral.label"
        },
        {
          "value": "color__bg-overlay-1 color__text",
          "label": "t:general.settings.color_scheme.accent_1.label"
        },
        {
          "value": "color__bg-overlay-2 color__text",
          "label": "t:general.settings.color_scheme.accent_2.label"
        },
        {
          "value": "color__bg-overlay-3 color__text",
          "label": "t:general.settings.color_scheme.accent_3.label"
        },
        {
          "value": "color__bg-shade-1 color__text",
          "label": "t:general.settings.color_scheme.shade_1.label"
        },
        {
          "value": "color__bg-shade-2 color__text",
          "label": "t:general.settings.color_scheme.shade_2.label"
        },
        {
          "value": "color__bg-shade-3 color__text",
          "label": "t:general.settings.color_scheme.shade_3.label"
        },
        {
          "value": "color__bg-primary color__primary",
          "label": "t:general.settings.color_scheme.primary.label"
        },
        {
          "value": "color__bg-secondary color__secondary",
          "label": "t:general.settings.color_scheme.secondary.label"
        },
        {
          "value": "color__bg-tertiary color__tertiary",
          "label": "t:general.settings.color_scheme.tertiary.label"
        }
      ],
      "default": "color__bg-body color__text"
    },
    {
      "type": "select",
      "id": "top_color_border",
      "label": "t:general.settings.color_border.label",
      "options": [
        {
          "value": "color__border-divider-1",
          "label": "t:general.settings.color_border.subtle.label"
        },
        {
          "value": "color__border-selected-1",
          "label": "t:general.settings.color_border.strong.label"
        },
        {
          "value": "!color__border-transparent",
          "label": "t:general.settings.color_border.none.label"
        }
      ],
      "default": "color__border-divider-1"
    },
    {
      "type": "header",
      "content": "t:general.headers.main_section.content"
    },
    {
      "type": "select",
      "id": "main_color_scheme",
      "label": "t:general.settings.color_scheme.label",
      "options": [
        {
          "value": "color__bg-body color__text",
          "label": "t:general.settings.color_scheme.body.label"
        },
        {
          "value": "color__bg-neutral color__text",
          "label": "t:general.settings.color_scheme.neutral.label"
        },
        {
          "value": "color__bg-overlay-1 color__text",
          "label": "t:general.settings.color_scheme.accent_1.label"
        },
        {
          "value": "color__bg-overlay-2 color__text",
          "label": "t:general.settings.color_scheme.accent_2.label"
        },
        {
          "value": "color__bg-overlay-3 color__text",
          "label": "t:general.settings.color_scheme.accent_3.label"
        },
        {
          "value": "color__bg-shade-1 color__text",
          "label": "t:general.settings.color_scheme.shade_1.label"
        },
        {
          "value": "color__bg-shade-2 color__text",
          "label": "t:general.settings.color_scheme.shade_2.label"
        },
        {
          "value": "color__bg-shade-3 color__text",
          "label": "t:general.settings.color_scheme.shade_3.label"
        },
        {
          "value": "color__bg-primary color__primary",
          "label": "t:general.settings.color_scheme.primary.label"
        },
        {
          "value": "color__bg-secondary color__secondary",
          "label": "t:general.settings.color_scheme.secondary.label"
        },
        {
          "value": "color__bg-tertiary color__tertiary",
          "label": "t:general.settings.color_scheme.tertiary.label"
        }
      ],
      "default": "color__bg-body color__text"
    },
    {
      "type": "select",
      "id": "main_color_border",
      "label": "t:general.settings.color_border.label",
      "options": [
        {
          "value": "color__border-divider-1",
          "label": "t:general.settings.color_border.subtle.label"
        },
        {
          "value": "color__border-selected-1",
          "label": "t:general.settings.color_border.strong.label"
        },
        {
          "value": "!color__border-transparent",
          "label": "t:general.settings.color_border.none.label"
        }
      ],
      "default": "color__border-divider-1"
    },
    {
      "type": "select",
      "id": "main_font",
      "label": "t:general.settings.font_family.label",
      "options": [
        {
          "value": "type__body",
          "label": "t:general.settings.font_family.standard.label"
        },
        {
          "value": "type__heading type__heading-1 !leading-normal",
          "label": "t:general.settings.font_family.heading.label"
        },
        {
          "value": "type__nav",
          "label": "t:general.settings.font_family.navigation.label"
        }
      ],
      "default": "type__body"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "t:general.settings.show_search_button.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_chevrons",
      "label": "t:general.settings.show_chevrons.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:general.headers.bottom_section.content"
    },
    {
      "type": "select",
      "id": "bottom_color_scheme",
      "label": "t:general.settings.color_scheme.label",
      "options": [
        {
          "value": "color__bg-body color__text",
          "label": "t:general.settings.color_scheme.body.label"
        },
        {
          "value": "color__bg-neutral color__text",
          "label": "t:general.settings.color_scheme.neutral.label"
        },
        {
          "value": "color__bg-overlay-1 color__text",
          "label": "t:general.settings.color_scheme.accent_1.label"
        },
        {
          "value": "color__bg-overlay-2 color__text",
          "label": "t:general.settings.color_scheme.accent_2.label"
        },
        {
          "value": "color__bg-overlay-3 color__text",
          "label": "t:general.settings.color_scheme.accent_3.label"
        },
        {
          "value": "color__bg-shade-1 color__text",
          "label": "t:general.settings.color_scheme.shade_1.label"
        },
        {
          "value": "color__bg-shade-2 color__text",
          "label": "t:general.settings.color_scheme.shade_2.label"
        },
        {
          "value": "color__bg-shade-3 color__text",
          "label": "t:general.settings.color_scheme.shade_3.label"
        },
        {
          "value": "color__bg-primary color__primary",
          "label": "t:general.settings.color_scheme.primary.label"
        },
        {
          "value": "color__bg-secondary color__secondary",
          "label": "t:general.settings.color_scheme.secondary.label"
        },
        {
          "value": "color__bg-tertiary color__tertiary",
          "label": "t:general.settings.color_scheme.tertiary.label"
        }
      ],
      "default": "color__bg-overlay-1 color__text"
    },
    {
      "type": "select",
      "id": "bottom_color_border",
      "label": "t:general.settings.color_border.label",
      "options": [
        {
          "value": "color__border-divider-1",
          "label": "t:general.settings.color_border.subtle.label"
        },
        {
          "value": "color__border-selected-1",
          "label": "t:general.settings.color_border.strong.label"
        },
        {
          "value": "!color__border-transparent",
          "label": "t:general.settings.color_border.none.label"
        }
      ],
      "default": "color__border-divider-1"
    }
  ],
  "blocks": [
    {
      "type": "content",
      "name": "t:sections.theme_menu.blocks.content.name",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "t:general.paragraphs.menu_content.content"
        },
        {
          "type": "header",
          "content": "t:general.headers.content.content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:general.settings.heading.label",
          "default": "Block heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:general.settings.content.label",
          "default": "<p>Describe a product, make announcements, or inform customers about a promotion.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:general.settings.button_label.label",
          "default": "Button"
        },
        {
          "type": "url",
          "id": "url",
          "label": "t:general.settings.url.label",
          "info": "t:general.settings.url.info",
          "default": "/collections/all"
        },
        {
