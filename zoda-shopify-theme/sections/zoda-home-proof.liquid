{% liquid
  assign panel_id = section.settings.panel_id | default: 'zoda-circuit-home-8'
  assign modifier_class = section.settings.modifier_class
%}

<section id="zoda-home-proof-{{ section.id }}" class="zoda-circuit" data-zoda-home-section="{{ section.settings.section_key | default: 'proof' }}">
  <article id="{{ panel_id }}" class="zoda-circuit__panel zoda-circuit__panel--proof{% if modifier_class != blank %} {{ modifier_class }}{% endif %}">
    <div class="zoda-circuit__intro-row">
      <div>
        {% if section.settings.kicker != blank %}
          <p class="zoda-circuit__kicker" data-animate>{{ section.settings.kicker }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="zoda-circuit__heading" data-animate style="--zoda-delay: 90ms">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
      </div>

      {% if section.settings.copy != blank %}
        <p class="zoda-circuit__copy" data-animate style="--zoda-delay: 180ms">
          {{ section.settings.copy }}
        </p>
      {% endif %}
    </div>

    <div class="zoda-circuit__proof-grid">
      {% for block in section.blocks %}
        {% liquid
          assign item_tag = 'div'
          if block.settings.url != blank
            assign item_tag = 'a'
          endif
        %}

        <{{ item_tag }}
          class="zoda-circuit__proof-item"
          {% if block.settings.url != blank %}
            href="{{ block.settings.url }}"
            {% if block.settings.open_new_tab %}
              target="_blank"
              rel="noopener"
            {% endif %}
          {% endif %}
          data-animate
          style="--zoda-delay: {{ forloop.index | times: 100 | plus: 120 }}ms"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.image_asset != blank %}
            <figure class="zoda-circuit__proof-media">
              <img
                src="{{ block.settings.image_asset | asset_url }}"
                alt="{{ block.settings.image_alt | escape }}"
                loading="lazy"
                width="900"
                height="900"
              >
            </figure>
            <div class="zoda-circuit__proof-copybox">
          {% endif %}

          {% if block.settings.meta != blank %}
            <span>{{ block.settings.meta }}</span>
          {% endif %}

          {% if block.settings.title != blank %}
            <strong>{{ block.settings.title }}</strong>
          {% endif %}

          {% if block.settings.copy != blank %}
            <p>{{ block.settings.copy }}</p>
          {% endif %}

          {% if block.settings.image_asset != blank %}
            </div>
          {% endif %}
        </{{ item_tag }}>
      {% endfor %}
    </div>
  </article>
</section>

{% schema %}
{
  "name": "ZODA Proof Panel",
  "tag": "section",
  "class": "zoda-home-proof-section",
  "settings": [
    {
      "type": "text",
      "id": "section_key",
      "label": "Section key",
      "default": "proof"
    },
    {
      "type": "text",
      "id": "panel_id",
      "label": "Source panel ID",
      "default": "zoda-circuit-home-8"
    },
    {
      "type": "text",
      "id": "modifier_class",
      "label": "Extra panel class"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "What's Coming / 10"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Exciting projects."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Upcoming drops, community moments, and access-led projects built for athletes moving with purpose."
    }
  ],
  "blocks": [
    {
      "type": "proof_item",
      "name": "Proof item",
      "settings": [
        {
          "type": "text",
          "id": "meta",
          "label": "Meta",
          "default": "01 / Drops"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Training releases"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "New kits, fabric updates, and session-ready pieces built around how athletes actually move."
        },
        {
          "type": "text",
          "id": "image_asset",
          "label": "Image asset filename"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZODA Proof Panel"
    }
  ]
}
{% endschema %}
