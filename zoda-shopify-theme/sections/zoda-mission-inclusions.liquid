{% liquid
  assign bag_image = section.settings.image_asset | default: 'Backpack.png'
%}

<section
  id="mission-inclusions"
  class="zoda-fabrics-page zoda-mission-page zoda-fabrics-snap__section zoda-mission-section zoda-mission-inclusions"
  data-zoda-page-section="mission-inclusions"
>
  <div class="zoda-mission-inclusions__grid" aria-label="{{ section.settings.aria_label | escape }}">
    <div class="zoda-mission-blueprint-board">
      <div class="zoda-mission-blueprint-board__head">
        {% if section.settings.kicker != blank %}
          <span>{{ section.settings.kicker }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <strong>{{ section.settings.heading }}</strong>
        {% endif %}
      </div>

      <div class="zoda-mission-blueprint-board__specs">
        <section class="zoda-mission-blueprint-group">
          <h3>{{ section.settings.main_group_title }}</h3>
          <ul>
            {% for block in section.blocks %}
              {% if block.settings.group == 'main' and block.settings.item != blank %}
                <li {{ block.shopify_attributes }}>
                  <span>{{ block.settings.number | default: forloop.index | prepend: '0' | slice: -2, 2 }}.</span>
                  <strong>{{ block.settings.item }}</strong>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </section>

        <section class="zoda-mission-blueprint-group">
          <h3>{{ section.settings.pockets_group_title }}</h3>
          <ul>
            {% for block in section.blocks %}
              {% if block.settings.group == 'pockets' and block.settings.item != blank %}
                <li {{ block.shopify_attributes }}>
                  <span>{{ block.settings.number | default: forloop.index | prepend: '0' | slice: -2, 2 }}.</span>
                  <strong>{{ block.settings.item }}</strong>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </section>
      </div>

      <div class="zoda-mission-blueprint-board__image" aria-label="{{ section.settings.image_label | escape }}">
        <img
          src="{{ bag_image | asset_url }}"
          alt="{{ section.settings.image_alt | escape }}"
          loading="lazy"
          width="1200"
          height="1200"
        >
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ZODA Mission Inclusions",
  "tag": "section",
  "class": "zoda-mission-inclusions-section",
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "Blueprint aria label",
      "default": "Mission bag blueprint"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "The Mission Blueprint"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The ZODA Mission Bag"
    },
    {
      "type": "text",
      "id": "main_group_title",
      "label": "Main group title",
      "default": "Main Compartments"
    },
    {
      "type": "text",
      "id": "pockets_group_title",
      "label": "Pockets group title",
      "default": "Pockets & Access"
    },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Bag image asset filename",
      "default": "Backpack.png"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Bag image alt text",
      "default": "ZODA Mission backpack"
    },
    {
      "type": "text",
      "id": "image_label",
      "label": "Bag image aria label",
      "default": "Mission bag image"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Blueprint item",
      "settings": [
        {
          "type": "select",
          "id": "group",
          "label": "Group",
          "default": "main",
          "options": [
            { "value": "main", "label": "Main Compartments" },
            { "value": "pockets", "label": "Pockets & Access" }
          ]
        },
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "item",
          "label": "Item"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZODA Mission Inclusions",
      "blocks": [
        { "type": "item", "settings": { "group": "main", "number": "01", "item": "Full-Access Clamshell" } },
        { "type": "item", "settings": { "group": "main", "number": "02", "item": "Compressed Expansion Vault" } },
        { "type": "item", "settings": { "group": "main", "number": "03", "item": "Direct-Access Internal Portal (QAP)" } },
        { "type": "item", "settings": { "group": "main", "number": "04", "item": "LaptopVault Compartment" } },
        { "type": "item", "settings": { "group": "main", "number": "05", "item": "VentVault Shoe Garage" } },
        { "type": "item", "settings": { "group": "main", "number": "06", "item": "ShadeVault Hardshell" } },
        { "type": "item", "settings": { "group": "main", "number": "07", "item": "QuickDivide Rails" } },
        { "type": "item", "settings": { "group": "pockets", "number": "08", "item": "ShieldPocket Passport" } },
        { "type": "item", "settings": { "group": "pockets", "number": "09", "item": "QuickDraw Phone Pocket" } },
        { "type": "item", "settings": { "group": "pockets", "number": "10", "item": "HeatLock Meal Sleeve" } },
        { "type": "item", "settings": { "group": "pockets", "number": "11", "item": "LockHold 1.5L Bottle Holster" } },
        { "type": "item", "settings": { "group": "pockets", "number": "12", "item": "StormSleeve Umbrella Pocket" } },
        { "type": "item", "settings": { "group": "pockets", "number": "13", "item": "MagEdge Twin Pockets" } },
        { "type": "item", "settings": { "group": "pockets", "number": "14", "item": "SideLift Laptop Access" } }
      ]
    }
  ]
}
{% endschema %}
