<section class="zoda-fabrics-page zoda-ikigai-page" data-zoda-page-section="ikigai-technology">
  <div
    id="ikigai-technology"
    class="zoda-fabrics-snap__section zoda-fabrics-feature"
    data-orientation="{{ section.settings.orientation }}"
    data-zoda-ikigai-technology
  >
    <div
      class="zoda-fabrics-feature__media zoda-ikigai-technology-media-grid"
      aria-label="{{ section.settings.media_label | escape }}"
    >
      {% if section.settings.hero_image != blank %}
        {{
          section.settings.hero_image
          | image_url: width: 1400
          | image_tag:
            class: 'zoda-ikigai-technology-media-grid__hero',
            loading: 'lazy',
            widths: '540, 720, 960, 1200, 1400',
            sizes: '(max-width: 760px) 100vw, 50vw',
            alt: section.settings.hero_alt
        }}
      {% elsif section.settings.hero_asset != blank %}
        <img
          class="zoda-ikigai-technology-media-grid__hero"
          src="{{ section.settings.hero_asset | asset_url }}"
          alt="{{ section.settings.hero_alt | escape }}"
          width="1400"
          height="1400"
          loading="lazy"
        >
      {% endif %}

      {% if section.settings.secondary_image != blank %}
        {{
          section.settings.secondary_image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            widths: '360, 540, 720, 900',
            sizes: '(max-width: 760px) 50vw, 24vw',
            alt: section.settings.secondary_alt
        }}
      {% elsif section.settings.secondary_asset != blank %}
        <img
          src="{{ section.settings.secondary_asset | asset_url }}"
          alt="{{ section.settings.secondary_alt | escape }}"
          width="900"
          height="900"
          loading="lazy"
        >
      {% endif %}

      {% if section.settings.tertiary_image != blank %}
        {{
          section.settings.tertiary_image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            widths: '360, 540, 720, 900',
            sizes: '(max-width: 760px) 50vw, 24vw',
            alt: section.settings.tertiary_alt
        }}
      {% elsif section.settings.tertiary_asset != blank %}
        <img
          src="{{ section.settings.tertiary_asset | asset_url }}"
          alt="{{ section.settings.tertiary_alt | escape }}"
          width="900"
          height="900"
          loading="lazy"
        >
      {% endif %}
    </div>

    <div class="zoda-fabrics-feature__body">
      {% if section.settings.eyebrow != blank %}
        <p class="zoda-fabrics-feature__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="zoda-fabrics-feature__title">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.copy != blank %}
        <p class="zoda-fabrics-feature__desc">{{ section.settings.copy }}</p>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div
          class="zoda-fabrics-craft__accordion zoda-ikigai-tech__accordion"
          aria-label="{{ section.settings.accordion_label | escape }}"
          data-zoda-ikigai-tech-accordion
        >
          {% for block in section.blocks %}
            <details
              class="zoda-fabrics-craft__item{% if forloop.first %} is-open{% endif %}"
              {% if forloop.first %}
                open
              {% endif %}
              data-zoda-ikigai-tech-item
              {{ block.shopify_attributes }}
            >
              <summary class="zoda-fabrics-craft__trigger" data-zoda-ikigai-tech-trigger>
                <span>{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                <strong>{{ block.settings.title }}</strong>
              </summary>
              <div class="zoda-fabrics-craft__panel">
                <p>{{ block.settings.copy }}</p>
              </div>
            </details>
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.button_label != blank and section.settings.button_url != blank %}
        <div class="zoda-fabrics-feature__actions">
          <a class="zoda-fabrics-feature__shop" href="{{ section.settings.button_url }}">
            {{ section.settings.button_label }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.getElementById('ikigai-technology');
    if (!root) return;

    root.querySelectorAll('[data-zoda-ikigai-tech-item]').forEach((item) => {
      item.addEventListener('toggle', () => {
        item.classList.toggle('is-open', item.open);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "ZODA Ikigai Technology",
  "tag": "section",
  "class": "zoda-ikigai-technology-section",
  "settings": [
    {
      "type": "select",
      "id": "orientation",
      "label": "Media orientation",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    { "type": "text", "id": "media_label", "label": "Media label", "default": "ZODA technology imagery" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "hero_asset", "label": "Hero asset filename", "default": "technology-runners.jpg" },
    { "type": "text", "id": "hero_alt", "label": "Hero image alt", "default": "Three runners on a wooden pathway with a city skyline in the background" },
    { "type": "image_picker", "id": "secondary_image", "label": "Secondary image" },
    { "type": "text", "id": "secondary_asset", "label": "Secondary asset filename", "default": "technology-pocket.avif" },
    { "type": "text", "id": "secondary_alt", "label": "Secondary image alt", "default": "Close-up of a teal performance wear pocket" },
    { "type": "image_picker", "id": "tertiary_image", "label": "Tertiary image" },
    { "type": "text", "id": "tertiary_asset", "label": "Tertiary asset filename", "default": "technology-buttons.avif" },
    { "type": "text", "id": "tertiary_alt", "label": "Tertiary image alt", "default": "Close-up of ZODA logo buttons on technical fabric" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Technology" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Engineered to outperform." },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "We lead in activewear innovation, crafting high-performance garments with cutting-edge fabrics like regenerated nylons and recycled cotton, certified by GRS and BCI. Engineered for breathability, moisture-wicking, and durability, our materials ensure peak performance."
    },
    { "type": "text", "id": "accordion_label", "label": "Accordion label", "default": "ZODA technology principles" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "See behind the force" },
    { "type": "url", "id": "button_url", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "principle",
      "name": "Principle",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "High-Quality Fabrics" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "We utilize only the finest fabrics, meticulously chosen for their exceptional performance, durability and sustainable sourcing." }
      ]
    }
  ],
  "presets": [
    { "name": "ZODA Ikigai Technology" }
  ]
}
{% endschema %}
