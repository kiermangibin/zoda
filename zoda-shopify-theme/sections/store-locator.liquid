<!-- sections/store-locator.liquid -->
{% comment %}
  View store locations with details for each.

  Globals:
  - layout_horizontal: {string} Class string to set horizontal margin.
  - mapbox_api_key: {string} Mapbox API key
  - color_background_primary: {string} Primary color for map markers
  - color_background_body: {string} Border color for map markers
{% endcomment %}

<section
  id="{{ section.id }}"
  class="
    animation-1000
    {{ section.settings.visibility }}
    {{ section.settings.color_border }}
    {{ section.settings.style_border }}
    {% unless section.settings.enable_color_fade %}
      {{ section.settings.color_text }}
      {% unless section.settings.color_scheme == 'custom' %}
        {{ section.settings.color_scheme }}
      {% endunless %}
    {% endunless %}
  "
  {% if section.settings.color_scheme == 'custom' %}
    {% unless section.settings.enable_color_fade %}
      style="        background:{{ section.settings.color_background }};"
    {% endunless %}
  {% endif %}
  {% if section.settings.enable_color_fade %}
    :class="`${body_background_color} ${body_text_color}`"
    :style="{ background: body_background_color }"
    x-intersect.margin.-50%="
      body_background_color = '{% if section.settings.color_scheme == 'custom' %}{{ section.settings.color_background }}{% else %}{{ section.settings.color_scheme }}{% endif %}';
      body_text_color = '{{ section.settings.color_text }}';
    "
  {% endif %}
  x-data="
    {
      activeAccordion: 0,
      map: null,
      initMap(){
        // Check if Mapbox assets are already loaded
        if (!window.mapboxgl) {
          // Create script element for Mapbox JS
          const script = document.createElement('script');
          script.src = 'https://api.mapbox.com/mapbox-gl-js/v2.4.1/mapbox-gl.js';
          script.onload = () => {
            const link = document.createElement('link');
            link.href = 'https://api.mapbox.com/mapbox-gl-js/v2.4.1/mapbox-gl.css';
            link.rel = 'stylesheet';
            document.head.appendChild(link);
            this.initializeMap();
          };
          document.head.appendChild(script);
        }

        // Assets are already loaded, initialize the map directly
        else {
          this.initializeMap();
        }
      },
      initializeMap(){
        mapboxgl.accessToken = '{{ settings.mapbox_api_key }}';
        this.map = new mapboxgl.Map({
          container: 'map',
          style: '{{ section.settings.map_style }}',
          center: [{{ section.blocks.first.settings.longitude }}, {{ section.blocks.first.settings.latitude }}],
          zoom: 5
        });
        this.map.addControl(new mapboxgl.NavigationControl());
        this.map.scrollZoom.disable();
        {% for block in section.blocks %}
          var markerElement = document.createElement('div');
          markerElement.className = 'mapboxgl-marker';
          markerElement.style.width = '14px';
          markerElement.style.height = '14px';
          markerElement.style.borderRadius = '50%';
          markerElement.style.backgroundColor = '{{ settings.color_background_primary }}';
          markerElement.style.borderColor = '{{ settings.color_background_body }}';
          markerElement.style.borderWidth = '2px';
          var marker = new mapboxgl.Marker({ element: markerElement })
            .setLngLat([{{ block.settings.longitude }}, {{ block.settings.latitude }}])
            .addTo(this.map);
          marker.getElement().addEventListener('click', () => {
            activeAccordion = {{ forloop.index0 }}
          });
        {% endfor %}
      },
      flyToStore(longitude, latitude){
        this.map.flyTo({
          center: [longitude, latitude],
          speed: 2,
          zoom: 12
        });
      }
    }
  "
  x-init="initMap()"
>
  <div
    class="
      {% if section.settings.enable_margin %}
        {{ settings.x_margin }}
      {% endif %}
    "
    style="
      padding-top:{{ section.settings.spacing_top }}px;
      padding-bottom:{{ section.settings.spacing_bottom }}px;
    "
  >
    <div
      class="
        flex flex-wrap items-start justify-between
        {% if section.settings.enable_split %}
          flex-row
        {% else %}
          flex-col
        {% endif %}
      "
    >
      {% comment %} Header {% endcomment %}
      <div
        class="
          flex w-full flex-col
          {% if section.settings.enable_split %}md:w-1/3 md:pr-4 md:sticky md:top-4{% endif %}
          {% unless section.settings.enable_margin %}
            px-4
          {% endunless %}
        "
      >
        {% render 'component__section-header' %}
      </div>

      {% comment %} Content {% endcomment %}
      <div
        class="
          relative w-full
          {% if section.settings.enable_split %}md:w-2/3{% endif %}
        "
      >
        {% if section.settings.enable_dynamic_map %}
          <div
            id="map"
            class="color__bg-overlay-1 border--radius mobile-border--b0-radius color__border-divider-1 border--width !sticky top-0 h-96 w-full flex-1 md:h-[500px] "
          ></div>
        {% else %}
          {{
            section.settings.image
            | image_url: height: 1000
            | image_tag:
              class: 'color__bg-overlay-1 border--radius w-full max-h-[500px]',
              loading: 'lazy',
              alt: section.settings.image.alt
          }}
        {% endif %}

        <div class="color__bg-body border--radius mobile-border--t0-radius right-[10px] top-[10px] z-10 flex w-full flex-col gap-4 overflow-auto py-4 md:p-4 md:absolute md:max-h-[500px] md:w-1/3">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'store' %}
                <div
                  @click="flyToStore({{ block.settings.longitude }}, {{ block.settings.latitude }});"
                >
                  {% render 'component__accordion',
                    open: false,
                    enable_once: true,
                    index: forloop.index0,
                    container_class: '',
                    inner_class: 'rte',
                    button_class: '',
                    button_label: block.settings.store_name,
                    content: block.settings.store_details
                  %}
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

