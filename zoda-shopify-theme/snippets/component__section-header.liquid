<!-- snippets/component__section-header.liquid -->
{% comment %}
  Renders the section title and featured button. This accepts content directly from section settings.

  Accepts:
  - container_class: {string} Class string to apply to container element.

  Globals:
  - settings.enable_animations: {boolean} Indicates if animations should be enabled.

  Usage:
    {% render 'component__section-header',
      container_class: 'px-4'
    %}

  Recommendations:
  - Display at the top of a section.
{% endcomment %}

{% if section.settings.heading != blank or section.settings.content != blank or section.settings.button_url != blank %}
  <div
    class="
      flex w-full flex-row flex-wrap items-start gap-4 pb-8
      {{ container_class }}
      {{ section.settings.layout_x_alignment }}
      {% if settings.enable_animations %}
        motion-safe:scroll-fadein-2-20
      {% endif %}
    "
  >
    <div
      class="
        flex w-full max-w-prose flex-col gap-4 md:w-auto
        {% if section.settings.enable_split %}!w-full{% endif %}
      "
    >
      {% unless section.settings.heading == blank %}
        <h3 class="type__heading-1">{{ section.settings.heading }}</h3>
      {% endunless %}
      {% unless section.settings.enable_split_heading %}
        {% unless section.settings.content == blank %}
          <div class="space-y-4">
            {{ section.settings.content }}
          </div>
        {% endunless %}
        {% unless section.settings.button_url == blank %}
          <div
            class="w-full"
          >
            <a
              href="{{ section.settings.button_url }}"
              class="{{ section.settings.color_button }}"
            >
              {{ section.settings.button_label }}
            </a>
          </div>
        {% endunless %}
      {% endunless %}
    </div>

    {% if section.settings.enable_split_heading %}
      <div class="flex max-w-xs flex-col gap-4">
        {% unless section.settings.content == blank %}
          <div class="space-y-4">
            {{ section.settings.content }}
          </div>
        {% endunless %}

        {% unless section.settings.button_url == blank %}
          <div
            class="w-full"
          >
            <a
              href="{{ section.settings.button_url }}"
              class="{{ section.settings.color_button }}"
            >
              {{ section.settings.button_label }}
            </a>
          </div>
        {% endunless %}
      </div>
    {% endif %}
  </div>
{% endif %}
