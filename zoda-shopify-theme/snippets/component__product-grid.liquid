<!-- snippets/component__product-grid.liquid -->
{% comment %}
  This is a standard product thumbnail snippet used to display product information in a grid or list view.

  Accepts:
  - product: {Object} The liquid product object containing all the product details.

  Usage:
    {% render 'component__product-grid',
      product: product,
    %}

  Globals:
  - enable_animations: {boolean} Enables animations if set to true.
  - product_card_border_style: {string} Sets the border style of thumbnails.
  - product_card_color_border: {string} Sets the border color.
  - product_card_color_scheme: {string} Sets the color scheme of thumbnails.
  - product_card_ratio: {string} Sets the aspect ratio of thumbnails.
  - thumbnails_object: {string} Sets the image object sizing.
  - product_card_title_capitilization: {string} Sets the capitilization for thumbnail titles.
  - product_card_title_font: {string} Sets the font family for titles.
  - type_seperator: {string} Sets the type of seperator between text.
  - product_card_savings_badge: {string} Can be set to 'dollar', 'percent', or 'none' to display savings badge.
  - product_card_stock_threshold: {number} Sets the threshold for when to show stock count.
  - enable_quick_desktop: {boolean} Enables quick add on desktop if set to true.
  - enable_quick_mobile: {boolean} Enables quick add on mobile if set to true.
  - product_card_enable_type: {boolean} Displays product type if set to true.
  - product_card_enable_vendor: {boolean} Displays vendor if set to true.
  - product_card_enable_count: {boolean} Displays variant count if set to true.
  - product_card_enable_tagline: {boolean} Display a short description.
  - product_card_show_text_on_hover: {boolean} Displays product content on hover if set to true.
  - product_card_enable_review_badge: {boolean} Displays review badge if set to true.
  - product_card_enable_review_line: {boolean} Displays review line if set to true.

  Recommendations:
  - This snippet is best used while looping through products, for example on collection product grids. It provides a consistent way to display product information across different sections of the site.
{% endcomment %}

{% liquid
  if settings.enable_collection_url
    assign url = product.url | within: collection
  else
    assign url = product.url
  endif

  capture badge_background
    if settings.product_card_badge_scheme == 'light_outline' or settings.product_card_badge_scheme == 'dark_outline'
      echo 'transparent'
    else
      echo settings.product_card_badge_scheme
    endif
  endcapture

  capture badge_foreground
    if settings.product_card_badge_scheme == 'light_outline'
      echo 'light'
    elsif settings.product_card_badge_scheme == 'dark_outline'
      echo 'dark'
    else
      echo settings.product_card_badge_scheme
    endif
  endcapture
%}

{% capture product_badges %}
  <div 
    class="pointer-events-none absolute left-0 top-0 z-10 flex w-full flex-wrap items-center gap-1 whitespace-normal p-4">
    
    {% comment %} Stock count {% endcomment %}
    {% if settings.product_card_stock_threshold %}
      {% assign product_qty = 0 %}
      {% for variant in product.variants %}
        {% if variant.inventory_quantity > 0 %}
          {% assign product_qty = product_qty | plus: variant.inventory_quantity %}
        {% endif %}
      {% endfor %}
      {% if product_qty < settings.product_card_stock_threshold %}
        {% if product_qty > 0 %}
          {% capture badge %}
            <span class="mr-2 inline-flex h-2 w-2">
              <span class="absolute inline-flex h-2 w-2 animate-ping rounded-full bg-current bg-opacity-50"></span>
              <span class="inline-flex h-2 w-2 rounded-full bg-current bg-opacity-50"></span>
            </span>
            <span>{{ product_qty }} {{ 'info.in_stock' | t | downcase }}</span>
          {% endcapture %}
          {% render 'component__badge', 
            background: badge_background,
            text: badge_foreground,
            border: badge_foreground,
            content: badge 
          %}
        {% else %}
          {% unless product.available %}
            {% capture badge %}
              <span class="mr-2 inline-flex h-2 w-2">
                <span class="absolute inline-flex h-2 w-2 animate-ping rounded-full bg-current bg-opacity-50"></span>
                <span class="inline-flex h-2 w-2 rounded-full bg-current bg-opacity-50"></span>
              </span>
              <span>{{ 'labels.sold_out' | t }}</span>
            {% endcapture %}
            {% render 'component__badge', 
              background: badge_background,
              text: badge_foreground,
              border: badge_foreground,
              content: badge 
            %} 
          {% endunless %}    
        {% endif %}
      {% endif %}
    {% endif %}

    {% comment %} Savings {% endcomment %}
    {% if settings.product_card_savings_badge != "none" %}
      {% if product.price < product.compare_at_price %}
        {% if settings.product_card_savings_badge == "percent" %}
          {% capture badge_content %}{{ discount_percentage }}{% endcapture %}
          {% capture a %}{{ product.compare_at_price | minus: product.price }} {% endcapture %}
          {% capture b %}{{ a | times: 100 }} {% endcapture %} 
          {% capture discount_percentage %}{{ b | divided_by: product.compare_at_price | round }} {% endcapture %} 
          {% capture badge_content %} {{ 'labels.save' | t }} {{ discount_percentage | strip | append: '%' }} {% endcapture %}
        {% else %}
          {% capture discount_amount %}{{ product.compare_at_price | minus: product.price }}{% endcapture %}
          {% capture badge_content %}
            {{ 'labels.save' | t }} {% render 'component__format-price', price: discount_amount %}
          {% endcapture %}
        {% endif %}
        {% render 'component__badge', 
          background: badge_background,
          text: badge_foreground,
          border: badge_foreground,
          content: badge_content %}
      {% endif %}
    {% endif %}
    
    {% comment %} Rating {% endcomment %}
    {% if settings.product_card_enable_review_badge %}
      {% render 'component__rating', 
        product: product,
        enable_stars: true,
        enable_badge: true,
        badge_background: badge_background,
        badge_text: badge_foreground
      %}
    {% endif %}

    {% comment %} Tags {% endcomment %}
    {% for tag in product.tags %}
      {% if tag contains "badge_" %}
        {% capture badge_content %}{{ tag | remove: "badge_" }}{% endcapture %}
        {% render 'component__badge', 
          background: badge_background,
          text: badge_foreground,
          border: badge_foreground,
          content: badge_content %}
      {% endif %}
    {% endfor %}
    
    {% comment %} Metafields {% endcomment %}
    {% assign metafield = product.metafields.custom.badge %}
    {% if metafield %}
      {% capture badge_content %}{{ metafield }}{% endcapture %}
      {% render 'component__badge',
        background: badge_background,
        text: badge_foreground,
        border: badge_foreground,
        content: badge_content %}
    {% endif %}
    
  </div>
{% endcapture %}

{% capture product_standard_image %}
  <a 
    href="{{ url }}"
    tabindex="-1"
    class="
      animation-300 w-full overflow-clip hover:opacity-100
      {{ settings.product_card_color_scheme }} 
      {% if settings.product_card_border_style == 'image' %}
        border--radius
      {% endif %}
    ">

    {% if product.media[0].media_type == "video" %}
      <div class="overflow-hidden object-cover {{ settings.product_card_ratio }}">
        {{ product.media[0] | video_tag: autoplay: true, loop: true, mute: true, controls: false, class: 'w-full h-full object-cover' }}
      </div>
    {% else %}
      <div 
        class="overflow-clip object-cover {{ settings.product_card_ratio }} {{ settings.product_card_color_scheme }} ">
        {% unless product.featured_image == blank %}
          {% capture aspect_ratio %}
            {{ settings.product_card_ratio }}
          {% endcapture %}
          {% capture crop %}
            {% if settings.product_card_crop == "cover" %}
              object-cover
            {% else %}
              object-contain
            {% endif %}
          {% endcapture %}
          {% render 'component__image', 
            image: product.featured_image,
            max_width: 1600,
            background_class: '',
            image_class: 'w-full h-full',
            ratio_class: aspect_ratio,
            crop_class: crop,
            enable_lazy_load: true,
            enable_2x: true
          %}
        {% endunless %}
      </div>
    {% endif %}
   
    {% if settings.product_card_enable_hover %}
      {% unless product.media[1] == blank %}
        {% case product.media[1].media_type %}
          {% when 'image' %}
            <div class="animation-300 absolute left-0 top-0 h-full w-full overflow-hidden opacity-0 group-hover/product:opacity-100
              {{ settings.product_card_color_scheme }}">
              <div class="overflow-hidden object-cover
                {{ settings.product_card_ratio }}">
                {% capture image_class %}
                  {% if settings.product_card_crop == "cover" %}
                    w-full h-full object-cover
                  {% else %}
                    w-full h-full object-contain
                  {% endif %}
                {% endcapture %}
                <img 
                  loading='lazy' 
                  class="{{ image_class }}" 
                  alt="{{ product.media[1].alt }}"
                  :src="second_image"
                  height="550"
                  width="370" />
              </div>
            </div>
          {% when 'video' %}
            <div class="animation-300 absolute left-0 top-0 h-full w-full overflow-hidden opacity-0 group-hover/product:opacity-100
              {{ settings.product_card_color_scheme }}">
              <div class="overflow-hidden object-cover
                {{ settings.product_card_ratio }}">
                {{ product.media[1] | video_tag: autoplay: true, loop: true, mute: true, controls: false, class: 'w-full h-full object-cover' }}
              </div>
            </div>
        {% endcase %}
      {% endunless %}
    {% endif %}

  </a>
{% endcapture %}

{% capture product_slider_image %}
  {% assign image_index = 0 %}
  {% capture slides %}
    {% for media in product.media limit: 4 %}
      <a 
        class="left-0 top-0 flex h-full w-full flex-none snap-center justify-center overflow-hidden hover:opacity-100 {{ settings.product_card_color_scheme }}"
        href="{{ url }}"
        x-intersect:enter.half="index = {{ image_index }};"
        x-bind:data-slide="{{ image_index }}">
        {% if media.media_type == "video" %}
          <div class="overflow-hidden object-cover {{ settings.product_card_ratio }}">
            {{ media | video_tag: autoplay: true, loop: true, mute: true, controls: false, class: 'w-full h-full object-cover' }}
          </div>
        {% else %}
          {% if settings.product_card_crop == "cover" %}
            {% capture crop_class %}object-cover{% endcapture %}
          {% else %}
            {% capture crop_class %}object-contain{% endcapture %}
          {% endif %}
          {% render 'component__image', 
            image: media,
            max_width: 1600,
            parent_class: 'w-full',
            background_class: settings.product_card_color_scheme,
            ratio_class: settings.product_card_ratio,
            crop_class: crop_class,
            enable_lazy_load: true,
            enable_2x: true
          %}
        {% endif %}
      </a>
      {% assign image_index = image_index | plus: 1 %}
    {% endfor %}
  {% endcapture %}
  {% assign image_index = image_index | minus: 1 %}
  {% if settings.product_card_indicator_type == 'full' %}
    {% assign enable_indicators_alt = true %}
  {% else %}
    {% assign enable_indicators_alt = false %}
  {% endif %}
  {% if settings.product_card_indicator_type == 'standard' %}
    {% assign enable_indicators = true %}
  {% else %}
    {% assign enable_indicators = false %}
  {% endif %}
  {% render 'component__slider',
    container_class: '!p-0',
    slider_size: image_index,
    slides: slides,
    layout_arrow_alignment: 'justify-center !bottom-2',
    layout_arrow_placement: 'bottom',
    indicator_class: '!bg-transparent !p-0',
    enable_arrows_over: true,
    enable_indicators: enable_indicators,
    enable_indicators_alt: enable_indicators_alt,
    disable_smooth_scroll: true
  %} 
  {% if product.media.size == 0 %}
    <div 
      class="overflow-clip object-cover {{ settings.product_card_ratio }} {{ settings.product_card_color_scheme }} ">
    </div>
  {% endif %}
{% endcapture %}

{% capture product_title %}
  <h3 
    class="
      {{ settings.product_card_title_capitilization }}
      {{ settings.product_card_title_font }}
    ">
    {{ product.title }}
  </h3>
{% endcapture %}

{% capture product_rating %}
  {% if settings.product_card_enable_review_text %}

    {% render 'component__rating', 
      product: product,
      enable_stars: true,
      enable_badge: false
    %}
  {% endif %}
{% endcapture %}

{% capture product_tagline %}
  {% if settings.product_card_enable_tagline and product.metafields.descriptors.subtitle %}
    <p class="type--small opacity-75">
      {{ product.metafields.descriptors.subtitle }}
    </p>
  {% endif %}
{% endcapture %}

{% capture product_swatches %}
  {% if settings.product_card_enable_swatches %}
    {% for product_option in product.options_with_values %}
      {% assign color =  'labels.color' | t | downcase %}
      {% assign downcase_option_name = product_option.name | downcase %}
      {% if 
        downcase_option_name == color or 
        downcase_option_name == "colour" or
        downcase_option_name == "color" or
        downcase_option_name == "colore" or
        downcase_option_name == "farbe" or
        downcase_option_name == "couleur" 
      %}
        {% comment %} Options named "color" will show automatic swatches or custom uploaded {% endcomment %}
        <div 
          class="
            flex w-full flex-wrap items-center gap-1
            {% if settings.product_card_alignment == "center" %}
              text-center justify-center
            {% endif %}
            {% if settings.product_card_alignment == "right" %}
              text-right justify-end
            {% endif %}
          ">
          {% for value in product_option.values limit: 6 %}
            {% assign swatch_image = '' %}
            {% if value.swatch %}
              {% assign swatch_color = value.swatch.color %}
              {% assign swatch_image = value.swatch.image | image_url: width: 32 %}
            {% else %}
              {% assign swatch_color = value | handle %}
              {% capture swatch_image_filename %}swatch-{{ value | handle }}.jpg{% endcapture %}
              {% assign swatch_image = images[swatch_image_filename] | image_url: width: 32 %}
            {% endif %}
            <div 
              class="
                border__button--radius color__bg-shade-2 border--width color__border-divider-1 focus:border--focus--inset hover:border--focus--inset flex bg-cover bg-center bg-no-repeat
                {% if settings.product_card_swatch_style == 'small' %}
                  !h-4 !w-4
                {% endif %}
                {% if settings.product_card_swatch_style == 'medium' %}
                  !h-6 !w-6
                {% endif %}
                {% if settings.product_card_swatch_style == 'large' %}
                  !h-10 !w-10
                {% endif %}
              "

              style="
                background-color: {{ swatch_color }};
                background-image: url('{{ swatch_image }}');
              "
              {% for variant in product.variants %}
                {% if value contains variant.title and variant.featured_image %}
                  @mouseover="second_image='{{ variant.featured_image | image_url: width: 1600 }}'"
                  :class="
                    {
                      'border--focus--inset' : second_image == `{{ variant.featured_image | image_url: width: 1600 }}`
                    }
                  "
                {% endif %}
              {% endfor %}>
            </div>
          {% endfor %}
          {% if product_option.values.size > 6 %}
            {% assign remaining = product_option.values.size | minus: 6 %}
            <span class="type--smaller opacity-50">+{{ remaining }}</span>
          {% endif %}
        </div>
        
      
      {% else %}
        {% comment %} All other options will only show automatic swatches {% endcomment %}
        {% assign has_swatch = false %}
        {% for value in product_option.values limit: 6 %}
          {% if value.swatch %}
            {% assign has_swatch = true %}
          {% endif %}
        {% endfor %}
        {% if has_swatch %}
          <div 
            class="
              flex w-full flex-wrap items-center gap-1
              {% if settings.product_card_alignment == "center" %}
                text-center justify-center
              {% endif %}
              {% if settings.product_card_alignment == "right" %}
                text-right justify-end
              {% endif %}
            ">
            {% assign swatches_shown = 0 %}
            {% assign total_swatches = 0 %}
            {% for value in product_option.values %}
              {% if value.swatch %}
                {% assign total_swatches = total_swatches | plus: 1 %}
              {% endif %}
            {% endfor %}
            {% for value in product_option.values limit: 6 %}
              {% if value.swatch %}
                {% assign swatches_shown = swatches_shown | plus: 1 %}
                {% assign swatch_color = value.swatch.color %}
                {% assign swatch_image = value.swatch.image | image_url: width: 32 %}
                <div 
                  class="
                    border__button--radius color__bg-shade-2 border--width color__border-divider-1 focus:border--focus--inset hover:border--focus--inset flex bg-cover bg-center bg-no-repeat
                    {% if settings.product_card_swatch_style == 'small' %}
                      !h-4 !w-4
                    {% endif %}
                    {% if settings.product_card_swatch_style == 'medium' %}
                      !h-6 !w-6
                    {% endif %}
                    {% if settings.product_card_swatch_style == 'large' %}
                      !h-10 !w-10
                    {% endif %}
                  "
                  style="
                    background-color: {{ swatch_color }};
                    background-image: url('{{ swatch_image }}');
                  "
                  {% for variant in product.variants %}
                    {% if value contains variant.title and variant.featured_image %}
                      @mouseover="second_image='{{ variant.featured_image | image_url: width: 1600 }}'"
                      :class="
                        {
                          'border--focus--inset' : second_image == `{{ variant.featured_image | image_url: width: 1600 }}`
                        }
                      "
                    {% endif %}
                  {% endfor %}>
                </div>
              {% endif %}
            {% endfor %}
            {% assign remaining_swatches = total_swatches | minus: swatches_shown %}
            {% if remaining_swatches > 0 %}
              <span class="type--smaller opacity-50">+{{ remaining_swatches }}</span>
            {% endif %}
          </div>
        {% endif %}

      {% endif %}
    {% endfor %}
  {% endif %}
{% endcapture %}

{% capture product_variant_and_sku %}
  <div class="flex gap-1">
    {% if settings.product_card_enable_count %}
      <span class="type--smaller opacity-50">{{ product.variants.size }} {{ 'labels.options' | t | downcase }}</span>
    {% endif %}
    
    {% if settings.product_card_enable_sku %}
      <span class="type--smaller mb-0 uppercase opacity-50">{{ product.variants[0].sku }}</span>
    {% endif %}
  </div>
{% endcapture %}

{% capture product_vendor %}
  {% if settings.product_card_enable_vendor %}
    <span class="type--small">
      {{ product.vendor }}
    </span>
  {% endif %}
{% endcapture %}

{% capture product_type %}
  {% if settings.product_card_enable_type %}
    <span class="type--small">
      {{ product.type }}
    </span>
  {% endif %}
{% endcapture %}

{% capture hover_add_button %} 
  {% if settings.quick_position == 'overlay' %}
    <div
      class="
        no-js--hide animation-500 mt-4 hidden w-full translate-y-2 opacity-0 focus-within:translate-y-0 focus-within:opacity-100 group-hover/product:translate-y-0 group-hover/product:opacity-100 md:block
        {% unless settings.enable_quick_desktop %}
          md:hidden
        {% endunless %}

      "
    >
      <form
        action="{{ routes.cart_add_url }}"
        data-productid="{{ product.id }}"
        method="post"
        enctype="multipart/form-data"
        data-productid="{{ product.id }}"
        x-data="
          {
            current_variant_id: {{ product.variants.first.id }},
            current_variant_selling_plan_id: 0,
            quantity: 1,
          }
        "
        @submit.prevent="
          button_loading = true;
          addCartItem(current_variant_id, current_variant_selling_plan_id, quantity, true);
          setTimeout(function(){ button_loading = false}, 500);
        "
      >
        {% if product.has_only_default_variant
          and product.selected_or_first_available_selling_plan_allocation == null
        %}
          <input
            name="id"
            type="hidden"
            :value="current_variant_id"
            x-model="current_variant_id"
          >
          <input
            class="!hidden"
            name="quantity"
            type="text"
            value="1"
            min="1"
            max=""
            aria-label="{{ 'labels.quantity' | t }}"
            x-model="quantity"
          >
          <button
            class="btn btn--smaller btn--load {{ settings.quick_color_button }}"
            :class="{ 'btn--loading' : button_loading }"
            type="submit"
            role="button"
            {% unless product.available %}
              disabled
            {% endunless %}
            :disabled="button_loading || ({{ product.available }} == false)"
          >
            <div class="btn__content">
              {% if product.available %}
                {% if product.metafields.custom.button_text %}
                  {{ product.metafields.custom.button_text }}
                {% else %}
                  {{ 'actions.add_to_cart' | t }}
                {% endif %}
              {% else %}
                {{ 'labels.sold_out' | t }}
              {% endif %}
            </div>
            <div class="btn__spinner">
              {% render 'component__icon', icon: 'spinner', size: '16', class: '' %}
            </div>
          </button>
        {% else %}
          <button
            class="btn btn--smaller btn--load {{ settings.quick_color_button }}"
            :class="{ 'btn--loading' : button_loading }"
            type="button"
            role="button"
            {% unless product.available %}
              disabled
            {% endunless %}
            :disabled="button_loading || ({{ product.available }} == false)"
            @click="
              button_loading = true;
              fetchAndRenderQuickAdd('{{ product.handle }}');
              setTimeout(function(){ button_loading = false}, 500);
            "
          >
            <div class="btn__content">
              {% if product.available %}
                {% if product.metafields.custom.button_text %}
                  {{ product.metafields.custom.button_text }}
                {% else %}
                  {{ 'actions.add_to_cart' | t }}
                {% endif %}
              {% else %}
                {{ 'labels.sold_out' | t }}
              {% endif %}
            </div>
            <div class="btn__spinner">
              {% render 'component__icon', icon: 'spinner', size: '16', class: '' %}
            </div>
          </button>
        {% endif %}
      </form>
    </div>
  {% endif %}
{% endcapture %}

{% capture product_price_and_add %}
  <div 
    class="
      flex min-w-[33%] flex-wrap items-start gap-1
      {% if settings.product_card_alignment == "center" %}
        text-center justify-center
      {% endif %}
      {% if settings.product_card_alignment == "right" %}
        text-right justify-end
      {% endif %}
      {% if settings.product_card_alignment == "justified" %}
        justify-end items-end text-right flex-col
      {% else %}
        w-full
      {% endif %}
    ">

    {% comment %} Unit price {% endcomment %}
    {% if settings.product_card_show_prices %}
      {% if product.selected_or_first_available_variant.unit_price %}
        <span class="type--smaller w-full opacity-50
          {% if settings.product_card_alignment == "center" %}
            justify-center
          {% endif %}
          {% if settings.product_card_alignment == "right" or settings.product_card_alignment == "justified" %}
            justify-end
          {% endif %}">
          {% render 'component__format-price', price: product.selected_or_first_available_variant.unit_price %} /
          {{ product.selected_or_first_available_variant.unit_price_measurement.reference_value }}
          {{ product.selected_or_first_available_variant.unit_price_measurement.reference_unit }}
        </span>
      {% endif %}
    {% endif %}
    
    {% comment %} Prices {% endcomment %}
    {% if settings.product_card_show_prices %}
      <div 
        class="shrink">
        <div 
          class="
            flex flex-wrap items-center gap-1
            {% if settings.product_card_alignment == "center" %}
              justify-center
            {% endif %}
            {% if settings.product_card_alignment == "right" or settings.product_card_alignment == "justified" %}
              justify-end
            {% endif %}
          ">

          {% comment %} Starting price {% endcomment %}
          <span class="
            {% if product.compare_at_price_max > product.price_max %}
              color__link
            {% endif %}
          ">
            {% if product.price_varies and settings.price_range == "show_starting_price" %}
              <span>
                {{ 'labels.from' | t }}
              </span>
            {% endif %}
            {% render 'component__format-price', price: product.price_min %}
          </span>

          {% comment %} If showing range {% endcomment %}
          {% if product.price_varies and settings.price_range == "show_range" %}
            <span>
              - 
              {% render 'component__format-price', price: product.price_max %}
            </span>
          {% endif %}

          {% comment %} Sale price {% endcomment %}
          {% if product.compare_at_price_max > 0 %}
            {% if settings.sale_price_range_display == "show_range" %}
              <span>
                <s 
                  class="opacity-50" 
                  x-html="Shopify.formatMoney({{ product.compare_at_price_min }})">
                  {% render 'component__format-price', price: product.compare_at_price_min %}
                </s>
                {% if product.compare_at_price_varies %}
                  <s 
                    class="m-0 opacity-50" 
                    x-html="'- ' + Shopify.formatMoney({{ product.compare_at_price_max }})"> - {{ product.compare_at_price_max | money }}
                  </s>
                {% endif %}
              </span>
            {% else %}
              <span>
                <s class="opacity-50" x-html="Shopify.formatMoney({{ product.compare_at_price_min }})">
                  {% render 'component__format-price', price: product.compare_at_price_min %}
                </s>
              </span>
            {% endif %}
          {% endif %}

        </div>
      </div>
    {% endif %}

    {% comment %} Quick add {% endcomment %}
    {% if settings.enable_quick_mobile %}
      {% if settings.product_card_show_prices and settings.product_card_alignment != 'justified' %}
        <span 
          class="
            {% if settings.product_card_alignment == "left" or settings.product_card_alignment == "justified" %}
              md:opacity-0 group-hover/product:opacity-100 animation-300
            {% endif %}
            {% unless settings.enable_quick_mobile %}
              hidden md:flex
            {% endunless %}
            {% unless settings.enable_quick_desktop %}
              md:hidden
            {% endunless %}
            {% if settings.quick_position == "overlay" %}
              md:hidden
            {% endif %}
            {% if settings.quick_position == "overlay" and settings.enable_quick_mobile %}
              hidden md:flex
            {% endif %}
          ">-</span>
      {% endif %}
      <div 
        class="
          {% if settings.product_card_alignment == "left" or settings.product_card_alignment == "justified" %}
            md:opacity-0 group-hover/product:opacity-100 group-focus-within/product:opacity-100 animation-300
          {% endif %}
          {% unless settings.enable_quick_mobile %}
            hidden md:flex
          {% endunless %}
          {% unless settings.enable_quick_desktop %}
            md:hidden
          {% endunless %}
          {% if settings.quick_position == "overlay" %}
            md:hidden
          {% endif %}
          {% if settings.quick_position == "overlay" and settings.enable_quick_mobile %}
            hidden md:flex
          {% endif %}
        ">
        <form 
          action="{{ routes.cart_add_url }}" 
          method="post" 
          enctype="multipart/form-data"
          x-data="{
            current_variant_id: {{ product.variants[0].id | default: 0 }},
            current_variant_selling_plan_id: 0,
            quantity: 1,
          }"
          @submit.prevent="
            button_loading = true; 
            addCartItem(current_variant_id, current_variant_selling_plan_id, quantity, true); 
            setTimeout(function(){ button_loading = false}, 500);
          ">
      
          {% comment %} Add to cart {% endcomment %}
          {% if product.has_only_default_variant and product.selected_or_first_available_selling_plan_allocation == nil %}
            <input 
              name="id" 
              type="hidden"
              :value="current_variant_id">
            <label 
              class="sr-only"
              for="quantity_c_product_item_{{ product.variants[0].id }}-{{ section.id }}">
              {{ 'labels.quantity' | t }}
            </label>
            <input 
              id="quantity_c_product_item_{{ product.variants[0].id }}-{{ section.id }}"
              name="quantity" 
              type="hidden" 
              value="1" 
              min="1"
              max="" 
              aria-label="{{ 'labels.quantity' | t }}"
              x-model="quantity">
            <button 
              {% if settings.quick_position == "overlay" %}
                class="
                  btn btn--smaller btn--load {{ settings.quick_color_button }}
                "
              {% endif %}
              :class="{
                'animate-pulse': button_loading
              }"
              type="submit" 
              role="button"
              {% unless product.available %}
                disabled
              {% endunless %}>
              <div 
                class="btn__content">
                {% if product.available %}
                  {% if product.metafields.custom.button_text %}
                    {{ product.metafields.custom.button_text }}
                  {% else %}
                    {{ 'actions.add_to_cart' | t }}
                  {% endif %}
                {% else %}
                  {{ 'labels.sold_out' | t }}
                {% endif %}
              </div>
            </button>

          {% comment %} Open quick add overlay {% endcomment %}
          {% else %}
            <button 
              {% if settings.quick_position == "overlay" %}
                class="
                  btn btn--smaller btn--load {{ settings.quick_color_button }}
                "
              {% endif %}
              :class="{
                'animate-pulse': button_loading
              }"
              type="button" 
              role="button"
              {% unless product.available %}
                disabled
              {% endunless %}
              @click="
                button_loading = true; 
                fetchAndRenderQuickAdd('{{ product.handle }}');
                setTimeout(function(){ button_loading = false}, 500);
              ">
              <div 
                class="btn__content">
                {% if product.available %}
                  {% if product.metafields.custom.button_text %}
                    {{ product.metafields.custom.button_text }}
                  {% else %}
                    {{ 'actions.add_to_cart' | t }}
                  {% endif %}
                {% else %}
                  {{ 'labels.sold_out' | t }}
                {% endif %}
              </div>
            </button>
          {% endif %}

        </form>
      </div>
    {% endif %}

  </div>
  <div 
    class="
    {% unless settings.enable_quick_mobile and settings.quick_position == "overlay" %}
        !hidden
      {% endunless %}
      md:hidden
      {% if settings.product_card_alignment == "left" or settings.product_card_alignment == "justified" %}
        md:opacity-0 group-hover/product:opacity-100 group-focus-within/product:opacity-100 animation-300
      {% endif %}
      
    ">
    <form 
      action="{{ routes.cart_add_url }}" 
      method="post" 
      enctype="multipart/form-data"
      x-data="{
        current_variant_id: {{ product.variants[0].id | default: 0 }},
        current_variant_selling_plan_id: 0,
        quantity: 1,
      }"
      @submit.prevent="
        button_loading = true; 
        addCartItem(current_variant_id, current_variant_selling_plan_id, quantity, true); 
        setTimeout(function(){ button_loading = false}, 500);
      ">
  
      {% comment %} Add to cart {% endcomment %}
      {% if product.has_only_default_variant and product.selected_or_first_available_selling_plan_allocation == nil %}
        <input 
          name="id" 
          type="hidden"
          :value="current_variant_id">
        <label 
          class="sr-only"
          for="quantity_c_product_item_{{ product.variants[0].id }}-{{ section.id }}">
          {{ 'labels.quantity' | t }}
        </label>
        <input 
          id="quantity_c_product_item_{{ product.variants[0].id }}-{{ section.id }}"
          name="quantity" 
          type="hidden" 
          value="1" 
          min="1"
          max="" 
          aria-label="{{ 'labels.quantity' | t }}"
          x-model="quantity">
        <button 
          class="btn--smaller btn--load {{ settings.quick_color_button }}"
          :class="{
            'animate-pulse': button_loading
          }"
          type="submit" 
          role="button"
          {% unless product.available %}
            disabled
          {% endunless %}>
          <div 
            class="btn__content">
            {% if product.available %}
              {% if product.metafields.custom.button_text %}
                {{ product.metafields.custom.button_text }}
              {% else %}
                {{ 'actions.add_to_cart' | t }}
              {% endif %}
            {% else %}
              {{ 'labels.sold_out' | t }}
            {% endif %}
          </div>
        </button>

      {% comment %} Open quick add overlay {% endcomment %}
      {% else %}
        <button 
          {% if settings.quick_position == "overlay" %}
            class="
              btn btn--smaller btn--load {{ settings.quick_color_button }}
            "
          {% endif %}
          :class="{
            'animate-pulse': button_loading
          }"
          type="button" 
          role="button"
          {% unless product.available %}
            disabled
          {% endunless %}
          @click="
            button_loading = true; 
            fetchAndRenderQuickAdd('{{ product.handle }}');
            setTimeout(function(){ button_loading = false}, 500);
          ">
          <div 
            class="btn__content">
            {% if product.available %}
              {% if product.metafields.custom.button_text %}
                {{ product.metafields.custom.button_text }}
              {% else %}
                {{ 'actions.add_to_cart' | t }}
              {% endif %}
            {% else %}
              {{ 'labels.sold_out' | t }}
            {% endif %}
          </div>
        </button>
      {% endif %}

    </form>
  </div>
{% endcapture %}

<div
  class="
    group/product relative w-full
    {% if settings.product_card_border_style == 'thumbnail' %}
      border--radius overflow-clip
      {{ settings.product_card_color_border }}
      {{ settings.product_card_color_scheme }}
    {% endif %}
  "
  x-data="
    {
      button_loading: false,
      second_image: '{{ product.media[1] | image_url: width: 1600 }}'
    }
  "
>
  {% comment %} Badges {% endcomment %}
  {{ product_badges }}

  {% comment %} Image + overlay {% endcomment %}
  <div
    class="
      relative block w-full
      {% if settings.product_card_border_style == 'image' %}
        border--radius overflow-clip
        {{ settings.product_card_color_border }}
      {% endif %}
    "
  >
    {% comment %} Images {% endcomment %}
    {% if settings.product_card_image_style == 'standard' %}
      {{ product_standard_image }}
    {% else %}
      {{ product_slider_image }}
    {% endif %}

    {% comment %} Overlay {% endcomment %}
    <div
      class="animation-300 pointer-events-none absolute bottom-0 flex h-full w-full items-end opacity-0 focus-within:translate-y-0 focus-within:opacity-100 group-hover/product:opacity-100"
      style="background: {{ settings.product_card_color_overlay }};"
    >
      <div
        class="
          pointer-events-auto z-10 flex w-full gap-1 p-4
          {{ settings.product_card_overlay_text }}
          {% if settings.product_card_alignment == "center" %}
            text-center
          {% endif %}
          {% if settings.product_card_alignment == "right" %}
            text-right
          {% endif %}
          {% if settings.product_card_alignment == "justified" %}
            flex-row
          {% else %}
            flex-wrap flex-col
          {% endif %}
        "
      >
        <div
          class="
            flex grow flex-col gap-1
            {% if settings.product_card_alignment == "center" %}
              items-center
            {% endif %}
            {% if settings.product_card_alignment == "right" %}
              items-end
            {% endif %}
            {% unless settings.product_card_alignment == "justified" %}
              w-full
            {% endunless %}
          "
        >
          {{ product_variant_and_sku }}
          {% if settings.product_card_show_text_on_hover %}
            {{ product_rating }}
            {{ product_title }}
            {{ product_tagline }}
          {% endif %}
          {{ product_vendor }}
          {{ product_type }}
        </div>
        {% if settings.product_card_show_text_on_hover %}
          {{ product_swatches }}
          {{ product_price_and_add }}
        {% endif %}
        {{ hover_add_button }}
      </div>
    </div>
  </div>

  {% comment %} Content {% endcomment %}
  <div
    class="
      flex items-start justify-between gap-2 whitespace-normal pt-4 no-underline hover:no-underline
      {% if settings.product_card_show_text_on_hover %}
        md:hidden
      {% endif %}
      {% if settings.product_card_alignment == "center" %}
        text-center
      {% endif %}
      {% if settings.product_card_alignment == "right" %}
        text-right
      {% endif %}
      {% unless settings.product_card_alignment == "justified" %}
        flex-wrap
      {% endunless %}
      {% if settings.product_card_border_style == "thumbnail" %}
        px-4 pb-4
      {% endif %}
    "
  >
    <a
      class="
        flex grow flex-col gap-1 no-underline hover:no-underline
        {% if settings.product_card_alignment == "center" %}
          items-center
        {% endif %}
        {% if settings.product_card_alignment == "right" %}
          items-end
        {% endif %}
        {% unless settings.product_card_alignment == "justified" %}
          w-full
        {% endunless %}
      "
      href="{{ url }}"
    >
      {{ product_rating }}
      {{ product_title }}
      {{ product_tagline }}
      {{ product_swatches }}
    </a>
    {{ product_price_and_add }}
  </div>
</div>
