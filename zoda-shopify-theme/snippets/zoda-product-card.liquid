{% comment %}
  ZODA product card.
  Usage: {% render 'zoda-product-card', product: product %}
{% endcomment %}

{%- assign p = product -%}
{%- assign first_variant = p.selected_or_first_available_variant -%}
{%- assign color_option = null -%}
{%- assign size_option = null -%}
{%- assign selected_color = blank -%}
{%- assign display_image = p.featured_image -%}

{%- for opt in p.options_with_values -%}
  {%- assign opt_name_down = opt.name | downcase -%}
  {%- if opt_name_down contains 'color' or opt_name_down contains 'colour' -%}
    {%- assign color_option = opt -%}
    {%- assign selected_color = opt.values.first -%}
  {%- elsif opt_name_down contains 'size' -%}
    {%- assign size_option = opt -%}
  {%- endif -%}
{%- endfor -%}

{%- if color_option and selected_color != blank -%}
  {%- for variant in p.variants -%}
    {%- if variant.options contains selected_color and variant.featured_image -%}
      {%- assign display_image = variant.featured_image -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

<a class="zoda-product-card" href="{{ p.url }}" aria-label="{{ p.title | escape }}">
  <div class="zoda-product-card__media">
    {%- if display_image -%}
      <img
        src="{{ display_image | image_url: width: 720 }}"
        alt="{{ display_image.alt | default: p.title | escape }}"
        loading="lazy"
        width="720"
        height="900"
      >
    {%- endif -%}

    {%- if size_option and size_option.values.size > 0 -%}
      <div class="zoda-product-card__sizes" role="group" aria-label="Quick add - choose a size">
        <span class="zoda-product-card__sizes-label">Quick add</span>
        <div class="zoda-product-card__sizes-row">
          {%- for size_value in size_option.values -%}
            {%- assign size_variant = null -%}
            {%- for variant in p.variants -%}
              {%- assign color_match = true -%}
              {%- assign size_match = false -%}
              {%- for option in variant.options -%}
                {%- if color_option and option == selected_color -%}
                  {%- assign color_match = true -%}
                {%- endif -%}
                {%- if option == size_value -%}
                  {%- assign size_match = true -%}
                {%- endif -%}
              {%- endfor -%}
              {%- if size_match and color_match and size_variant == null -%}
                {%- assign size_variant = variant -%}
              {%- endif -%}
            {%- endfor -%}

            <button
              type="button"
              class="zoda-product-card__size{% unless size_variant and size_variant.available %} is-unavailable{% endunless %}"
              data-zoda-quick-add
              data-variant-id="{{ size_variant.id }}"
              aria-label="Add {{ p.title | escape }} - {{ selected_color | escape }} {{ size_value | escape }} to cart"
              {% unless size_variant and size_variant.available %}
                disabled
              {% endunless %}
            >
              {{ size_value }}
            </button>
          {%- endfor -%}
        </div>
      </div>
    {%- elsif first_variant -%}
      <button
        type="button"
        class="zoda-product-card__quick-add"
        data-zoda-quick-add
        data-variant-id="{{ first_variant.id }}"
        aria-label="Quick add {{ p.title | escape }} to cart"
        {% unless first_variant.available %}
          disabled
        {% endunless %}
      >
        Quick Add
      </button>
    {%- endif -%}
  </div>

  <div class="zoda-product-card__body">
    {%- if color_option and color_option.values.size > 1 -%}
      <div class="zoda-product-card__swatches" aria-label="Available colors">
        {%- for val in color_option.values limit: 6 -%}
          {%- assign swatch_image = blank -%}
          {%- capture size_payload -%}{%- endcapture -%}
          {%- for variant in p.variants -%}
            {%- if variant.options contains val and variant.featured_image -%}
              {%- assign swatch_image = variant.featured_image | image_url: width: 96 -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if size_option and size_option.values.size > 0 -%}
            {%- capture size_payload -%}
              {%- for size_value in size_option.values -%}
                {%- assign swatch_size_variant = null -%}
                {%- for variant in p.variants -%}
                  {%- if variant.options contains val and variant.options contains size_value and swatch_size_variant == null -%}
                    {%- assign swatch_size_variant = variant -%}
                  {%- endif -%}
                {%- endfor -%}
                {{ size_value | escape }}::{{ swatch_size_variant.id }}::{{ swatch_size_variant.available }}{% unless forloop.last %}||{% endunless %}
              {%- endfor -%}
            {%- endcapture -%}
          {%- endif -%}

          <button
            type="button"
            class="zoda-product-card__swatch{% if forloop.first %} is-active{% endif %}"
            data-zoda-card-swatch
            data-color="{{ val | escape }}"
            data-image-url="{% if swatch_image != blank %}{{ swatch_image | replace: 'width=96', 'width=720' }}{% endif %}"
            data-size-payload="{{ size_payload | strip | escape }}"
            title="{{ val | escape }}"
            aria-label="{{ val | escape }}"
            aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
            style="{% if swatch_image != blank %}background: center / cover no-repeat url({{ swatch_image }});{% else %}background: {{ val | downcase | replace: ' ', '' }};{% endif %}"
          >
            {%- if forloop.first -%}
              <svg class="zoda-product-card__swatch-check" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            {%- endif -%}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <span class="zoda-product-card__title">{{ p.title }}</span>
    <span class="zoda-product-card__price">{{ cart.currency.iso_code }} {{ p.price | money_without_currency }}</span>
  </div>
</a>
