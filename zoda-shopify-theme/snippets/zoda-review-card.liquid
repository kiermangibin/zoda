{% liquid
  assign duplicate_attrs = ''
  if is_duplicate
    assign duplicate_attrs = 'aria-hidden="true"'
  endif
%}

<article
  class="zoda-circuit__review-card"
  {% unless is_duplicate %}
    {{ block.shopify_attributes }}
  {% endunless %}
  {{ duplicate_attrs }}
>
  <div class="zoda-circuit__review-stars" aria-label="{{ block.settings.rating }} out of 5 stars">
    {% for star in (1..5) %}
      <svg viewBox="0 0 20 20" aria-hidden="true" focusable="false">
        <path
          d="M10 1.6 12.5 7l5.8.6-4.3 4 1.2 5.8L10 14.4l-5.2 3 1.2-5.8-4.3-4L7.5 7 10 1.6Z"
          fill="{% if star <= block.settings.rating %}currentColor{% else %}none{% endif %}"
          stroke="currentColor"
          stroke-width="1.4"
        />
      </svg>
    {% endfor %}
  </div>

  {% if block.settings.tag != blank %}
    <span class="zoda-circuit__review-meta">{{ block.settings.tag }}</span>
  {% endif %}

  {% if block.settings.quote != blank %}
    <p>{{ block.settings.quote }}</p>
  {% endif %}

  <div class="zoda-circuit__review-divider"></div>

  <div class="zoda-circuit__review-person">
    {% if block.settings.image != blank %}
      {{
        block.settings.image
        | image_url: width: 96
        | image_tag:
          loading: 'lazy',
          widths: '48, 72, 96',
          sizes: '48px',
          alt: block.settings.name
      }}
    {% else %}
      <span class="zoda-circuit__review-avatar" aria-hidden="true">{{ block.settings.initials }}</span>
    {% endif %}

    <span class="zoda-circuit__review-info">
      {% if block.settings.name != blank %}
        <strong>{{ block.settings.name }}</strong>
      {% endif %}
      {% if block.settings.role != blank %}
        <em>{{ block.settings.role }}</em>
      {% endif %}
      {% if block.settings.product != blank %}
        <span class="zoda-circuit__review-product-title">{{ block.settings.product }}</span>
      {% endif %}
    </span>
  </div>

  {% if block.settings.verified %}
    <span class="zoda-circuit__review-verified">
      <svg viewBox="0 0 20 20" aria-hidden="true" focusable="false">
        <path
          d="m8.6 13.6-3-3 1.3-1.3 1.7 1.7 4.5-4.6 1.3 1.3-5.8 5.9Z"
          fill="currentColor"
        />
      </svg>
      Verified
    </span>
  {% endif %}
</article>
