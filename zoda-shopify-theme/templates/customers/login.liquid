<!-- templates/customers/login.liquid -->

<section>
  <div
    class="
      py-24
      {{ settings.x_margin }}
      {{ settings.x_alignment }}
    "
    x-data="{ forgot_password: window.location.hash === '#recover' ? true : false }"
  >
    <div
      class="w-full max-w-prose"
      x-show="!forgot_password"
    >
      <h1 class="mb-4">
        {{ 'actions.log_in' | t }}
      </h1>
      {% form 'customer_login' %}
        {% if form.errors %}
          <div class="color__bg-overlay-1 type--small border--radius mb-4 p-2">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <label for="customer_email">{{ 'labels.email' | t }}</label><br>
        <input
          id="customer_email"
          class="mb-4"
          type="email"
          name="customer[email]"
        >

        <label for="customer_password">{{ 'labels.password' | t }}</label><br>
        <input
          id="customer_password"
          class="mb-4"
          type="password"
          name="customer[password]"
        >

        <button type="submit" class="btn mb-2">
          {{ 'actions.log_in' | t }}
        </button>

        <div class="border--t-width color__border-divider-1 flex flex-col gap-4 pb-4 pt-4">
          <p>{{ 'info.dont_have_account' | t }}</p>
          <div class="flex gap-4">
            <button
              type="button"
              class="btn btn--plain"
              @click="forgot_password = true; window.location.hash = 'recover';"
            >
              {{ 'actions.forgot_password' | t }}
            </button>
            <a href="{{ routes.account_register_url }}" class="btn btn--plain">
              {{ 'actions.sign_up' | t }}
            </a>
          </div>
        </div>
      {% endform %}
      {% if settings.account_enable_shop_sign_in %}
        <div class="border--t-width color__border-divider-1 flex flex-col gap-4 pt-4">
          <p>{{ 'actions.log_in_with_shop' | t }}</p>
          <div class="flex gap-4">
            {{ shop | login_button }}
          </div>
        </div>
      {% endif %}
    </div>

    <div
      class="w-full max-w-prose"
      x-show="forgot_password"
      x-cloak
    >
      <h1 class="mb-4">
        {{ 'actions.reset_password' | t }}
      </h1>
      {% form 'recover_customer_password' %}
        {% if form.errors %}
          <div class="color__bg-overlay-1 type--small border--radius mb-4 p-2">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <label for="reset_customer_email">{{ 'labels.email' | t }}</label><br>
        <input id="reset_customer_email" class="mb-4" type="email" name="email">

        <button type="submit" class="btn mb-4">
          {{ 'actions.submit' | t }}
        </button>

        <div class="border--t-width color__border-divider-1 pt-4">
          <button
            type="button"
            class="btn btn--plain"
            @click="forgot_password = false; window.location.hash = 'login';"
          >
            {{ 'actions.log_in' | t }}
          </button>
        </div>
      {% endform %}
    </div>
  </div>
</section>
