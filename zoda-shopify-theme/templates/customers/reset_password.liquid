<!-- templates/customers/reset_password.liquid -->

<section>
  <div
    class="
      py-24
      {{ settings.x_margin }}
      {{ settings.x_alignment }}
    "
  >
    <div class="w-full max-w-prose">
      <h1>
        {{ 'actions.reset_password' | t }}
      </h1>
      {% form 'reset_customer_password' %}
        {% if form.errors %}
          <div class="color__bg-overlay-1 type--small border--radius mb-4 mt-2 p-2">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <label for="password">{{ 'labels.password' | t }}</label>
        <input
          id="password"
          class="mb-4"
          type="password"
          name="customer[password]"
        >

        <label for="password_confirmation">
          {{- 'labels.password_confirmation' | t -}}
        </label>
        <input
          id="password_confirmation"
          class="mb-4"
          type="password"
          name="customer[password_confirmation]"
        >

        <button type="submit" class="btn mb-4">
          {{ 'actions.reset_password' | t }}
        </button>

        <div class="border--t-width color__border-divider-1 pt-4">
          <p>{{ 'info.already_have_account' | t }}</p>
          <a href="{{ routes.account_login_url }}" class="btn btn--plain">
            {{ 'actions.log_in' | t }}
          </a>
        </div>
      {% endform %}
    </div>
  </div>
</section>
