<!-- snippets/blog__subtags.liquid -->
{% comment %}
  Secondary navigation for blog pages. Use tags for quick filtering.

  Usage:
    {% render 'blog__subtags' %}

  Globals:
    - settings.x_margin: horizontaly margin

  Pro tips:
    - Use this snippet on blog templates.
    - These links are populated using metafields. For more information on how to add and manage metafields, refer to our help center.
{% endcomment %}

{% assign raw_sub_tags = blog.metafields.custom.subtags %}

{% if raw_sub_tags != blank %}
  <section
    style="      background-color: {{ section.settings.color_background }};"
  >
    <nav
      class="
        border--b-width color__border-divider-1 flex
        flex-wrap
        {% if section.settings.enable_margin %}
          {{ settings.x_margin }}
        {% else %}
          window--full
        {% endif %}
      "
    >
      <div class="relative w-full">
        <div class="inline-flex w-full snap-x gap-6 overflow-x-auto scroll-smooth whitespace-nowrap">
          <div class="flex flex-none snap-center justify-center">
            <a
              href="{{ blog.url }}"
              class="
                type--big color__border-selected-2 border-b-2 py-4 no-underline
                {% if current_tags != blank %}opacity-40 !border-b-0{% endif %}
              "
            >
              {{ 'labels.all' | t }}
            </a>
          </div>
          {% for item in raw_sub_tags.value %}
            <div class="flex flex-none snap-center justify-center">
              <a
                href="{{ blog.url }}/tagged/{{ item | handle }}"
                class="
                  type--big py-4 no-underline opacity-40
                  {% assign handleized_current_tags = current_tags | handleize %}
                  {% assign handleized_item = item | handleize %}
                  {% if handleized_current_tags contains handleized_item %}
                    !opacity-100
                    border-b-2
                    color__border-selected-2
                  {% endif %}
                "
              >
                {{ item }}
              </a>
            </div>
          {% endfor %}
        </div>
      </div>
    </nav>
  </section>
{% endif %}
