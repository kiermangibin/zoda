<!-- sections/slideshow.liquid -->
{% comment %}
  This is a banner component with either a background image or video and a text overlay.

    Globals:
    - layout_horizontal: {string} Class string to set horizontal margin.
    - enable_animations: {boolean} Global setting to determine if animations are enabled.
    - layout_header_overlap: {integer} Size when setting header overlap.

    Recommendations:
    - Use images or videos that contrast well with the text overlay.
{% endcomment %}

{% liquid
  if section.settings.show_entire_image
    assign image_classes = ' object-contain group-hover/banner:scale-105 animation-300'
  else
    assign image_classes = ' object-cover h-full w-full group-hover/banner:scale-105 animation-300'
  endif

  assign enable_lazy_load = true
  if section.index == 1
    assign enable_lazy_load = false
  endif
%}

{% assign slider_size = section.blocks.size | minus: 1 %}
{% capture slides %}
  {% for block in section.blocks %}
    <div 
      class="flex h-full w-full flex-none snap-center justify-center whitespace-normal"
      x-bind:data-slide="{{ forloop.index0 }}"
      x-intersect:enter.half="index = {{ forloop.index0 }};"
      x-transition:enter="animation-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="animation-300"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0">

      {% if block.settings.url == blank %}
        <div 
          class="
            group/banner relative block flex-grow no-underline hover:no-underline hover:!opacity-100
            {{ block.settings.color_scheme }}
            {{ section.settings.layout_y_spacing }}
          "
        >
      {% else %}
        <a 
          href="{{ block.settings.url }}" 
          class="
            group/banner relative block flex-grow no-underline hover:no-underline hover:!opacity-100
            {{ block.settings.color_scheme }}
            {{ section.settings.layout_y_spacing }}
          "
        >
      {% endif %}   
        {% comment %} Media {% endcomment %}
        <div 
          class="
            absolute h-full w-full
            {% if settings.enable_animations %}
              motion-safe:scroll-blurinzoom-2-20
            {% endif %}
          ">
          
          {% comment %} Image background {% endcomment %}
          <div 
            class="animation-1000 absolute h-full w-full">

            {% comment %} Desktop image {% endcomment %}
            {% if block.settings.image_background_desktop %}
              <div class="absolute h-full w-full">
                {% render 'component__image',
                  image: block.settings.image_background_desktop,
                  max_width: 5760,
                  container_class: 'hidden md:block h-full w-full z-10',
                  image_class: image_classes,
                  crop_class: image_classes,
                  enable_lazy_load: enable_lazy_load,
                  enable_2x: true
                %}
              </div>
            {% endif %}

            {% comment %} Mobile image {% endcomment %}
            {% if block.settings.image_background_mobile == blank %}
              {% if block.settings.image_background_desktop %}
                <div class="absolute h-full w-full">
                  {% render 'component__image',
                    image: block.settings.image_background_desktop,
                    max_width: 900,
                    container_class: 'block md:hidden w-full h-full z-10',
                    image_class: image_classes,
                    crop_class: image_classes,
                    enable_lazy_load: enable_lazy_load,
                    enable_2x: true
                  %}
                </div>
              {% endif %}
            {% else %}
              <div class="absolute h-full w-full">
                {% render 'component__image',
                  image: block.settings.image_background_mobile,
                  max_width: 900,
                  container_class: 'block md:hidden w-full h-full z-10',
                  image_class: image_classes,
                  crop_class: image_classes,
                  enable_lazy_load: enable_lazy_load,
                  enable_2x: true
                %}
              </div>
            {% endif %}
          </div>

          {% comment %} Video background {% endcomment %}
          {% unless block.settings.video_background == blank %}
            <div class="absolute bottom-0 left-0 right-0 top-0 z-10">
              {% render 'component__video', 
                video: section.settings.video_background,
                container_class: 'max-w-none md:min-h-full min-w-full h-full',
                video_class: 'object-cover',
                enable_custom_controls: false,
                enable_mute_toggle: false,
                enable_autoplay: true,
                enable_loop: true
              %}
            </div>
          {% endunless %}

        </div>

        {% comment %} Banner content {% endcomment %}
        <div 
          class="absolute z-10 h-full w-full "
          {% if block.settings.enable_gradient %}
            style="background: linear-gradient( to bottom, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.4) );"
          {% endif %}>

          <div 
            class="
              flex h-full w-full flex-row flex-wrap py-4
              {{ block.settings.layout_x_alignment }}
              {{ block.settings.layout_y_alignment }}
              {% if section.settings.enable_margin %}
                {{ settings.x_margin }}
              {% else %}
                window--full
              {% endif %}
            ">

            <div 
              class="
                flex w-full flex-col gap-4
                {% if settings.enable_animations %}
                  motion-safe:scroll-blurinfadeinandout-1-100
                {% endif %}
                {% if section.settings.enable_max_width %}max-w-prose{% endif %}
                {% if block.settings.layout_x_alignment contains 'text-center' %}items-center{% endif %}
                {% if block.settings.layout_x_alignment contains 'text-right' %}items-end{% endif %}
                {% if block.settings.enable_background_overlay %}
                  p-4 w-full border--radius {{ block.settings.color_scheme }}
                {% endif %}
              ">

              {% unless block.settings.heading == blank %}
                <h1 
                  class="
                    m-0
                    {{ block.settings.color_text }}
                  ">
                  {{ block.settings.heading }}
                </h1>
              {% endunless %}

              {% unless block.settings.content == blank %}
                <div 
                  class="
                    space-y-4
                    {{ block.settings.color_text }}
                  ">
                  {{ block.settings.content }}
                </div>
              {% endunless %}

              {% unless block.settings.button_url == blank and block.settings.secondary_button_url == blank %}
                <div 
                  class="
                    flex flex-wrap gap-2 md:flex-nowrap
                    {% if block.settings.layout_x_alignment contains 'text-center' %}justify-center{% endif %}
                    {% if block.settings.layout_x_alignment contains 'text-right' %}justify-end{% endif %}
                  ">
                  {% unless block.settings.button_label == blank %}
                    {% if section.settings.url == blank %}
                      <a 
                        href="{{ block.settings.button_url }}" 
                        class="{{ block.settings.color_button }}">
                        {{ block.settings.button_label }}
                      </a>
                    {% else %}
                      <button class="{{ block.settings.color_button }}">
                        {{ block.settings.button_label }}
                      </button>
                    {% endif %}
                  {% endunless %}
                  {% unless block.settings.secondary_button_label == blank %}
                    {% if section.settings.url == blank %}
                      <a 
                        href="{{ block.settings.secondary_button_url }}" 
                        class="{{ block.settings.secondary_color_button }}">
                        {{ block.settings.secondary_button_label }}
                      </a>
                    {% else %}
                      <button 
                        class="{{ block.settings.secondary_color_button }}">
                        {{ block.settings.secondary_button_label }}
                      </button>
                    {% endif %}
                  {% endunless %}
                </div>
              {% endunless %}
              
            </div>

          </div>
        </div>
        
      {% if block.settings.url == blank %}</div>{% else %}</a>{% endif %}
    
    </div>
  {% endfor %} 
{% endcapture %}

<section
  class="
    {{ section.settings.visibility }}
    {{ section.settings.color_border }}
    {{ section.settings.style_border }}
    {% if section.settings.enable_border_margin %}
      padding--gap
    {% endif %}
  "
>
  <div
    id="{{ section.id }}"
    class="
      group/banner
      relative flex items-center justify-center !no-underline hover:no-underline hover:opacity-100
      {{ section.settings.color_scheme }}
      {% if section.settings.enable_header_overlap %}
        banner--overlap
      {% endif %}
      {% if section.settings.enable_border_margin %}
        border--radius
      {% endif %}
    "
    {% if section.settings.url != blank %}
      tabindex="-1"
    {% endif %}
    {% if section.settings.enable_header_overlap %}
      x-init="
        has_banner_overlap = true;
        header_color = header_overlay_color;
        header_border = header_overlay_border;
      "
    {% endif %}
  >
    <div class="flex w-full flex-wrap">
      <div
        class="relative w-full"
      >
        {% render 'component__slider',
          container_class: '!px-0',
          parent_class: '!px-0',
          slider_size: slider_size,
          slides: slides,
          auto_scroll_delay: section.settings.auto_scroll_delay,
          enable_first_snap: true,
          enable_arrows: true,
          enable_arrows_over: false,
          enable_indicators: true,
          enable_scrollbar: false,
          disable_scroll_padding: false,
          disable_smooth_scroll: true,
          layout_arrow_alignment: section.settings.layout_arrow_alignment,
          layout_arrow_placement: section.settings.layout_arrow_placement
        %}
      </div>
    </div>
  </div>
</section>

